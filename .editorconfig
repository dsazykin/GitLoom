# EditorConfig for Mainguard — keeps formatting consistent across Rider / VS / VS Code.
# https://editorconfig.org  +  .NET analyzer/style rules.
root = true

# ---- All files ----
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Windows-only scripts must keep CRLF (mirrors .gitattributes).
[*.{bat,cmd,ps1}]
end_of_line = crlf

[*.{json,yml,yaml,axaml,xaml,xml,csproj,props,targets,slnx}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

# ---- C# ----
[*.cs]
indent_size = 4

# Prefer file-scoped namespaces (matches the existing codebase).
csharp_style_namespace_declarations = file_scoped:warning

# 'this.' is not used in this codebase.
dotnet_style_qualification_for_field = false:suggestion
dotnet_style_qualification_for_property = false:suggestion
dotnet_style_qualification_for_method = false:suggestion
dotnet_style_qualification_for_event = false:suggestion

# 'var' is used freely here.
csharp_style_var_for_built_in_types = true:silent
csharp_style_var_when_type_is_apparent = true:silent
csharp_style_var_elsewhere = true:silent

# Modern C# expression preferences.
csharp_prefer_braces = true:suggestion
csharp_style_expression_bodied_methods = when_on_single_line:silent
csharp_using_directive_placement = outside_namespace:suggestion
dotnet_sort_system_directives_first = true

# Nullable / correctness — surfaced as warnings, not silently ignored.
dotnet_diagnostic.CS8618.severity = warning
dotnet_diagnostic.CS8600.severity = warning
dotnet_diagnostic.CS8602.severity = warning
dotnet_diagnostic.CS8625.severity = warning

# ---- Naming ----
# Private fields: _camelCase (matches [ObservableProperty] backing fields).
dotnet_naming_rule.private_fields_camelcase.severity = suggestion
dotnet_naming_rule.private_fields_camelcase.symbols = private_fields
dotnet_naming_rule.private_fields_camelcase.style = underscore_camel_case
dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private
dotnet_naming_style.underscore_camel_case.required_prefix = _
dotnet_naming_style.underscore_camel_case.capitalization = camel_case

# Interfaces: IPascalCase.
dotnet_naming_rule.interfaces_start_with_i.severity = warning
dotnet_naming_rule.interfaces_start_with_i.symbols = interfaces
dotnet_naming_rule.interfaces_start_with_i.style = begins_with_i
dotnet_naming_symbols.interfaces.applicable_kinds = interface
dotnet_naming_style.begins_with_i.required_prefix = I
dotnet_naming_style.begins_with_i.capitalization = pascal_case

# Types & public members: PascalCase.
dotnet_naming_rule.types_pascalcase.severity = suggestion
dotnet_naming_rule.types_pascalcase.symbols = types_and_members
dotnet_naming_rule.types_pascalcase.style = pascal_case
dotnet_naming_symbols.types_and_members.applicable_kinds = class,struct,enum,property,method,event
dotnet_naming_symbols.types_and_members.applicable_accessibilities = public,internal,protected
dotnet_naming_style.pascal_case.capitalization = pascal_case
