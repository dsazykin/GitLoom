<!-- ATELIER — warm craftsman dark.
     Warm charcoal surfaces, cream text, copper/brass accent, sage and
     oxblood semantics. Plays on the "Loom" weaving-craft heritage. -->
<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Surfaces -->
    <SolidColorBrush x:Key="SurfaceWindow" Color="#171512"/>
    <SolidColorBrush x:Key="SurfacePanel" Color="#1D1A16"/>
    <SolidColorBrush x:Key="SurfaceDeep" Color="#121009"/>
    <SolidColorBrush x:Key="SurfaceCard" Color="#24201A"/>
    <SolidColorBrush x:Key="SurfaceHover" Color="#2E2921"/>
    <SolidColorBrush x:Key="SurfaceHoverGhost" Color="#002E2921"/>
    <SolidColorBrush x:Key="ButtonBg" Color="#272219"/>
    <SolidColorBrush x:Key="BorderHairline" Color="#322D25"/>

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimary" Color="#EDE7DB"/>
    <SolidColorBrush x:Key="TextMuted" Color="#9C9284"/>
    <SolidColorBrush x:Key="OnAccent" Color="#171512"/>

    <!-- Signature accent -->
    <SolidColorBrush x:Key="AccentBrush" Color="#D8A25A"/>
    <SolidColorBrush x:Key="AccentHover" Color="#E4B677"/>
    <SolidColorBrush x:Key="AccentSelection" Color="#26D8A25A"/>

    <!-- Semantic -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#8FBC7F"/>
    <SolidColorBrush x:Key="SuccessHover" Color="#A5CC97"/>
    <SolidColorBrush x:Key="DangerBrush" Color="#E5726A"/>
    <SolidColorBrush x:Key="DangerHover" Color="#EC8F88"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#D9B04C"/>
    <SolidColorBrush x:Key="InfoBrush" Color="#6E96BE"/>

    <!-- Agent status micro-badge tokens (P2-13): resolved by AgentStatusBrushConverter; glyph
         carries state (E1/E2), brush is the second channel. -->
    <SolidColorBrush x:Key="AgentStatusWorkingBrush" Color="#6E96BE"/>
    <SolidColorBrush x:Key="AgentStatusVerifyingBrush" Color="#D8A25A"/>
    <SolidColorBrush x:Key="AgentStatusVerifiedBrush" Color="#8FBC7F"/>
    <SolidColorBrush x:Key="AgentStatusStaleBrush" Color="#D9B04C"/>
    <SolidColorBrush x:Key="AgentStatusAwaitingReviewBrush" Color="#AC57A5"/>
    <SolidColorBrush x:Key="AgentStatusConflictBrush" Color="#E5726A"/>
    <SolidColorBrush x:Key="AgentStatusRateLimitedBrush" Color="#D9B04C"/>
    <SolidColorBrush x:Key="AgentStatusDeadBrush" Color="#E5726A"/>
    <SolidColorBrush x:Key="AgentStatusPausedBrush" Color="#9C9284"/>

    <!-- Commit-graph lanes -->
    <!-- Lanes decoupled from semantic status tokens (DESIGN.md §2); retuned per ThemeRefinement Finding B. -->
    <SolidColorBrush x:Key="Lane1" Color="#E4C399"/>
    <SolidColorBrush x:Key="Lane2" Color="#AC57A5"/>
    <SolidColorBrush x:Key="Lane3" Color="#C7E0BF"/>
    <SolidColorBrush x:Key="Lane4" Color="#3A698E"/>
    <SolidColorBrush x:Key="Lane5" Color="#DA9A91"/>

    <!-- Diff line backgrounds -->
    <SolidColorBrush x:Key="DiffAddedBg" Color="#1E2A1A"/>
    <SolidColorBrush x:Key="DiffRemovedBg" Color="#33201D"/>
    <!-- Intra-line (word-level) emphasis + trailing-whitespace marker (T-13) -->
    <SolidColorBrush x:Key="DiffAddedEmphasis" Color="#668FBC7F"/>
    <SolidColorBrush x:Key="DiffRemovedEmphasis" Color="#66E5726A"/>
    <SolidColorBrush x:Key="DiffWhitespaceMarker" Color="#55D9B04C"/>

    <!-- Blame age-heat gutter (T-11): recent → BlameAgeNew, old → BlameAgeOld. -->
    <SolidColorBrush x:Key="BlameAgeNew" Color="#D9A441"/>
    <SolidColorBrush x:Key="BlameAgeOld" Color="#4A4238"/>

    <!-- Terminal cell palette (P2-03 interim engine). Default surface + the 16 ANSI
         colours as tokens so the cell renderer follows the active theme and Daylight
         Loom stays readable; the 256-colour cube (16-255) is computed in code. -->
    <SolidColorBrush x:Key="TerminalBackground" Color="#141018"/>
    <SolidColorBrush x:Key="TerminalForeground" Color="#EDE6F2"/>
    <SolidColorBrush x:Key="TerminalCursor" Color="#C08AF0"/>
    <SolidColorBrush x:Key="TerminalAnsi0" Color="#000000"/>
    <SolidColorBrush x:Key="TerminalAnsi1" Color="#CD3131"/>
    <SolidColorBrush x:Key="TerminalAnsi2" Color="#2AA745"/>
    <SolidColorBrush x:Key="TerminalAnsi3" Color="#C7C43B"/>
    <SolidColorBrush x:Key="TerminalAnsi4" Color="#3B6FD6"/>
    <SolidColorBrush x:Key="TerminalAnsi5" Color="#B454C9"/>
    <SolidColorBrush x:Key="TerminalAnsi6" Color="#2EC5CE"/>
    <SolidColorBrush x:Key="TerminalAnsi7" Color="#D0D0D0"/>
    <SolidColorBrush x:Key="TerminalAnsi8" Color="#6A737D"/>
    <SolidColorBrush x:Key="TerminalAnsi9" Color="#F14C4C"/>
    <SolidColorBrush x:Key="TerminalAnsi10" Color="#3FC56B"/>
    <SolidColorBrush x:Key="TerminalAnsi11" Color="#EAE05B"/>
    <SolidColorBrush x:Key="TerminalAnsi12" Color="#5C8DF0"/>
    <SolidColorBrush x:Key="TerminalAnsi13" Color="#D67BEA"/>
    <SolidColorBrush x:Key="TerminalAnsi14" Color="#4FE0E8"/>
    <SolidColorBrush x:Key="TerminalAnsi15" Color="#FFFFFF"/>
</ResourceDictionary>
