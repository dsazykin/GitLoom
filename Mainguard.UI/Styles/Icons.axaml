    <!-- Signing badges (T-15): verified = shield+check, untrusted = shield+exclamation,
         bad = shield+X. Untrusted (can't-verify) and bad (contents don't match signature)
         are genuinely different states and MUST NOT differ by color alone — distinct
         glyphs so the meaning survives with zero color (accessibility). -->
    <StreamGeometry x:Key="SignatureVerifiedIcon">M12,1L3,5V11C3,16.55 6.84,21.74 12,23C17.16,21.74 21,16.55 21,11V5L12,1M10,17L6,13L7.41,11.59L10,14.17L16.59,7.58L18,9L10,17Z</StreamGeometry>
