<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- ============================================================
         Theme-INDEPENDENT design-system resources: typography + icons.
         Moved out of Mainguard.App.Shell/App.axaml into Mainguard.UI (step 2c)
         so the shell and the Pro UI share one icon/font vocabulary.
         Deliberately NOT under /Themes/ — ThemeManager.Apply removes
         every merged dictionary whose source contains "/Themes/" when it
         swaps the active theme; this one must survive that sweep.
         Color tokens live in Themes/*.axaml; reference them with
         DynamicResource. Everything here is fonts + icon geometries.
         ============================================================ -->

    <!-- Typography -->
    <FontFamily x:Key="FontUi">Inter, SF Pro Text, Segoe UI Variable, Segoe UI, Cantarell, Noto Sans, sans-serif</FontFamily>
    <FontFamily x:Key="FontMono">JetBrains Mono, Cascadia Mono, SF Mono, Consolas, DejaVu Sans Mono, monospace</FontFamily>

