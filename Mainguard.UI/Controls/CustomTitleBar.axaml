<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:Mainguard.UI.Controls"
             x:Class="Mainguard.UI.Controls.CustomTitleBar">
    <!-- Reusable hand-drawn title bar (#77) — drag/minimize/maximize/close, matching MainWindow's
         chrome so every secondary window/dialog shares one consistent look. Reads Title/CanMinimize/
         CanMaximize straight off its ancestor Window; no per-window wiring needed beyond
         <controls:CustomTitleBar/> in row 0 of a ChromedWindow-derived window's root Auto,* Grid. -->
    <Border Background="{DynamicResource SurfacePanel}" BorderBrush="{DynamicResource BorderHairline}" BorderThickness="0,0,0,1"
            Padding="12,0,8,0" MinHeight="40"
            PointerPressed="TitleBar_PointerPressed" DoubleTapped="TitleBar_DoubleTapped">
        <Grid ColumnDefinitions="*,Auto">
            <TextBlock Grid.Column="0" Text="{Binding $parent[Window].Title}" Foreground="{DynamicResource TextPrimary}"
                       FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Stretch">
                <Button Classes="WindowButton" ToolTip.Tip="Minimize" Click="MinimizeButton_Click">
                    <PathIcon Data="{StaticResource WindowMinimizeIcon}" Width="11" Height="11" Foreground="{DynamicResource TextMuted}"/>
                </Button>
                <Button Classes="WindowButton" ToolTip.Tip="Maximize" Click="MaximizeButton_Click">
                    <PathIcon x:Name="MaximizeIcon" Data="{StaticResource WindowMaximizeIcon}" Width="11" Height="11" Foreground="{DynamicResource TextMuted}"/>
                </Button>
                <Button Classes="WindowButton Close" ToolTip.Tip="Close" Click="CloseButton_Click">
                    <PathIcon Data="{StaticResource DismissIcon}" Width="12" Height="12" Foreground="{DynamicResource TextMuted}"/>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
