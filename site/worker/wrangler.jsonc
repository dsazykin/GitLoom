{
  // Mainguard marketing-site backend. Deploy: npx wrangler deploy (needs
  // CLOUDFLARE_API_TOKEN + CLOUDFLARE_ACCOUNT_ID in the environment).
  // Renamed from mainguard-site-api 2026-07-16 — a rename creates a NEW worker, so
  // secrets must be re-put on it; the old worker stays deployed until traffic
  // drains (rebrand plan Phase 5), then gets deleted. Same D1 database.
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mainguard-site-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-01",
  "observability": { "enabled": true },
  "vars": {
    "NOTIFY_EMAIL": "daniel.sazykin@gmail.com"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "mainguard-site",
      "database_id": "8202aed8-7929-4bcb-9404-9431d2385556"
    }
  ]
  // Secrets (set via `npx wrangler secret put <NAME>`):
  //   TURNSTILE_SECRET — Turnstile widget secret key
  //   ADMIN_TOKEN      — bearer token for GET /api/admin/submissions
  //   RESEND_API_KEY   — optional; enables email notifications to NOTIFY_EMAIL
}
