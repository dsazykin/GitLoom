<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Mainguard.App.Shell.ViewModels"
        xmlns:views="using:Mainguard.App.Shell.Views"
        x:Class="Mainguard.App.Shell.Views.ReleasesWindow"
        x:DataType="vm:ReleasesViewModel"
        Title="Releases"
        Width="820"
        Height="680"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SurfaceWindow}">
    <!-- Content extracted to ReleasesView (2026-07-11) so the same surface hosts as a
         MainWindow section tab; this window remains for the legacy dialog entry points. -->
    <views:ReleasesView/>
</Window>
