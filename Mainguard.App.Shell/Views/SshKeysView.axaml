<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Mainguard.App.Shell.ViewModels"
        x:Class="Mainguard.App.Shell.Views.SshKeysView"
        x:DataType="vm:SshKeysViewModel">
    <StackPanel Spacing="15" MaxWidth="620">
        <StackPanel Orientation="Horizontal" Spacing="10">
            <PathIcon Data="{StaticResource KeyIcon}" Width="18" Height="18" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
            <TextBlock Text="SSH Keys" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
        </StackPanel>

        <ItemsControl ItemsSource="{Binding Keys}">
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="vm:SshKeyRowViewModel">
                    <Border Classes="Card" Background="{DynamicResource SurfaceCard}" Padding="14" Margin="0,0,0,2" CornerRadius="8">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource TextPrimary}"/>
                                    <Border CornerRadius="999" Padding="8,2" Background="{DynamicResource SurfaceHover}" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding KeyType}" FontSize="10" Foreground="{DynamicResource TextMuted}"/>
                                    </Border>
                                    <Border CornerRadius="999" Padding="8,2" Background="{DynamicResource AccentSelection}" VerticalAlignment="Center" IsVisible="{Binding HasStoredPassphrase}">
                                        <TextBlock Text="passphrase saved" FontSize="10" Foreground="{DynamicResource AccentBrush}"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="{Binding PublicKeyText}" Classes="Mono" FontSize="11" Foreground="{DynamicResource TextMuted}" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Copy public key" Classes="Primary" Padding="12,4" VerticalAlignment="Center" Command="{Binding CopyPublicKeyCommand}"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <TextBlock Text="No SSH keys found in ~/.ssh yet." Foreground="{DynamicResource TextMuted}" FontSize="12"
                   IsVisible="{Binding !Keys.Count}" Margin="4,8"/>

        <Border Background="{DynamicResource SurfaceCard}" CornerRadius="8" Padding="12">
            <StackPanel Spacing="8">
                <TextBlock Text="Generate a new ed25519 key" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" FontSize="13"/>
                <Grid ColumnDefinitions="110,*">
                    <TextBlock Grid.Column="0" Text="Name" Foreground="{DynamicResource TextMuted}" FontSize="12" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding NewKeyName, UpdateSourceTrigger=PropertyChanged}" Watermark="id_ed25519"/>
                </Grid>
                <Grid ColumnDefinitions="110,*">
                    <TextBlock Grid.Column="0" Text="Comment" Foreground="{DynamicResource TextMuted}" FontSize="12" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding NewKeyComment, UpdateSourceTrigger=PropertyChanged}" Watermark="you@example.com (optional)"/>
                </Grid>
                <Grid ColumnDefinitions="110,*,Auto">
                    <TextBlock Grid.Column="0" Text="Passphrase" Foreground="{DynamicResource TextMuted}" FontSize="12" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" PasswordChar="•" Text="{Binding NewKeyPassphrase, UpdateSourceTrigger=PropertyChanged}" Watermark="optional but recommended"/>
                    <Button Grid.Column="2" Content="Generate" Classes="Accent" Padding="14,4" Margin="8,0,0,0" Command="{Binding GenerateKeyCommand}"/>
                </Grid>
            </StackPanel>
        </Border>

        <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource TextMuted}"
                   TextWrapping="Wrap" FontSize="12"
                   IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
    </StackPanel>
</UserControl>
