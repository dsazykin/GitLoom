<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:GitLoom.App.ViewModels"
             xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:DataType="vm:AnalyticsViewModel"
             x:Class="GitLoom.App.Views.AnalyticsView">

    <Grid>
        <!-- Skeleton Ghost Loader -->
        <Grid IsVisible="{Binding IsLoading}" Background="{DynamicResource SurfaceWindow}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Analyzing Repository History..." FontSize="18" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Foreground="{DynamicResource AccentBrush}" Background="{DynamicResource SurfaceCard}"/>
            </StackPanel>
        </Grid>

        <!-- Analytics Content -->
        <ScrollViewer IsVisible="{Binding !IsLoading}">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto" Margin="30">

                <!-- Language Breakdown (categorical donut) -->
                <Border Grid.Row="0" Background="{DynamicResource SurfaceCard}" CornerRadius="12" Padding="20" Margin="0,0,0,24">
                    <StackPanel>
                        <TextBlock Text="Language Breakdown (Bytes)" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,16"/>
                        <lvc:PieChart Series="{Binding LanguageSeries}" Height="300" LegendPosition="Right"
                                      IsVisible="{Binding HasLanguageData}"/>
                        <TextBlock Text="No source files to analyze." Foreground="{DynamicResource TextMuted}"
                                   IsVisible="{Binding !HasLanguageData}" Margin="0,20"/>
                    </StackPanel>
                </Border>

                <!-- Weekly Churn (time series) -->
                <Border Grid.Row="1" Background="{DynamicResource SurfaceCard}" CornerRadius="12" Padding="20" Margin="0,0,0,24">
                    <StackPanel>
                        <TextBlock Text="Code Churn per Week (Lines)" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,16"/>
                        <lvc:CartesianChart Series="{Binding ChurnSeries}"
                                            XAxes="{Binding ChurnXAxes}"
                                            YAxes="{Binding ChurnYAxes}"
                                            LegendPosition="Top"
                                            Height="300"
                                            IsVisible="{Binding HasCommitData}"/>
                        <TextBlock Text="No commit history yet." Foreground="{DynamicResource TextMuted}"
                                   IsVisible="{Binding !HasCommitData}" Margin="0,20"/>
                    </StackPanel>
                </Border>

                <!-- Commit Punch Card (sequential heatmap) -->
                <Border Grid.Row="2" Background="{DynamicResource SurfaceCard}" CornerRadius="12" Padding="20" Margin="0,0,0,24">
                    <StackPanel>
                        <TextBlock Text="Commit Punch Card" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,16"/>
                        <lvc:CartesianChart Series="{Binding PunchCardSeries}"
                                            XAxes="{Binding PunchCardXAxes}"
                                            YAxes="{Binding PunchCardYAxes}"
                                            Height="360"
                                            IsVisible="{Binding HasCommitData}"/>
                    </StackPanel>
                </Border>

                <!-- Top Contributors (ranked bars) -->
                <Border Grid.Row="3" Background="{DynamicResource SurfaceCard}" CornerRadius="12" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Top Contributors (Commits)" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,16"/>
                        <lvc:CartesianChart Series="{Binding ContributorSeries}"
                                            XAxes="{Binding ContributorXAxes}"
                                            YAxes="{Binding ContributorYAxes}"
                                            Height="320"
                                            IsVisible="{Binding HasCommitData}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
