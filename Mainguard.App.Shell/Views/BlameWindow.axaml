<ChromedWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Mainguard.App.Shell.ViewModels"
        xmlns:views="using:Mainguard.App.Shell.Views"
        xmlns:controls="clr-namespace:Mainguard.App.Shell.Controls"
        x:Class="Mainguard.App.Shell.Views.BlameWindow"
        x:DataType="vm:BlameViewModel"
        Title="Blame"
        Width="1040" Height="660"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SurfaceWindow}">

    <!-- Hosts the T-11 blame view (gutter) + T-32 "Why this line" popover. The BlameView UserControl
         inherits this window's BlameViewModel DataContext. -->
    <Grid RowDefinitions="Auto,*">
        <CustomTitleBar Grid.Row="0"/>
        <views:BlameView Grid.Row="1"/>
    </Grid>
</ChromedWindow>
