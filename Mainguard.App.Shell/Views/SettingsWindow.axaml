<ChromedWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Mainguard.App.Shell.ViewModels"
        xmlns:views="using:Mainguard.App.Shell.Views"
        xmlns:controls="clr-namespace:Mainguard.App.Shell.Controls"
        x:Class="Mainguard.App.Shell.Views.SettingsWindow"
        x:DataType="vm:SettingsViewModel"
        Title="Settings"
        Width="440" Height="560"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SurfaceWindow}">
    <Grid RowDefinitions="Auto,*">
    <CustomTitleBar Grid.Row="0"/>
    <Border Grid.Row="1" Padding="20">
        <Grid RowDefinitions="Auto,Auto,*,Auto,Auto">

            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="0,0,0,15">
                <PathIcon Data="{StaticResource MenuIcon}" Width="18" Height="18" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                <TextBlock Text="Settings" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock Grid.Row="1" Text="Pinned top-menu icons" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" FontSize="13" Margin="0,0,0,4"/>
            <TextBlock Grid.Row="1" Text="Pinned items appear as their own icon button next to Push/Pull, instead of living inside the Collaborate/Tools menus."
                       Foreground="{DynamicResource TextMuted}" FontSize="11" TextWrapping="Wrap" Margin="0,20,0,0"/>

            <!-- Pin list -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,10,0,0">
                <ItemsControl ItemsSource="{Binding PinRows}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:SettingsPinRowViewModel">
                            <CheckBox IsChecked="{Binding IsPinned, Mode=TwoWay}" Content="{Binding Label}"
                                      Foreground="{DynamicResource TextPrimary}" Margin="0,4"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- About / versions (read-only): app + daemon + GitLoomOS payload, fetched once on
                 open (see SettingsWindow.axaml.cs Opened hook) with a manual refresh — no polling. -->
            <Border Grid.Row="3" Classes="Card" Padding="14,12" Margin="0,15,0,0">
                <StackPanel Spacing="6">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="About Mainguard" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}" FontSize="13" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Classes="Secondary" Padding="6,3"
                                Command="{Binding Versions.RefreshCommand}"
                                IsEnabled="{Binding !Versions.IsRefreshing}"
                                ToolTip.Tip="Check versions again">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <PathIcon Data="{StaticResource RefreshIcon}" Width="11" Height="11"/>
                                <TextBlock Text="Refresh" FontSize="11"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                    <Grid ColumnDefinitions="130,*" RowDefinitions="Auto,Auto,Auto">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="App" Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="0,2"/>
                        <SelectableTextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Versions.AppVersion}"
                                             Foreground="{DynamicResource TextPrimary}" FontSize="12" Margin="0,2" TextWrapping="Wrap"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Mainguard OS daemon" Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="0,2"/>
                        <SelectableTextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Versions.DaemonVersion}"
                                             Foreground="{DynamicResource TextPrimary}" FontSize="12" Margin="0,2" TextWrapping="Wrap"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Mainguard OS payload" Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="0,2"/>
                        <SelectableTextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Versions.OsVersion}"
                                             Foreground="{DynamicResource TextPrimary}" FontSize="12" Margin="0,2" TextWrapping="Wrap"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Footer -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                <Button Content="Close" Classes="Secondary" Padding="15,6" Click="CloseButton_Click"/>
            </StackPanel>
        </Grid>
    </Border>
    </Grid>
</ChromedWindow>
