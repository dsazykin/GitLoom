<ChromedWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Mainguard.App.Shell.ViewModels"
        xmlns:views="using:Mainguard.App.Shell.Views"
        x:Class="Mainguard.App.Shell.Views.SettingsWindow"
        x:DataType="vm:SettingsViewModel"
        Title="Settings"
        Width="880" Height="620"
        MinWidth="720" MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SurfaceWindow}">
    <Grid RowDefinitions="Auto,*">
        <CustomTitleBar Grid.Row="0"/>
        <Grid Grid.Row="1" ColumnDefinitions="220,*">

            <!-- Sidebar: one row per Settings page (RailSectionViewModel's pattern, shrunk down —
                 every page is always enabled, no adornments). -->
            <Border Grid.Column="0" Background="{DynamicResource SurfacePanel}"
                    BorderBrush="{DynamicResource BorderHairline}" BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Pages}" Margin="8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:SettingsPageRowViewModel">
                                <Button Classes="railItem" Classes.active="{Binding IsActive}"
                                        Command="{Binding ActivateCommand}" HorizontalAlignment="Stretch" Margin="0,0,0,2">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <PathIcon Width="15" Height="15" Data="{Binding IconResourceKey, Converter={x:Static ResourceKeyToGeometryConverter.Instance}}"
                                                  Foreground="{DynamicResource TextPrimary}"/>
                                        <TextBlock Text="{Binding Label}" FontSize="13" Foreground="{DynamicResource TextPrimary}"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <!-- Content: resolves the active page's ViewModel through the app-wide ViewLocator, same
                 as MainWindow's own CurrentWorkspace/RailSections content areas. -->
            <ScrollViewer Grid.Column="1" Padding="28,24">
                <ContentControl Content="{Binding ActivePageContent}"/>
            </ScrollViewer>
        </Grid>
    </Grid>
</ChromedWindow>
