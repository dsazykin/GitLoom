<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Mainguard.App.Shell.ViewModels"
        xmlns:views="using:Mainguard.App.Shell.Views"
        x:Class="Mainguard.App.Shell.Views.PullRequestsWindow"
        x:DataType="vm:PullRequestsViewModel"
        Title="Pull Requests"
        Width="760"
        Height="620"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SurfaceWindow}">
    <!-- Content extracted to PullRequestsView (2026-07-11) so the same surface hosts as a
         MainWindow section tab; this window remains for the legacy dialog entry points. -->
    <views:PullRequestsView/>
</Window>
