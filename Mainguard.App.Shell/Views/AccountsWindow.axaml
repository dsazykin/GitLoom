<ChromedWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Mainguard.App.Shell.ViewModels"
        xmlns:views="using:Mainguard.App.Shell.Views"
        x:Class="Mainguard.App.Shell.Views.AccountsWindow"
        x:DataType="vm:AccountsViewModel"
        Title="Accounts"
        Width="600" Height="560"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SurfaceWindow}">
    <!-- Thin standalone-dialog wrapper around the shared AccountsView content — kept for the
         first-run "Sign in to a host" flow (App.axaml.cs), which runs before the Settings window
         exists. In-session callers go through Settings' Accounts page instead. -->
    <Grid RowDefinitions="Auto,*,Auto">
        <CustomTitleBar Grid.Row="0"/>
        <Border Grid.Row="1" Padding="20">
            <views:AccountsView/>
        </Border>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,20,15">
            <Button Content="Close" Classes="Secondary" Padding="15,6" Command="{Binding CloseCommand}"/>
        </StackPanel>
    </Grid>
</ChromedWindow>
