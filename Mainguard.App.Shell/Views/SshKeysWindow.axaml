<ChromedWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Mainguard.App.Shell.ViewModels"
        xmlns:views="using:Mainguard.App.Shell.Views"
        x:Class="Mainguard.App.Shell.Views.SshKeysWindow"
        x:DataType="vm:SshKeysViewModel"
        Title="SSH Keys"
        Width="620" Height="580"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SurfaceWindow}">
    <!-- Thin standalone-dialog wrapper around the shared SshKeysView content — kept for the
         first-run "SSH keys" flow (App.axaml.cs), which runs before the Settings window exists.
         In-session callers go through Settings' SSH Keys page instead. -->
    <Grid RowDefinitions="Auto,*,Auto">
        <CustomTitleBar Grid.Row="0"/>
        <Border Grid.Row="1" Padding="20">
            <views:SshKeysView/>
        </Border>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,20,15">
            <Button Content="Close" Classes="Secondary" Padding="15,6" Command="{Binding CloseCommand}"/>
        </StackPanel>
    </Grid>
</ChromedWindow>
