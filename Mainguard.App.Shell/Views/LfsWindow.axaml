<ChromedWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Mainguard.App.Shell.ViewModels"
        xmlns:views="using:Mainguard.App.Shell.Views"
        xmlns:controls="clr-namespace:Mainguard.App.Shell.Controls"
        x:Class="Mainguard.App.Shell.Views.LfsWindow"
        x:DataType="vm:LfsViewModel"
        Title="Git LFS"
        Width="640" Height="620"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SurfaceWindow}">
    <Grid RowDefinitions="Auto,*">
    <CustomTitleBar Grid.Row="0"/>
    <Border Grid.Row="1" Padding="20">
        <Grid RowDefinitions="Auto,Auto,*,Auto,Auto">

            <!-- Header -->
            <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,15">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                    <PathIcon Data="{StaticResource CloudIcon}" Width="18" Height="18" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="Git LFS" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Grid.Column="2" Classes="IconButton" Command="{Binding RefreshCommand}" ToolTip.Tip="Refresh" IsEnabled="{Binding IsAvailable}">
                    <PathIcon Data="{StaticResource RefreshIcon}" Width="14" Height="14" Foreground="{DynamicResource TextMuted}"/>
                </Button>
            </Grid>

            <!-- Not-installed notice -->
            <Border Grid.Row="1" Background="{DynamicResource SurfaceCard}" CornerRadius="8" Padding="12" Margin="0,0,0,15"
                    IsVisible="{Binding !IsAvailable}">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <PathIcon Data="{StaticResource WarningIcon}" Width="16" Height="16" Foreground="{DynamicResource WarningBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="Git LFS is not installed on this system. Install git-lfs and reopen this panel."
                               Foreground="{DynamicResource TextMuted}" FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Enable toggle + patterns + files -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" IsVisible="{Binding IsAvailable}">
                <StackPanel Spacing="15">

                    <!-- Per-repo enable toggle -->
                    <Border Classes="Card" Background="{DynamicResource SurfaceCard}" Padding="12" CornerRadius="8">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                <TextBlock Text="Enable Git LFS for this repository" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" FontSize="13"/>
                                <TextBlock Text="Installs the LFS clean/smudge filters into this repo's config." Foreground="{DynamicResource TextMuted}" FontSize="11"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding IsEnabled}" IsEnabled="{Binding !IsBusy}" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Tracked patterns -->
                    <StackPanel Spacing="8">
                        <TextBlock Text="Tracked patterns" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" FontSize="13"/>

                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox Grid.Column="0" Text="{Binding NewPattern}" Watermark="Pattern to track (e.g. *.psd)" FontSize="12"/>
                            <Button Grid.Column="1" Content="Track" Classes="Primary" Padding="15,6" Margin="8,0,0,0" Command="{Binding TrackCommand}" IsEnabled="{Binding !IsBusy}"/>
                        </Grid>

                        <ItemsControl ItemsSource="{Binding Patterns}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:LfsPatternRowViewModel">
                                    <Border Background="{DynamicResource SurfaceCard}" Padding="10,6" Margin="0,0,0,4" CornerRadius="6">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Grid.Column="0" Classes="Mono" Text="{Binding Pattern}" Foreground="{DynamicResource TextPrimary}" FontSize="12" VerticalAlignment="Center"/>
                                            <Button Grid.Column="1" Content="Untrack" Classes="Secondary" Padding="10,3" Command="{Binding UntrackCommand}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock IsVisible="{Binding HasNoPatterns}" Text="No patterns are tracked with LFS yet."
                                   Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="2,2"/>
                    </StackPanel>

                    <!-- LFS files -->
                    <StackPanel Spacing="8">
                        <TextBlock Text="LFS objects" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" FontSize="13"/>

                        <ItemsControl ItemsSource="{Binding Files}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:LfsFileRowViewModel">
                                    <Border Background="{DynamicResource SurfaceCard}" Padding="10,6" Margin="0,0,0,4" CornerRadius="6">
                                        <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                                            <PathIcon Grid.Column="0" Data="{StaticResource DocumentIcon}" Width="14" Height="14" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Path}" Foreground="{DynamicResource TextPrimary}" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="2" Classes="Mono" Text="{Binding ShortOid}" Foreground="{DynamicResource TextMuted}" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                            <Panel Grid.Column="3" Margin="8,0,0,0">
                                                <Border CornerRadius="999" Padding="8,2" Background="{DynamicResource SuccessBrush}" IsVisible="{Binding IsDownloaded}">
                                                    <TextBlock Text="{Binding StatusLabel}" Foreground="{DynamicResource OnAccent}" FontSize="10"/>
                                                </Border>
                                                <Border CornerRadius="999" Padding="8,2" Background="{DynamicResource ButtonBg}" IsVisible="{Binding IsPointer}">
                                                    <TextBlock Text="{Binding StatusLabel}" Foreground="{DynamicResource TextMuted}" FontSize="10"/>
                                                </Border>
                                            </Panel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <StackPanel IsVisible="{Binding HasNoFiles}" Spacing="8" Margin="4,16" HorizontalAlignment="Center">
                            <PathIcon Data="{StaticResource CloudIcon}" Width="40" Height="40" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center" Opacity="0.5"/>
                            <TextBlock Text="No LFS objects in this repository." Foreground="{DynamicResource TextMuted}" FontSize="12" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Status / error -->
            <StackPanel Grid.Row="3" Spacing="4" Margin="0,10,0,0">
                <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource TextMuted}"
                           TextWrapping="Wrap" FontSize="12"
                           IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource DangerBrush}"
                           TextWrapping="Wrap" FontSize="12"
                           IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
            </StackPanel>

            <!-- Footer -->
            <Grid Grid.Row="4" ColumnDefinitions="Auto,*,Auto" Margin="0,15,0,0">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                    <Button Content="Pull objects" Classes="Accent" Padding="15,6" Command="{Binding PullCommand}" IsEnabled="{Binding IsAvailable}"/>
                    <Button Content="Prune…" Classes="Primary" Padding="15,6" Command="{Binding PruneCommand}" IsEnabled="{Binding IsAvailable}"/>
                </StackPanel>
                <Button Grid.Column="2" Content="Close" Classes="Secondary" Padding="15,6" Command="{Binding CloseCommand}"/>
            </Grid>
        </Grid>
    </Border>
    </Grid>
</ChromedWindow>
