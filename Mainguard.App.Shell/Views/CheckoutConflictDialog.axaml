<ChromedWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Mainguard.App.Shell.ViewModels"
        xmlns:views="using:Mainguard.App.Shell.Views"
        xmlns:controls="clr-namespace:Mainguard.App.Shell.Controls"
        x:Class="Mainguard.App.Shell.Views.CheckoutConflictDialog"
        x:DataType="vm:CheckoutConflictDialogViewModel"
        Title="Uncommitted Changes"
        Width="450" Height="220"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ExtendClientAreaToDecorationsHint="True"
        Background="{DynamicResource SurfaceWindow}">

    <Grid RowDefinitions="Auto,*">
    <CustomTitleBar Grid.Row="0"/>
    <Border Grid.Row="1" Padding="30" BorderBrush="{DynamicResource BorderHairline}" BorderThickness="1">
        <Grid RowDefinitions="Auto,*,Auto">
            
            <TextBlock Text="Uncommitted Changes" 
                       FontSize="18" 
                       FontWeight="Bold" 
                       Foreground="{DynamicResource TextPrimary}"/>

            <TextBlock Grid.Row="1" 
                       Text="You have uncommitted changes in your working directory. What would you like to do before checking out?" 
                       TextWrapping="Wrap"
                       Margin="0,20,0,0"
                       Foreground="{DynamicResource TextPrimary}"/>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                <Button Content="Cancel" 
                        Command="{Binding CancelCommand}"
                        CommandParameter="{Binding $parent[Window]}"
                        Classes="Secondary"/>
                <Button Content="Carry Over" 
                        Command="{Binding CarryOverCommand}"
                        CommandParameter="{Binding $parent[Window]}"
                        Classes="Secondary"/>
                <Button Content="Stash"
                        Command="{Binding StashCommand}"
                        CommandParameter="{Binding $parent[Window]}"
                        Classes="Success"/>
            </StackPanel>
        </Grid>
    </Border>
    </Grid>
</ChromedWindow>
