<UserControl xmlns="https://github.com/avaloniaui"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:vm="using:Mainguard.App.Shell.ViewModels"
                 xmlns:models="using:Mainguard.Git.Models"
                 xmlns:controls="clr-namespace:Mainguard.App.Shell.Controls"
                 xmlns:views="clr-namespace:Mainguard.App.Shell.Views"
                 x:Class="Mainguard.App.Shell.Views.RepoDashboardView"
                 x:DataType="vm:RepoDashboardViewModel">

    <UserControl.Styles>
        <Style Selector="Border.toast">
            <Setter Property="Background" Value="{DynamicResource SuccessBrush}" />
        </Style>
        <Style Selector="Border.toast.error">
            <Setter Property="Background" Value="{DynamicResource DangerBrush}" />
        </Style>
        <Style Selector="Button.toastClose">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="2" />
            <Setter Property="CornerRadius" Value="999" />
        </Style>
        <Style Selector="Button.toastClose:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#20000000" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="*">

        <!-- Skeleton Ghost Loader -->
        <Border Grid.Row="0" IsVisible="{Binding IsLoading}" Background="{DynamicResource SurfaceWindow}" ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20">
                <TextBlock Text="Parsing Repository..." FontSize="18" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center"/>
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Foreground="{DynamicResource AccentBrush}" Background="{DynamicResource SurfaceCard}"/>
            </StackPanel>
        </Border>

        <!-- Floating panel workspace: rounded cards on the window background,
             separated by invisible splitter gutters instead of fused borders. -->
        <Grid Grid.Row="0" IsVisible="{Binding !IsLoading}" Margin="8,8,8,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="7*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="3*" MinHeight="120" />
            </Grid.RowDefinitions>

            <!-- TOP (70%): Staging card + Diff card -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="350" MinWidth="280" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- LEFT CARD: Source Control Lists -->
                <Border Grid.Column="0" Classes="Card" Padding="12">
                    <views:StagingPanelView DataContext="{Binding StagingPanel}" />
                </Border>

                <!-- Gutter -->
                <GridSplitter Grid.Column="1" Width="8" Background="Transparent" ResizeDirection="Columns"/>

                <!-- RIGHT CARD: Diff Viewer (deepest surface — it hosts code) -->
                <Border Grid.Column="2" Classes="Card" Background="{DynamicResource SurfaceDeep}">
                    <views:DiffViewerView DataContext="{Binding DiffViewer}" />
                </Border>
            </Grid>

            <!-- Gutter -->
            <GridSplitter Grid.Row="1" Height="8" Background="Transparent" ResizeDirection="Rows"/>

            <!-- BOTTOM CARD (30%): Commit History Timeline -->
            <Border Grid.Row="2" Classes="Card">
                <views:CommitTimelineView DataContext="{Binding CommitTimeline}" />
            </Border>

        </Grid>

        <!-- Floating notification toasts (#85): stacked, newest at the bottom, capped at 3 (see
             RepoDashboardViewModel.ShowNotification/Toasts). -->
        <ItemsControl Grid.Row="1" ItemsSource="{Binding Toasts}" ZIndex="100"
                      HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="20">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Vertical" Spacing="8"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:ToastViewModel">
                    <Border Classes="toast" Classes.error="{Binding IsError}" CornerRadius="12" Padding="14,10"
                            MaxWidth="360" MinHeight="20"
                            BoxShadow="0 4 14 0 #40000000">
                        <StackPanel Spacing="4">
                            <Grid ColumnDefinitions="*,Auto,Auto">
                                <TextBlock Grid.Column="0" Text="{Binding Message}" Foreground="{DynamicResource OnAccent}" FontSize="12" FontWeight="SemiBold"
                                           TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" IsVisible="{Binding !IsExpanded}" VerticalAlignment="Center"/>
                                <Button Grid.Column="1" Classes="toastClose" ToolTip.Tip="Expand" Command="{Binding ToggleExpandedCommand}" VerticalAlignment="Center" Margin="4,0,0,0">
                                    <PathIcon Data="{StaticResource ChevronDownIcon}" Width="10" Height="10" Foreground="{DynamicResource OnAccent}"/>
                                </Button>
                                <Button Grid.Column="2" Classes="toastClose" ToolTip.Tip="Dismiss" Command="{Binding DismissCommand}" VerticalAlignment="Center" Margin="4,0,0,0">
                                    <PathIcon Data="{StaticResource DismissIcon}" Width="10" Height="10" Foreground="{DynamicResource OnAccent}"/>
                                </Button>
                            </Grid>
                            <TextBlock Text="{Binding Message}" Foreground="{DynamicResource OnAccent}" FontSize="12" FontWeight="SemiBold"
                                       TextWrapping="Wrap" IsVisible="{Binding IsExpanded}"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
