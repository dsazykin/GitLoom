<Application xmlns="https://github.com/avaloniaui"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 x:Class="GitLoom.App.App"
                 xmlns:local="using:GitLoom.App"
                 RequestedThemeVariant="Dark">

        <Application.DataTemplates>
            <local:ViewLocator/>
        </Application.DataTemplates>

        <Application.Resources>
            <!-- ============================================================
                 The design system moved to Mainguard.UI (step 2c). Color
                 tokens live in avares://Mainguard.UI/Themes/*.axaml (Midnight
                 Loom is the default active-theme slot; ThemeManager swaps this
                 dictionary at runtime — it removes any merged dict whose source
                 contains "/Themes/", so the theme-INDEPENDENT fonts + icons ride
                 in Styles/Icons.axaml instead, which survives that sweep). Views
                 reference color tokens with DynamicResource; icons/fonts by key.
                 ============================================================ -->
            <ResourceDictionary>
                <ResourceDictionary.MergedDictionaries>
                    <ResourceInclude Source="avares://Mainguard.UI/Themes/MidnightLoom.axaml"/>
                    <ResourceInclude Source="avares://Mainguard.UI/Styles/Icons.axaml"/>
                </ResourceDictionary.MergedDictionaries>
            </ResourceDictionary>
        </Application.Resources>

        <Application.Styles>
            <FluentTheme />
            <StyleInclude Source="avares://AvaloniaEdit/Themes/Fluent/AvaloniaEdit.xaml" />
            <!-- P2-13: Dock.Avalonia tab/split chrome for the per-agent workspaces is a Pro-only dependency,
                 so the reference-clean shell (Client head) must NOT include it here (an avares include forces
                 an assembly reference). The Pro edition injects it at runtime — inserted BEFORE DesignSystem
                 to preserve the "DesignSystem overrides win" ordering — via ProDesktopHost.InjectProChrome
                 (step 2f). -->

            <!-- The design-system component classes (Button.*/Border.*/ComboBox/…) moved to
                 Mainguard.UI (step 2c). Included LAST so these overrides still win over Fluent
                 (and the third-party AvaloniaEdit theme above / the Pro-injected Dock theme). -->
            <StyleInclude Source="avares://Mainguard.UI/Styles/DesignSystem.axaml" />
        </Application.Styles>
    </Application>
