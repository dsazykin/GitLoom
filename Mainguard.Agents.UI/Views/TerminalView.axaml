<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Mainguard.Agents.UI.ViewModels"
             xmlns:controls="using:Mainguard.Agents.UI.Controls"
             x:Class="Mainguard.Agents.UI.Views.TerminalView"
             x:DataType="vm:TerminalViewModel">

  <!-- P2-03 interim terminal surface: the engine renders behind ITerminalView (controls:TerminalControl),
       the ViewModel wires it to the daemon stream. No terminal/VT logic lives here or in code-behind;
       the code-behind only binds the concrete control to the ViewModel (invariant 3). -->
  <Border Background="{DynamicResource TerminalBackground}" Padding="6">
    <Grid RowDefinitions="Auto,*">
      <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="2,0,0,6">
        <TextBlock Text="Terminal" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
        <TextBlock Text="{Binding AgentId, StringFormat='agent {0}'}"
                   Classes="Mono" FontSize="12" Foreground="{DynamicResource TextMuted}"
                   VerticalAlignment="Center"/>
      </StackPanel>

      <controls:TerminalControl x:Name="Terminal" Grid.Row="1"/>
    </Grid>
  </Border>
</UserControl>
