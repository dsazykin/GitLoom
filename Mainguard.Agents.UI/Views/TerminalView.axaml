<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Mainguard.Agents.UI.ViewModels"
             xmlns:controls="using:Mainguard.Agents.UI.Controls"
             x:Class="Mainguard.Agents.UI.Views.TerminalView"
             x:DataType="vm:TerminalViewModel">

  <!-- The terminal surface: the engine renders behind ITerminalView, the ViewModel wires it to the
       daemon stream. The concrete control (interim TerminalControl or the P2-18 TerminalGridControl)
       is chosen by the TerminalEngine flag in code-behind, which only binds it to the ViewModel —
       no terminal/VT logic lives here or there (invariant 3). -->
  <Border Background="{DynamicResource TerminalBackground}" Padding="6">
    <Grid RowDefinitions="Auto,*">
      <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="2,0,0,6">
        <TextBlock Text="Terminal" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
        <TextBlock Text="{Binding AgentId, StringFormat='agent {0}'}"
                   Classes="Mono" FontSize="12" Foreground="{DynamicResource TextMuted}"
                   VerticalAlignment="Center"/>
      </StackPanel>

      <ContentControl x:Name="TerminalHost" Grid.Row="1"/>
    </Grid>
  </Border>
</UserControl>
