<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Mainguard.Agents.UI.ViewModels"
        x:Class="Mainguard.Agents.UI.Views.EgressAllowlistView"
        x:DataType="vm:EgressAllowlistViewModel"
        Title="Agent Network Allowlist"
        Width="600" Height="580"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SurfaceWindow}">
    <Border Padding="20">
        <Grid RowDefinitions="Auto,Auto,Auto,*,Auto,Auto,Auto">

            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="0,0,0,6">
                <PathIcon Data="{StaticResource CloudIcon}" Width="18" Height="18" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                <TextBlock Text="Agent egress allowlist" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Grid.Row="1" Margin="0,0,0,12" FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource TextMuted}"
                       Text="Agents reach the network only through the proxy. Everything not listed here is denied by default. Your git host is deliberately absent — agents fetch git dependencies through the daemon's read-only git proxy, never directly."/>

            <!-- A6 warning banner: a git-host entry re-opens a direct route -->
            <Border Grid.Row="2" Background="{DynamicResource SurfaceCard}" BorderBrush="{DynamicResource WarningBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="12" Margin="0,0,0,10" IsVisible="{Binding HasGitHostWarning}">
                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Left" Text="&#x26A0;" Foreground="{DynamicResource WarningBrush}" FontSize="14"
                               VerticalAlignment="Top" Margin="0,0,8,0"/>
                    <TextBlock Foreground="{DynamicResource WarningBrush}" FontSize="12" TextWrapping="Wrap"
                               Text="A git-host entry is present. This re-opens a direct route to the git host and defeats the default-deny exfiltration control (A6)."/>
                </DockPanel>
            </Border>

            <!-- Entries -->
            <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="8">
                    <ItemsControl ItemsSource="{Binding Entries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:EgressAllowlistRowViewModel">
                                <Border Classes="Card" Background="{DynamicResource SurfaceCard}" Padding="12" Margin="0,0,0,2" CornerRadius="8">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Grid.Column="0" Spacing="3">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" FontSize="13"/>
                                                <Border Background="{DynamicResource WarningBrush}" CornerRadius="4" Padding="6,1" IsVisible="{Binding DefeatsA6}">
                                                    <TextBlock Text="defeats A6" Foreground="{DynamicResource SurfaceWindow}" FontSize="10" FontWeight="Bold"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding HostPattern}" Classes="Mono" Foreground="{DynamicResource TextMuted}" FontSize="12"/>
                                            <TextBlock Text="{Binding Kind}" Foreground="{DynamicResource TextMuted}" FontSize="10"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="Remove" Classes="Danger" Padding="12,4" VerticalAlignment="Center" Command="{Binding RemoveCommand}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="No hosts allowlisted — all agent egress is denied." Foreground="{DynamicResource TextMuted}" FontSize="12"
                               IsVisible="{Binding !Entries.Count}" Margin="4,8"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Add entry -->
            <Border Grid.Row="4" Background="{DynamicResource SurfaceCard}" CornerRadius="8" Padding="12" Margin="0,12,0,0">
                <StackPanel Spacing="8">
                    <TextBlock Text="Allow a host" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" FontSize="13"/>
                    <Grid ColumnDefinitions="90,*">
                        <TextBlock Grid.Column="0" Text="Name" Foreground="{DynamicResource TextMuted}" FontSize="12" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}" Watermark="e.g. Internal mirror"/>
                    </Grid>
                    <Grid ColumnDefinitions="90,*,Auto">
                        <TextBlock Grid.Column="0" Text="Host" Foreground="{DynamicResource TextMuted}" FontSize="12" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Classes="Mono" Text="{Binding NewHostPattern, UpdateSourceTrigger=PropertyChanged}" Watermark="registry.example.com"/>
                        <Button Grid.Column="2" Content="Allow" Classes="Accent" Padding="14,4" Margin="8,0,0,0" Command="{Binding AddCommand}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Error -->
            <TextBlock Grid.Row="5" Text="{Binding ErrorMessage}" Foreground="{DynamicResource DangerBrush}"
                       TextWrapping="Wrap" Margin="0,10,0,0" FontSize="12"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

            <!-- Footer -->
            <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                <Button Content="Close" Classes="Secondary" Padding="15,6" Command="{Binding CloseCommand}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
