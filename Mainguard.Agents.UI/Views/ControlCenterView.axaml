<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Mainguard.Agents.UI.ViewModels"
             xmlns:views="using:Mainguard.Agents.UI.Views"
             x:Class="Mainguard.Agents.UI.Views.ControlCenterView"
             x:DataType="vm:ControlCenterViewModel">

  <!-- The coordinator surface hosted inside MainWindow's content area (revised design,
       2026-07-11): the section rail picks WHAT is focused (coordinator vs an agent); the
       workspace layout preset picks HOW it is arranged — Flight Deck (queue rail right,
       chat as the coordinator's center content) or Conversation Deck (chat pinned left).
       The layout applies to this surface only; the Repo viewer is untouched. -->

  <Grid RowDefinitions="Auto,*" Margin="8">

    <!-- freeze banner: Still, full strength from frame one (D5) -->
    <Border Grid.Row="0" IsVisible="{Binding IsFrozen}" Background="{DynamicResource SurfaceCard}"
            BorderBrush="{DynamicResource DangerBrush}" BorderThickness="1" CornerRadius="8"
            Padding="12,6" Margin="0,0,0,8">
      <StackPanel Spacing="2">
        <TextBlock FontSize="12" Foreground="{DynamicResource TextPrimary}"
                   Text="All agents paused. The merge queue is frozen. Nothing was lost — resume when ready."/>
        <TextBlock FontSize="11" Foreground="{DynamicResource TextMuted}" Text="{Binding FreezeBannerText}"/>
      </StackPanel>
    </Border>

    <Grid Grid.Row="1" ColumnDefinitions="Auto,*,8,300">

      <!-- The coordinator is driven from its own inline terminal now (not a bespoke chat panel); the
           CoordinatorPanelView / ICoordinatorService plumbing is kept for a possible future surface but
           is no longer rendered here. Column 0 stays in the grid for the layout but hosts nothing. -->

      <!-- center content: what the section rail focused -->
      <Border Grid.Column="1" Background="{DynamicResource SurfacePanel}" CornerRadius="12"
              BorderBrush="{DynamicResource BorderHairline}" BorderThickness="1">
        <Panel>
          <Panel IsVisible="{Binding IsCoordinatorFocus}">
            <!-- The coordinator surface is now just the built-in terminal (the normal CLI interface) plus
                 a Start / Stop / Restart toolbar. Start spawns a REAL CLI in its own hardened jail and its
                 interactive terminal appears below; that terminal is how you talk to it (and where CLI login
                 happens when no key is stored). -->
            <Grid RowDefinitions="Auto,*" Margin="10">

              <!-- header + lifecycle controls -->
              <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                  <TextBlock Text="Coordinator" FontSize="15" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextPrimary}"/>
                  <TextBlock FontSize="11" Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"
                             Text="Runs an installed agent CLI in its own sandbox. Talk to it in the terminal below; it spawns sub-agents through Mainguard, and they appear in the agent list."/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                  <ComboBox MinWidth="200" FontSize="12" VerticalAlignment="Center"
                            IsVisible="{Binding CanStartCoordinator}"
                            ItemsSource="{Binding InstalledClis}" SelectedItem="{Binding SelectedCli}">
                    <ComboBox.ItemTemplate>
                      <DataTemplate>
                        <TextBlock Classes="Mono" Text="{Binding Display}" FontSize="12"/>
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                  <Button Classes="Primary" Content="Start coordinator" FontSize="12"
                          IsVisible="{Binding CanStartCoordinator}"
                          Command="{Binding StartCoordinatorCommand}"
                          IsEnabled="{Binding !IsStartingCoordinator}"/>
                  <Button Classes="Secondary" Content="Restart" FontSize="12"
                          IsVisible="{Binding IsCoordinatorLive}"
                          Command="{Binding RestartCoordinatorCommand}"
                          IsEnabled="{Binding !IsStartingCoordinator}"/>
                  <Button Classes="Secondary" Content="Stop coordinator" FontSize="12"
                          IsVisible="{Binding IsCoordinatorLive}"
                          Command="{Binding StopCoordinatorCommand}"
                          IsEnabled="{Binding !IsStartingCoordinator}"/>
                </StackPanel>
              </Grid>

              <!-- body: the built-in terminal once a coordinator exists; otherwise the start explainer -->
              <Border Grid.Row="1" Background="{DynamicResource SurfaceCard}" CornerRadius="8" ClipToBounds="True"
                      BorderBrush="{DynamicResource BorderHairline}" BorderThickness="1">
                <Panel>
                  <!-- coordinator exists (live or dead) → its interactive terminal, or a placeholder
                       until the sandbox PTY attaches (and on the design harness, which has no daemon) -->
                  <Panel IsVisible="{Binding ShowCoordinatorTerminal}">
                    <ContentControl Content="{Binding CoordinatorTerminal}"/>
                    <!-- a dead coordinator's exit reason, so a death that produced no output isn't a silent
                         revert to the start card (an egress block additionally raises the unblock prompt) -->
                    <Border VerticalAlignment="Top" Margin="10" Padding="10,8" CornerRadius="6"
                            Background="{DynamicResource SurfaceDeep}"
                            BorderBrush="{DynamicResource WarningBrush}" BorderThickness="1"
                            IsVisible="{Binding CoordinatorDeadReason, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                      <TextBlock Text="{Binding CoordinatorDeadReason, StringFormat='Coordinator ended — {0}'}"
                                 FontSize="11" TextWrapping="Wrap" Foreground="{DynamicResource TextPrimary}"/>
                    </Border>
                  </Panel>

                  <!-- no coordinator yet → the start explainer + honest error line -->
                  <StackPanel IsVisible="{Binding !ShowCoordinatorTerminal}" Spacing="8" MaxWidth="440"
                              HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="No coordinator running" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}" HorizontalAlignment="Center"/>
                    <TextBlock FontSize="12" Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap" TextAlignment="Center"
                               Text="A coordinator runs one of your installed agent CLIs in its own sandbox. Start one to talk to it here in its terminal."/>
                    <TextBlock Text="Starting the coordinator sandbox…" FontSize="11" HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextMuted}"
                               IsVisible="{Binding IsStartingCoordinator}"/>
                    <TextBlock Text="{Binding CoordinatorStartError}" FontSize="11" TextWrapping="Wrap" TextAlignment="Center"
                               Foreground="{DynamicResource WarningBrush}"
                               IsVisible="{Binding CoordinatorStartError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                  </StackPanel>

                  <!-- loading animation: covers the area while the coordinator is spawning / its CLI is still
                       starting up, instead of a blank pane; cleared on the terminal's first drawn frame -->
                  <Border IsVisible="{Binding IsCoordinatorConnecting}" Background="{DynamicResource SurfaceCard}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="14">
                      <ProgressBar IsIndeterminate="True" Width="220" Height="4" MinHeight="4"
                                   Foreground="{DynamicResource TextPrimary}" Background="{DynamicResource SurfaceDeep}"/>
                      <TextBlock Text="Starting the coordinator…" FontSize="13" HorizontalAlignment="Center"
                                 Foreground="{DynamicResource TextPrimary}"/>
                      <TextBlock Text="Launching its sandbox and connecting the CLI." FontSize="11"
                                 HorizontalAlignment="Center" Foreground="{DynamicResource TextMuted}"/>
                    </StackPanel>
                  </Border>
                </Panel>
              </Border>
            </Grid>
          </Panel>
          <Panel IsVisible="{Binding !IsCoordinatorFocus}">
            <!-- P2-13 #6: the per-agent dock workspace host (Terminal + agent-diff + staging), reused across
                 agent selections. Its primary pane is the live terminal (#5) attached to the agent's PTY.
                 Rendered via the ContentControl → ViewLocator so IsVisible stays in this VM's data context. -->
            <ContentControl Content="{Binding Workspace}"/>
            <TextBlock Text="Select an agent from the sidebar to open its workspace."
                       FontSize="13" Foreground="{DynamicResource TextMuted}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       IsVisible="{Binding Workspace, Converter={x:Static ObjectConverters.IsNull}}"/>
          </Panel>
        </Panel>
      </Border>

      <!-- right rail: the merge queue (+ telemetry beneath it on Flight Deck) -->
      <Grid Grid.Column="3" RowDefinitions="*,Auto">
        <Border Grid.Row="0" Background="{DynamicResource SurfacePanel}" CornerRadius="12"
                BorderBrush="{DynamicResource BorderHairline}" BorderThickness="1">
          <views:QueueRailView DataContext="{Binding Queue}"/>
        </Border>
        <Border Grid.Row="1" Height="240" Margin="0,8,0,0" IsVisible="{Binding IsFlightDeck}"
                Background="{DynamicResource SurfacePanel}" CornerRadius="12"
                BorderBrush="{DynamicResource BorderHairline}" BorderThickness="1">
          <views:TelemetryPanelView DataContext="{Binding Telemetry}"/>
        </Border>
      </Grid>
    </Grid>

    <!-- P2-47 #7: the review cockpit overlay — built from the live GetMergeDiff RPC. Shown when the merge
         rail's "review" action resolves a real branch-vs-main diff; dismissable back to the surface. -->
    <Border Grid.Row="0" Grid.RowSpan="2" Background="#B0000000"
            IsVisible="{Binding ReviewCockpit, Converter={x:Static ObjectConverters.IsNotNull}}">
      <Border Margin="24" Background="{DynamicResource SurfacePanel}" CornerRadius="12"
              BorderBrush="{DynamicResource BorderHairline}" BorderThickness="1" ClipToBounds="True">
        <Grid RowDefinitions="Auto,*">
          <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="12,8">
            <TextBlock Grid.Column="0" Text="Review" FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Content="Close" Classes="Secondary" Padding="12,4"
                    Command="{Binding CloseReviewCommand}"/>
          </Grid>
          <views:ReviewCockpitView Grid.Row="1" DataContext="{Binding ReviewCockpit}"/>
        </Grid>
      </Border>
    </Border>

    <!-- Fix 2: egress block-notification prompt — an agent CLI died on a host the default-deny sandbox
         proxy refused. Names what was blocked + which agent needed it; Unblock adds it to the allowlist
         and retries, Keep blocked leaves the policy as-is (the safe default). -->
    <Border Grid.Row="0" Grid.RowSpan="2" Background="#B0000000"
            IsVisible="{Binding EgressBlockPrompt, Converter={x:Static ObjectConverters.IsNotNull}}">
      <Border Width="460" VerticalAlignment="Center" HorizontalAlignment="Center"
              Background="{DynamicResource SurfacePanel}" CornerRadius="12" Padding="20"
              BorderBrush="{DynamicResource BorderHairline}" BorderThickness="1"
              DataContext="{Binding EgressBlockPrompt}" x:DataType="vm:EgressBlockPromptViewModel">
        <StackPanel Spacing="12">
          <TextBlock Text="Blocked by the sandbox" FontSize="14" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimary}"/>
          <TextBlock Text="{Binding Message}" FontSize="12" TextWrapping="Wrap"
                     Foreground="{DynamicResource TextPrimary}"/>
          <Border Background="{DynamicResource SurfaceDeep}" CornerRadius="6" Padding="8,6">
            <TextBlock Classes="Mono" Text="{Binding Host}" FontSize="12" Foreground="{DynamicResource TextMuted}"/>
          </Border>
          <TextBlock FontSize="11" Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"
                     Text="Unblock adds it to the egress allowlist and retries. Keep blocked leaves the default-deny policy as-is."/>
          <TextBlock Text="{Binding Error}" FontSize="11" TextWrapping="Wrap"
                     Foreground="{DynamicResource WarningBrush}"
                     IsVisible="{Binding Error, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
          <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
            <Button Classes="Secondary" Content="Keep blocked" FontSize="12"
                    Command="{Binding KeepBlockedCommand}" IsEnabled="{Binding !IsBusy}"/>
            <Button Classes="Primary" Content="Unblock and retry" FontSize="12"
                    Command="{Binding UnblockCommand}" IsEnabled="{Binding !IsBusy}"/>
          </StackPanel>
        </StackPanel>
      </Border>
    </Border>
  </Grid>
</UserControl>
