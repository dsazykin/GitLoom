<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Mainguard.Agents.UI.ViewModels"
        x:Class="Mainguard.Agents.UI.Views.PrIntakeSettingsView"
        x:DataType="vm:PrIntakeSettingsViewModel"
        Title="External PR Intake"
        Width="600" Height="600"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SurfaceWindow}">
    <Border Padding="20">
        <Grid RowDefinitions="Auto,Auto,Auto,*,Auto,Auto">

            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="0,0,0,15">
                <TextBlock Text="External PR Intake" FontSize="18" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Subscribe to a source -->
            <Border Grid.Row="1" Classes="Card" Background="{DynamicResource SurfaceCard}" CornerRadius="8" Padding="14" Margin="0,0,0,12">
                <StackPanel Spacing="10">
                    <TextBlock Text="Subscribe a repository" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock Text="Bot-authored pull requests on this repo enter the same verify → review → merge pipeline as local agents. Leave the author filter blank to use the shared bot list."
                               FontSize="11" Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"/>
                    <StackPanel Spacing="8">
                        <TextBox Text="{Binding NewHost, UpdateSourceTrigger=PropertyChanged}" Watermark="Host (github.com)"/>
                        <TextBox Text="{Binding NewOwner, UpdateSourceTrigger=PropertyChanged}" Watermark="Owner"/>
                        <TextBox Text="{Binding NewRepo, UpdateSourceTrigger=PropertyChanged}" Watermark="Repository"/>
                        <TextBox Text="{Binding NewAuthorFilter, UpdateSourceTrigger=PropertyChanged}" Watermark="Author filter (optional)"/>
                    </StackPanel>
                    <Button Content="Subscribe" Classes="Accent" HorizontalAlignment="Left" Padding="14,6" Command="{Binding AddSourceCommand}"/>
                    <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" FontSize="12"
                               Foreground="{DynamicResource TextMuted}" IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                </StackPanel>
            </Border>

            <!-- Poll cadence + bot list -->
            <Border Grid.Row="2" Classes="Card" Background="{DynamicResource SurfaceCard}" CornerRadius="8" Padding="14" Margin="0,0,0,12">
                <StackPanel Spacing="10">
                    <TextBlock Text="Polling" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource TextPrimary}"/>
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <TextBlock Text="Interval (seconds)" VerticalAlignment="Center" Foreground="{DynamicResource TextMuted}" FontSize="12"/>
                        <NumericUpDown Minimum="10" Maximum="3600" Increment="10" Value="{Binding PollIntervalSeconds}" HorizontalAlignment="Left" Width="140"/>
                    </StackPanel>
                    <TextBlock Text="Bot authors (comma-separated)" Foreground="{DynamicResource TextMuted}" FontSize="12"/>
                    <TextBox Text="{Binding BotAuthors, UpdateSourceTrigger=PropertyChanged}" Watermark="codex[bot], google-jules[bot], copilot"/>
                </StackPanel>
            </Border>

            <!-- Subscribed sources -->
            <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="8">
                    <TextBlock Text="Subscribed repositories" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource TextMuted}"/>
                    <ItemsControl ItemsSource="{Binding Sources}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:PrIntakeSourceRowViewModel">
                                <Border Classes="Card" Background="{DynamicResource SurfaceCard}" Padding="14" Margin="0,0,0,8" CornerRadius="8">
                                    <StackPanel Spacing="3">
                                        <TextBlock Text="{Binding Key}" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource TextPrimary}"/>
                                        <TextBlock Text="{Binding AuthorFilter}" FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                <Button Content="Close" Classes="Secondary" Padding="15,6" Command="{Binding CloseCommand}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
