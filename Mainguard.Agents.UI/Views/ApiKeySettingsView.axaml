<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GitLoom.App.ViewModels"
        x:Class="GitLoom.App.Views.ApiKeySettingsView"
        x:DataType="vm:ApiKeySettingsViewModel"
        Title="AI Providers"
        Width="600" Height="600"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SurfaceWindow}">
    <Border Padding="20">
        <Grid RowDefinitions="Auto,Auto,Auto,*,Auto,Auto">

            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="0,0,0,15">
                <PathIcon Data="{StaticResource KeyIcon}" Width="18" Height="18" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                <TextBlock Text="AI Providers" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Add / update a key -->
            <Border Grid.Row="1" Classes="Card" Background="{DynamicResource SurfaceCard}" CornerRadius="8" Padding="14" Margin="0,0,0,12">
                <StackPanel Spacing="10">
                    <TextBlock Text="Store an API key" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock Text="The key is validated with the provider, then stored in your OS keyring. An invalid key is never saved."
                               FontSize="11" Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"/>
                    <Grid ColumnDefinitions="150,*">
                        <ComboBox Grid.Column="0" ItemsSource="{Binding AvailableProviders}"
                                  SelectedItem="{Binding SelectedProvider, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                  ToolTip.Tip="LLM provider"/>
                        <TextBox Grid.Column="1" Classes="Mono" Margin="8,0,0,0"
                                 PasswordChar="●"
                                 Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}"
                                 Watermark="Paste an API key (sk-ant-… / sk-…)"/>
                    </Grid>
                    <Button Content="Validate &amp; save" Classes="Accent" HorizontalAlignment="Left"
                            Padding="14,6" Command="{Binding SaveCommand}"/>

                    <!-- Health / status line: success (green) vs error (danger), role-colored -->
                    <TextBlock Text="{Binding HealthMessage}" TextWrapping="Wrap" FontSize="12"
                               Foreground="{DynamicResource SuccessBrush}"
                               IsVisible="{Binding !IsHealthError}"/>
                    <TextBlock Text="{Binding HealthMessage}" TextWrapping="Wrap" FontSize="12"
                               Foreground="{DynamicResource DangerBrush}"
                               IsVisible="{Binding IsHealthError}"/>
                </StackPanel>
            </Border>

            <!-- CLI-OAuth alternative -->
            <Border Grid.Row="2" Classes="Card" Background="{DynamicResource SurfaceCard}" CornerRadius="8" Padding="14" Margin="0,0,0,12">
                <StackPanel Spacing="8">
                    <TextBlock Text="Use your Claude subscription (CLI OAuth)" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock Text="Not the supported path — Anthropic restricted subscription OAuth in third-party tools (April 2026). A BYOK API key above is recommended."
                               FontSize="11" Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Content="Use CLI OAuth…" Classes="Secondary" Padding="12,5" Command="{Binding UseClaudeSubscriptionCommand}"/>
                        <Border CornerRadius="999" Padding="10,3" VerticalAlignment="Center"
                                Background="{DynamicResource AccentSelection}" IsVisible="{Binding IsCliOAuthEnabled}">
                            <TextBlock Text="Enabled" FontSize="11" Foreground="{DynamicResource AccentBrush}"/>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Stored providers -->
            <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="8">
                    <TextBlock Text="Stored keys" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource TextMuted}"/>
                    <ItemsControl ItemsSource="{Binding Providers}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:ApiKeyProviderRowViewModel">
                                <Border Classes="Card" Background="{DynamicResource SurfaceCard}" Padding="14" Margin="0,0,0,8" CornerRadius="8">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Grid.Column="0" Spacing="3" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource TextPrimary}"/>
                                            <TextBlock Text="{Binding StatusLabel}" FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                            <Border CornerRadius="999" Padding="10,3" VerticalAlignment="Center"
                                                    Background="{DynamicResource AccentSelection}" IsVisible="{Binding HasKey}">
                                                <TextBlock Text="Stored" FontSize="11" Foreground="{DynamicResource AccentBrush}"/>
                                            </Border>
                                            <Button Content="Remove" Classes="Danger" Padding="12,4" Command="{Binding DeleteCommand}" IsVisible="{Binding HasKey}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                <Button Content="Close" Classes="Secondary" Padding="15,6" Command="{Binding CloseCommand}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
