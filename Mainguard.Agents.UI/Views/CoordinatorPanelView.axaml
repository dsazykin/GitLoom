<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Mainguard.Agents.UI.ViewModels"
             x:Class="Mainguard.Agents.UI.Views.CoordinatorPanelView"
             x:DataType="vm:CoordinatorPanelViewModel">

  <!-- The Coordinator conversation + TaskPlan approval (ControlCenterDesign.md §5): no bubbles,
       no avatars — an instrument, not a companion. Cards are decisions, lines are history.
       Approve is the panel's one accent (the product thesis; not destructive). -->

  <Grid RowDefinitions="Auto,*,Auto,Auto" Margin="10">
    <StackPanel Grid.Row="0" Margin="0,0,0,8" Spacing="3">
      <TextBlock Text="Coordinator" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
      <TextBlock Text="{Binding PressureText}" FontSize="11" Foreground="{DynamicResource WarningBrush}"
                 IsVisible="{Binding PressureText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
      <TextBlock Text="The Coordinator plans and delegates — it never touches code or merges."
                 FontSize="11" Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"
                 IsVisible="{Binding IsEmpty}"/>
    </StackPanel>

    <ScrollViewer Grid.Row="1">
      <ItemsControl ItemsSource="{Binding Transcript}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:ChatLineViewModel">
            <StackPanel Margin="0,0,0,8">
              <!-- Human / Coordinator message block -->
              <StackPanel IsVisible="{Binding IsHuman}">
                <TextBlock Text="{Binding SenderLabel}" FontSize="10" Foreground="{DynamicResource TextMuted}"/>
                <TextBlock Text="{Binding Text}" FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource TextPrimary}"/>
              </StackPanel>
              <StackPanel IsVisible="{Binding IsCoordinator}">
                <TextBlock Text="{Binding SenderLabel}" FontSize="10" Foreground="{DynamicResource TextMuted}"/>
                <TextBlock Text="{Binding Text}" FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource TextPrimary}"/>
              </StackPanel>
              <!-- Tool call: one-line mono fact (audit-mirrored) -->
              <TextBlock IsVisible="{Binding IsToolCall}" Classes="Mono" FontSize="11"
                         Foreground="{DynamicResource TextMuted}" Text="{Binding Text}"/>
              <!-- System line: OPS event as history -->
              <TextBlock IsVisible="{Binding IsSystemLine}" FontSize="11" TextWrapping="Wrap"
                         Foreground="{DynamicResource TextMuted}" Text="{Binding Text}" HorizontalAlignment="Center"/>
              <!-- Plan card marker line: the live card renders below the transcript -->
              <TextBlock IsVisible="{Binding IsPlanCard}" FontSize="11" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextMuted}" Text="{Binding Text}"/>
            </StackPanel>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

    <!-- The TaskPlan approval card (§5.2): Scope is the load-bearing field -->
    <Border Grid.Row="2" Classes="Card" Padding="10" Margin="0,8,0,8"
            BorderBrush="{DynamicResource BorderHairline}" BorderThickness="1" CornerRadius="8"
            IsVisible="{Binding PendingPlan, Converter={x:Static ObjectConverters.IsNotNull}}">
      <StackPanel Spacing="6" DataContext="{Binding PendingPlan}" x:DataType="vm:PlanCardViewModel">
        <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
        <Grid ColumnDefinitions="60,*" RowDefinitions="Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Scope" FontSize="11" Foreground="{DynamicResource TextMuted}"/>
          <TextBlock Grid.Row="0" Grid.Column="1" Classes="Mono" Text="{Binding ScopeText}" FontSize="11"
                     TextWrapping="Wrap" Foreground="{DynamicResource TextPrimary}"/>
          <TextBlock Grid.Row="1" Grid.Column="0" Text="Approach" FontSize="11" Foreground="{DynamicResource TextMuted}"/>
          <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Approach}" FontSize="11" TextWrapping="Wrap" Foreground="{DynamicResource TextPrimary}"/>
          <TextBlock Grid.Row="2" Grid.Column="0" Text="Test" FontSize="11" Foreground="{DynamicResource TextMuted}"/>
          <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding TestStrategy}" FontSize="11" TextWrapping="Wrap" Foreground="{DynamicResource TextPrimary}"/>
        </Grid>
        <TextBlock Text="{Binding FactsText}" FontSize="11" Foreground="{DynamicResource TextMuted}"/>
        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
          <Button Classes="Secondary" Content="Reject" FontSize="12" Command="{Binding RejectCommand}" IsEnabled="{Binding !IsDeciding}"/>
          <Button Classes="Accent" Content="Approve plan" FontSize="12" Command="{Binding ApproveCommand}" IsEnabled="{Binding !IsDeciding}"/>
        </StackPanel>
      </StackPanel>
    </Border>

    <Grid Grid.Row="3" ColumnDefinitions="*,Auto">
      <TextBox Grid.Column="0" Text="{Binding ComposerText}" Watermark="Message the Coordinator…"
               FontSize="12" AcceptsReturn="False"/>
      <Button Grid.Column="1" Classes="Primary" Content="Send" FontSize="12" Margin="8,0,0,0"
              Command="{Binding SendCommand}"/>
    </Grid>
  </Grid>
</UserControl>
