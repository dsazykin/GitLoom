<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Mainguard.Agents.UI.ViewModels"
        x:Class="Mainguard.Agents.UI.Views.DaemonLogsView"
        x:DataType="vm:DaemonLogsViewModel"
        Title="Daemon logs"
        Width="760" Height="620"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SurfaceWindow}">
    <Border Padding="20">
        <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">

            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="0,0,0,6">
                <PathIcon Data="{StaticResource TerminalIcon}" Width="18" Height="18"
                          Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                <TextBlock Text="Daemon logs" FontSize="18" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Grid.Row="1" Margin="0,0,0,12" FontSize="12" TextWrapping="Wrap"
                       Foreground="{DynamicResource TextMuted}"
                       Text="Recent diagnostics from the Mainguard OS daemon (gitloomd) running inside the Mainguard environment. Pick the unified journal or a single subsystem. Read-only, and secret-safe — model keys and other secrets are masked before anything is written."/>

            <!-- Source picker + Refresh -->
            <Grid Grid.Row="2" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,10">
                <TextBlock Grid.Column="0" Text="Source" VerticalAlignment="Center" Margin="0,0,10,0"
                           FontSize="12" Foreground="{DynamicResource TextMuted}"/>
                <ComboBox Grid.Column="1" MinWidth="240" HorizontalAlignment="Left"
                          ItemsSource="{Binding Sources}" SelectedItem="{Binding SelectedSource, Mode=TwoWay}"
                          Background="{DynamicResource SurfaceCard}" Foreground="{DynamicResource TextPrimary}"
                          BorderBrush="{DynamicResource BorderHairline}"/>
                <Button Grid.Column="2" Classes="Primary" Padding="14,5" VerticalAlignment="Center"
                        Content="Refresh" Command="{Binding RefreshCommand}"/>
            </Grid>

            <!-- Log pane: deep-surface card, monospace, scrollable both ways. -->
            <Border Grid.Row="3" Classes="Card" Background="{DynamicResource SurfaceDeep}" CornerRadius="8" Padding="2">
                <Panel>
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                  Padding="12" IsVisible="{Binding HasLogText}">
                        <SelectableTextBlock Classes="Mono" Text="{Binding LogText}" FontSize="12"
                                             Foreground="{DynamicResource TextPrimary}" TextWrapping="NoWrap"/>
                    </ScrollViewer>
                    <TextBlock IsVisible="{Binding ShowEmpty}" HorizontalAlignment="Center" VerticalAlignment="Center"
                               MaxWidth="440" TextAlignment="Center" TextWrapping="Wrap"
                               FontSize="12" Foreground="{DynamicResource TextMuted}"
                               Text="Nothing to show yet. If the Mainguard environment is still starting, wait a moment and Refresh — a subsystem file only appears once that subsystem has logged."/>

                    <!-- Loading: a named line centered inside the log pane, never a silent blank. -->
                    <StackPanel Orientation="Horizontal" Spacing="8"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                IsVisible="{Binding IsLoading}">
                        <PathIcon Classes="spinning" Data="{StaticResource RefreshIcon}" Width="14" Height="14"
                                  Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="Reading recent daemon logs…" FontSize="12"
                                   Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Panel>
            </Border>

            <!-- Footer -->
            <Grid Grid.Row="4" ColumnDefinitions="Auto,*,Auto" Margin="0,15,0,0">
                <Button Grid.Column="0" Classes="Secondary" Padding="14,6"
                        Content="Copy" Command="{Binding CopyCommand}"/>
                <Button Grid.Column="2" Classes="Secondary" Padding="15,6"
                        Content="Close" Command="{Binding CloseCommand}"/>
            </Grid>
        </Grid>
    </Border>
</Window>
