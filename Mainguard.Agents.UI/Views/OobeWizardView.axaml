<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Mainguard.Agents.UI.ViewModels"
        x:Class="Mainguard.Agents.UI.Views.OobeWizardView"
        x:DataType="vm:OobeWizardViewModel"
        x:Name="Root"
        Icon="/Assets/avalonia-logo.ico"
        Title="Welcome to Mainguard"
        Width="720" Height="640"
        MinWidth="640" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource SurfaceWindow}"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1">

    <Grid Margin="{Binding #Root.OffScreenMargin}">
        <Grid RowDefinitions="Auto, *">

            <!-- UNIFIED CUSTOM TITLE BAR — same client-area chrome as MainWindow (one product). -->
            <Border Grid.Row="0" Background="{DynamicResource SurfacePanel}"
                    BorderBrush="{DynamicResource BorderHairline}" BorderThickness="0,0,0,1"
                    Padding="12,0,8,0" MinHeight="44"
                    PointerPressed="TitleBar_PointerPressed" DoubleTapped="TitleBar_DoubleTapped">
                <Grid ColumnDefinitions="Auto, *, Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <PathIcon Data="{StaticResource CloudIcon}" Width="16" Height="16"
                                  Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="Mainguard Setup" FontWeight="SemiBold" FontSize="13"
                                   Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Window controls (custom chrome) -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Stretch">
                        <Button Classes="WindowButton" ToolTip.Tip="Minimize" Click="MinimizeButton_Click">
                            <PathIcon Data="{StaticResource WindowMinimizeIcon}" Width="11" Height="11" Foreground="{DynamicResource TextMuted}"/>
                        </Button>
                        <Button Classes="WindowButton" ToolTip.Tip="Maximize" Click="MaximizeButton_Click">
                            <PathIcon x:Name="MaximizeIcon" Data="{StaticResource WindowMaximizeIcon}" Width="11" Height="11" Foreground="{DynamicResource TextMuted}"/>
                        </Button>
                        <Button Classes="WindowButton Close" ToolTip.Tip="Close" Click="CloseButton_Click">
                            <PathIcon Data="{StaticResource DismissIcon}" Width="12" Height="12" Foreground="{DynamicResource TextMuted}"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- CONTENT: a centered column, one panel per phase. -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid HorizontalAlignment="Center" MaxWidth="560" Margin="32,28">
                    <Grid.Styles>
                        <Style Selector="TextBlock.h1">
                            <Setter Property="FontSize" Value="22"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                        </Style>
                        <Style Selector="TextBlock.sub">
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                            <Setter Property="TextWrapping" Value="Wrap"/>
                        </Style>
                    </Grid.Styles>

                    <!-- 1. DIAGNOSTICS (read-only preflight) -->
                    <StackPanel Spacing="16" IsVisible="{Binding IsDiagnostics}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <PathIcon Data="{StaticResource RefreshIcon}" Width="20" Height="20"
                                      Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                            <TextBlock Classes="h1" Text="Checking your system"/>
                        </StackPanel>
                        <TextBlock Classes="sub"
                                   Text="Mainguard is confirming this machine can run its isolated agent sandbox. Nothing is changed during this step."/>
                        <ItemsControl ItemsSource="{Binding Diagnostics}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:OobeDiagnosticViewModel">
                                    <Border Classes="Card" Background="{DynamicResource SurfaceCard}"
                                            CornerRadius="8" Padding="14" Margin="0,0,0,8">
                                        <Grid ColumnDefinitions="Auto,*">
                                            <Panel Grid.Column="0" Width="20" Height="20" Margin="0,0,12,0" VerticalAlignment="Top">
                                                <PathIcon Data="{StaticResource CheckmarkIcon}" Width="16" Height="16"
                                                          Foreground="{DynamicResource SuccessBrush}" IsVisible="{Binding IsPass}"/>
                                                <PathIcon Data="{StaticResource WarningIcon}" Width="16" Height="16"
                                                          Foreground="{DynamicResource DangerBrush}" IsVisible="{Binding IsBlocking}"/>
                                            </Panel>
                                            <StackPanel Grid.Column="1" Spacing="3">
                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14"
                                                           Foreground="{DynamicResource TextPrimary}"/>
                                                <TextBlock Text="{Binding Message}" FontSize="12"
                                                           Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"
                                                           IsVisible="{Binding HasDetail}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Content="Cancel" Classes="Secondary" Padding="16,7" HorizontalAlignment="Right"
                                Command="{Binding CancelSetupCommand}"/>
                    </StackPanel>

                    <!-- 2. CONSENT (Construct Sandbox + single UAC) -->
                    <StackPanel Spacing="16" IsVisible="{Binding IsConsent}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <PathIcon Data="{StaticResource ShieldIcon}" Width="20" Height="20"
                                      Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                            <TextBlock Classes="h1" Text="Construct the Mainguard sandbox"/>
                        </StackPanel>
                        <TextBlock Classes="sub"
                                   Text="Your system checks passed. Mainguard needs to enable two Windows features for its isolated agent environment. It runs exactly this, with your permission (one prompt):"/>
                        <Border Classes="Card" Background="{DynamicResource SurfaceCard}" CornerRadius="8" Padding="14">
                            <TextBlock Text="{Binding ConsentCommandText}" Classes="Mono" FontSize="12"
                                       Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap"/>
                        </Border>
                        <TextBlock Classes="sub"
                                   Text="Your own WSL distros are never touched. You can cancel now and nothing will be changed."/>
                        <!-- Elevation runs off the UI thread, so the wizard stays live while the UAC
                             prompt is up — tell the user what it is waiting for (icon + text, never
                             colour alone). -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8"
                                    IsVisible="{Binding IsBusy}">
                            <PathIcon Data="{StaticResource ShieldIcon}" Width="14" Height="14"
                                      Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                            <TextBlock Classes="sub"
                                       Text="Waiting for Windows permission — approve the prompt to continue. If none appears, look for a flashing shield icon on the taskbar."/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                            <Button Content="Cancel" Classes="Secondary" Padding="16,7"
                                    Command="{Binding CancelConsentCommand}"/>
                            <Button Content="Construct Sandbox" Classes="Accent" Padding="16,7"
                                    Command="{Binding ConstructSandboxCommand}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- 3. REBOOT (Restart now) -->
                    <StackPanel Spacing="16" IsVisible="{Binding IsReboot}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <PathIcon Data="{StaticResource RefreshIcon}" Width="20" Height="20"
                                      Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                            <TextBlock Classes="h1" Text="One restart to finish"/>
                        </StackPanel>
                        <TextBlock Classes="sub"
                                   Text="Windows enabled the features and needs to restart to activate them. When you restart, Mainguard setup continues automatically — no command line, no re-launching."/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                            <Button Content="I'll restart later" Classes="Secondary" Padding="16,7"
                                    Click="RestartLater_Click"/>
                            <Button Content="Restart now" Classes="Accent" Padding="16,7"
                                    Command="{Binding RestartNowCommand}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- 4. IMPORTING (VM import checklist) -->
                    <StackPanel Spacing="16" IsVisible="{Binding IsImporting}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <PathIcon Data="{StaticResource CloudIcon}" Width="20" Height="20"
                                      Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                            <TextBlock Classes="h1" Text="Setting up the Mainguard environment"/>
                        </StackPanel>
                        <TextBlock Classes="sub"
                                   Text="Mainguard is preparing an isolated WSL2 environment for your agents. This runs once."/>
                        <ItemsControl ItemsSource="{Binding ImportStages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:BootstrapStageViewModel">
                                    <Border Classes="Card" Background="{DynamicResource SurfaceCard}"
                                            CornerRadius="8" Padding="14" Margin="0,0,0,8">
                                        <Grid ColumnDefinitions="Auto,*">
                                            <Panel Grid.Column="0" Width="22" Height="22" Margin="0,0,12,0" VerticalAlignment="Top">
                                                <PathIcon Data="{StaticResource AgentWorkingIcon}" Width="12" Height="12"
                                                          Foreground="{DynamicResource TextMuted}" IsVisible="{Binding IsPending}"/>
                                                <PathIcon Data="{StaticResource RefreshIcon}" Width="18" Height="18"
                                                          Foreground="{DynamicResource AccentBrush}" IsVisible="{Binding IsRunning}"/>
                                                <PathIcon Data="{StaticResource CheckmarkIcon}" Width="18" Height="18"
                                                          Foreground="{DynamicResource SuccessBrush}" IsVisible="{Binding IsDone}"/>
                                                <PathIcon Data="{StaticResource DismissIcon}" Width="18" Height="18"
                                                          Foreground="{DynamicResource DangerBrush}" IsVisible="{Binding IsFailed}"/>
                                            </Panel>
                                            <StackPanel Grid.Column="1" Spacing="3">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14"
                                                           Foreground="{DynamicResource TextPrimary}"/>
                                                <TextBlock Text="{Binding LogTail}" FontSize="11" Classes="Mono"
                                                           Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"
                                                           IsVisible="{Binding HasLog}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Content="Cancel" Classes="Secondary" Padding="16,7" HorizontalAlignment="Right"
                                Command="{Binding CancelSetupCommand}"/>
                    </StackPanel>

                    <!-- 5. AGENT CLIS (choose your coding agents — clearly skippable, failure-isolated) -->
                    <StackPanel Spacing="16" IsVisible="{Binding IsAgentClis}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <PathIcon Data="{StaticResource TerminalIcon}" Width="20" Height="20"
                                      Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                            <TextBlock Classes="h1" Text="Choose your coding agents"/>
                        </StackPanel>
                        <TextBlock Classes="sub"
                                   Text="Pick the agent command-line tools to install into Mainguard's isolated environment. Each installs at a version Mainguard has tested, verified against its published checksum — nothing touches your own system. Skip freely; you can add agents anytime from the Agent CLIs settings."/>

                        <!-- Loading the channel + per-CLI installed-state probes: named line, never blank. -->
                        <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding IsCliLoading}">
                            <PathIcon Classes="spinning" Data="{StaticResource RefreshIcon}" Width="14" Height="14"
                                      Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                            <TextBlock Classes="sub" Text="Checking which agents are already installed…"/>
                        </StackPanel>

                        <!-- Catalog read failed: actionable card; the skip path below stays live. -->
                        <Border Classes="Card" Background="{DynamicResource SurfaceCard}" CornerRadius="8" Padding="14"
                                IsVisible="{Binding HasCliLoadError}">
                            <StackPanel Spacing="10">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource WarningIcon}" Width="16" Height="16"
                                              Foreground="{DynamicResource DangerBrush}" VerticalAlignment="Top"/>
                                    <TextBlock Text="{Binding CliLoadError}" FontSize="12"
                                               Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap"/>
                                </StackPanel>
                                <Button Content="Try again" Classes="Primary" Padding="14,6" HorizontalAlignment="Right"
                                        Command="{Binding LoadCliOptionsCommand}"/>
                            </StackPanel>
                        </Border>

                        <ItemsControl ItemsSource="{Binding CliOptions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:AgentCliRowViewModel">
                                    <Border Classes="Card" Background="{DynamicResource SurfaceCard}"
                                            CornerRadius="8" Padding="14" Margin="0,0,0,8">
                                        <Grid ColumnDefinitions="Auto,*">
                                            <!-- Lifecycle glyph column: checkbox (choosable) / spinner / done check. -->
                                            <Panel Grid.Column="0" Width="24" Height="22" Margin="0,0,10,0" VerticalAlignment="Top">
                                                <CheckBox IsChecked="{Binding IsSelected}" IsVisible="{Binding CanSelect}"
                                                          VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                                <PathIcon Classes="spinning" Data="{StaticResource RefreshIcon}" Width="16" Height="16"
                                                          Foreground="{DynamicResource AccentBrush}" IsVisible="{Binding IsInstalling}"/>
                                                <PathIcon Data="{StaticResource CheckmarkIcon}" Width="18" Height="18"
                                                          Foreground="{DynamicResource SuccessBrush}" IsVisible="{Binding IsInstalled}"/>
                                            </Panel>
                                            <StackPanel Grid.Column="1" Spacing="4">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <!-- MaxWidth bounds the measure so TextTrimming actually engages inside the
                                                         horizontal StackPanel (unbounded, it would shove the version chip off the card). -->
                                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="14"
                                                               Foreground="{DynamicResource TextPrimary}" MaxWidth="300"
                                                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                    <Border CornerRadius="999" Background="{DynamicResource AccentSelection}"
                                                            Padding="8,1" VerticalAlignment="Center">
                                                        <TextBlock Classes="Mono" Text="{Binding VersionLabel}" FontSize="10"
                                                                   Foreground="{DynamicResource AccentBrush}"/>
                                                    </Border>
                                                    <TextBlock Text="Installed" FontSize="11" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource SuccessBrush}" VerticalAlignment="Center"
                                                               IsVisible="{Binding IsInstalled}"/>
                                                </StackPanel>
                                                <!-- Progress detail (muted) vs failure cause (icon + danger text, never colour alone). -->
                                                <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                                                           Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap">
                                                    <TextBlock.IsVisible>
                                                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                                                            <Binding Path="HasStatusMessage"/>
                                                            <Binding Path="!IsFailed"/>
                                                        </MultiBinding>
                                                    </TextBlock.IsVisible>
                                                </TextBlock>
                                                <StackPanel Orientation="Horizontal" Spacing="6" IsVisible="{Binding IsFailed}">
                                                    <PathIcon Data="{StaticResource WarningIcon}" Width="12" Height="12"
                                                              Foreground="{DynamicResource DangerBrush}" VerticalAlignment="Top"
                                                              Margin="0,2,0,0"/>
                                                    <TextBlock Text="{Binding StatusMessage}" FontSize="12" MaxWidth="440"
                                                               Foreground="{DynamicResource DangerBrush}" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- While installing: what is happening + the way out (finished installs stay). -->
                        <TextBlock Classes="sub" IsVisible="{Binding IsInstallingClis}"
                                   Text="Installing into the Mainguard environment. You can cancel anytime — agents already installed stay installed."/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                            <Button Content="Cancel" Classes="Secondary" Padding="16,7"
                                    IsVisible="{Binding IsInstallingClis}"
                                    Command="{Binding CancelCliInstallCommand}"/>
                            <Button Content="Skip for now" Classes="Secondary" Padding="16,7"
                                    IsVisible="{Binding ShowSkipClis}"
                                    Command="{Binding FinishCliStepCommand}"/>
                            <Button Content="Install selected" Classes="Primary" Padding="16,7"
                                    IsVisible="{Binding ShowInstallCliPrimary}"
                                    Command="{Binding InstallSelectedClisCommand}"/>
                            <Button Content="Install selected" Classes="Accent" Padding="16,7"
                                    IsVisible="{Binding ShowInstallCliAccent}"
                                    Command="{Binding InstallSelectedClisCommand}"/>
                            <Button Content="Continue" Classes="Accent" Padding="16,7"
                                    IsVisible="{Binding ShowContinueClis}"
                                    Command="{Binding FinishCliStepCommand}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- 6. REPO ONBOARDING (copy your repositories into Mainguard OS — skippable, failure-isolated) -->
                    <StackPanel Spacing="16" IsVisible="{Binding IsRepoOnboarding}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <PathIcon Data="{StaticResource FolderIcon}" Width="20" Height="20"
                                      Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                            <TextBlock Classes="h1" Text="Copy your repositories"/>
                        </StackPanel>
                        <TextBlock Classes="sub"
                                   Text="Mainguard agents work on copies of your repositories inside the isolated Mainguard OS — your own working folders are never touched. Point Mainguard at your repos and choose which to copy. Skip freely; a repository is also copied automatically the first time you open it."/>

                        <!-- The two ways in: one folder of repos (scanned), or individual picks. -->
                        <StackPanel Spacing="10" IsVisible="{Binding IsRepoChoice}">
                            <Button Classes="Primary" Padding="14,12" HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left"
                                    Command="{Binding PickRepoFolderCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <PathIcon Data="{StaticResource FolderIcon}" Width="18" Height="18"
                                              Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="I keep my repos in one folder" FontWeight="SemiBold" FontSize="13"
                                                   Foreground="{DynamicResource TextPrimary}"/>
                                        <TextBlock Text="Pick that folder and Mainguard finds every git repository inside it."
                                                   FontSize="11" Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>
                            <Button Classes="Primary" Padding="14,12" HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left"
                                    Command="{Binding PickIndividualReposCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <PathIcon Data="{StaticResource DocumentAddIcon}" Width="18" Height="18"
                                              Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="Pick individual repositories" FontWeight="SemiBold" FontSize="13"
                                                   Foreground="{DynamicResource TextPrimary}"/>
                                        <TextBlock Text="Select one or more repository folders yourself."
                                                   FontSize="11" Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- Advisory line (empty scan / skipped non-repos / scan error): icon + text, never colour alone. -->
                        <Border Classes="Card" Background="{DynamicResource SurfaceCard}" CornerRadius="8" Padding="14"
                                IsVisible="{Binding HasRepoNotice}">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <PathIcon Data="{StaticResource WarningIcon}" Width="16" Height="16"
                                          Foreground="{DynamicResource DangerBrush}" VerticalAlignment="Top"/>
                                <TextBlock Text="{Binding RepoNotice}" FontSize="12" MaxWidth="470"
                                           Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- Scanning the chosen folder: named line, never a blank panel. -->
                        <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding IsRepoScanning}">
                            <PathIcon Classes="spinning" Data="{StaticResource RefreshIcon}" Width="14" Height="14"
                                      Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                            <TextBlock Classes="sub" Text="Scanning for git repositories…"/>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding RepoRows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:OnboardRepoRowViewModel">
                                    <Border Classes="Card" Background="{DynamicResource SurfaceCard}"
                                            CornerRadius="8" Padding="14" Margin="0,0,0,8">
                                        <Grid ColumnDefinitions="Auto,*">
                                            <!-- Lifecycle glyph column: checkbox (choosable) / spinner / done check. -->
                                            <Panel Grid.Column="0" Width="24" Height="22" Margin="0,0,10,0" VerticalAlignment="Top">
                                                <CheckBox IsChecked="{Binding IsSelected}" IsVisible="{Binding CanSelect}"
                                                          VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                                <PathIcon Classes="spinning" Data="{StaticResource RefreshIcon}" Width="16" Height="16"
                                                          Foreground="{DynamicResource AccentBrush}" IsVisible="{Binding IsProvisioning}"/>
                                                <PathIcon Data="{StaticResource CheckmarkIcon}" Width="18" Height="18"
                                                          Foreground="{DynamicResource SuccessBrush}" IsVisible="{Binding IsOnboarded}"/>
                                            </Panel>
                                            <StackPanel Grid.Column="1" Spacing="4">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <!-- MaxWidth bounds the measure so TextTrimming actually engages inside the
                                                         horizontal StackPanel (same fix as the CLI rows). -->
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14"
                                                               Foreground="{DynamicResource TextPrimary}" MaxWidth="300"
                                                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                    <TextBlock Text="In Mainguard OS" FontSize="11" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource SuccessBrush}" VerticalAlignment="Center"
                                                               IsVisible="{Binding IsOnboarded}"/>
                                                </StackPanel>
                                                <TextBlock Classes="Mono" Text="{Binding Path}" FontSize="11" MaxWidth="470"
                                                           Foreground="{DynamicResource TextMuted}" TextTrimming="CharacterEllipsis"
                                                           HorizontalAlignment="Left"/>
                                                <!-- Progress detail (muted) vs failure cause (icon + danger text, never colour alone). -->
                                                <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                                                           Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap">
                                                    <TextBlock.IsVisible>
                                                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                                                            <Binding Path="HasStatusMessage"/>
                                                            <Binding Path="!IsFailed"/>
                                                        </MultiBinding>
                                                    </TextBlock.IsVisible>
                                                </TextBlock>
                                                <StackPanel Orientation="Horizontal" Spacing="6" IsVisible="{Binding IsFailed}">
                                                    <PathIcon Data="{StaticResource WarningIcon}" Width="12" Height="12"
                                                              Foreground="{DynamicResource DangerBrush}" VerticalAlignment="Top"
                                                              Margin="0,2,0,0"/>
                                                    <TextBlock Text="{Binding StatusMessage}" FontSize="12" MaxWidth="440"
                                                               Foreground="{DynamicResource DangerBrush}" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- While copying: what is happening + the way out (finished copies stay). -->
                        <TextBlock Classes="sub" IsVisible="{Binding IsProvisioningRepos}"
                                   Text="Copying into Mainguard OS. You can cancel anytime — repositories already copied stay available."/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                            <Button Content="Cancel" Classes="Secondary" Padding="16,7"
                                    IsVisible="{Binding IsProvisioningRepos}"
                                    Command="{Binding CancelRepoCopyCommand}"/>
                            <Button Content="Choose again" Classes="Secondary" Padding="16,7"
                                    IsVisible="{Binding ShowRepoChooseAgain}"
                                    Command="{Binding ChooseReposAgainCommand}"/>
                            <Button Content="Skip for now" Classes="Secondary" Padding="16,7"
                                    IsVisible="{Binding ShowSkipRepos}"
                                    Command="{Binding FinishRepoStepCommand}"/>
                            <Button Content="Copy selected to Mainguard OS" Classes="Primary" Padding="16,7"
                                    IsVisible="{Binding ShowCopyReposPrimary}"
                                    Command="{Binding CopySelectedReposCommand}"/>
                            <Button Content="Copy selected to Mainguard OS" Classes="Accent" Padding="16,7"
                                    IsVisible="{Binding ShowCopyReposAccent}"
                                    Command="{Binding CopySelectedReposCommand}"/>
                            <Button Content="Continue" Classes="Accent" Padding="16,7"
                                    IsVisible="{Binding ShowContinueRepos}"
                                    Command="{Binding FinishRepoStepCommand}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- 7. DONE -->
                    <StackPanel Spacing="18" IsVisible="{Binding IsDone}" HorizontalAlignment="Center">
                        <PathIcon Data="{StaticResource CheckmarkIcon}" Width="44" Height="44"
                                  Foreground="{DynamicResource SuccessBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Classes="h1" Text="Mainguard is ready" HorizontalAlignment="Center"/>
                        <TextBlock Classes="sub" HorizontalAlignment="Center" TextAlignment="Center"
                                   Text="Your isolated agent environment is provisioned and the daemon is running."/>
                        <Button Content="Open Mainguard" Classes="Accent" Padding="20,8" HorizontalAlignment="Center"
                                Command="{Binding OpenControlCenterCommand}"/>
                    </StackPanel>

                    <!-- 8. BLOCKED (diagnostic hard-stop) -->
                    <StackPanel Spacing="16" IsVisible="{Binding IsBlocked}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <PathIcon Data="{StaticResource WarningIcon}" Width="20" Height="20"
                                      Foreground="{DynamicResource DangerBrush}" VerticalAlignment="Center"/>
                            <TextBlock Classes="h1" Text="A few things need attention first"/>
                        </StackPanel>
                        <TextBlock Classes="sub"
                                   Text="Mainguard can't set up its environment on this machine yet. Nothing has been changed. Resolve the items below, then re-check."/>
                        <ItemsControl ItemsSource="{Binding Failures}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:OobeDiagnosticViewModel">
                                    <Border Classes="Card" Background="{DynamicResource SurfaceCard}"
                                            CornerRadius="8" Padding="14" Margin="0,0,0,8">
                                        <StackPanel Spacing="6">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <PathIcon Data="{StaticResource WarningIcon}" Width="16" Height="16"
                                                          Foreground="{DynamicResource DangerBrush}" VerticalAlignment="Top"/>
                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14"
                                                           Foreground="{DynamicResource TextPrimary}"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Message}" FontSize="12"
                                                       Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding DocLink}" FontSize="11" Classes="Mono"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       IsVisible="{Binding HasDocLink}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Content="Re-check" Classes="Accent" Padding="16,7" HorizontalAlignment="Right"
                                Command="{Binding RetryCommand}"/>
                    </StackPanel>

                    <!-- 9. ERROR (actionable failure card) -->
                    <StackPanel Spacing="16" IsVisible="{Binding IsError}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <PathIcon Data="{StaticResource WarningIcon}" Width="20" Height="20"
                                      Foreground="{DynamicResource DangerBrush}" VerticalAlignment="Center"/>
                            <TextBlock Classes="h1" Text="Setup ran into a problem"/>
                        </StackPanel>
                        <Border Classes="Card" Background="{DynamicResource SurfaceCard}" CornerRadius="8" Padding="14">
                            <TextBlock Text="{Binding ErrorMessage}" FontSize="13"
                                       Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap"/>
                        </Border>
                        <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                            <Button Content="Start over" Classes="Secondary" Padding="16,7"
                                    Command="{Binding StartOverCommand}"/>
                            <Button Content="Try again" Classes="Accent" Padding="16,7"
                                    Command="{Binding RetryCommand}"/>
                        </StackPanel>
                    </StackPanel>

                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
