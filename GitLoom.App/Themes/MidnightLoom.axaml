<!-- MIDNIGHT LOOM — the default GitLoom theme.
     Layered cool-charcoal surfaces, hairline borders, a single indigo-violet
     signature accent, jewel-tone graph lanes.
     Every theme file must define the FULL token contract documented in
     AGENTS.md (UI / Design System). Add a theme = copy this file, change
     values, register it in ThemeManager.Themes. -->
<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Surfaces (darkest window → raised card) -->
    <SolidColorBrush x:Key="SurfaceWindow" Color="#0F1115"/>
    <SolidColorBrush x:Key="SurfacePanel" Color="#14171C"/>   <!-- floating panel / sidebar card -->
    <SolidColorBrush x:Key="SurfaceDeep" Color="#0B0D10"/>    <!-- code/diff editor -->
    <SolidColorBrush x:Key="SurfaceCard" Color="#1A1E24"/>    <!-- inputs, raised cards, segment tracks -->
    <SolidColorBrush x:Key="SurfaceHover" Color="#252B34"/>   <!-- hover / neutral selection -->
    <SolidColorBrush x:Key="SurfaceHoverGhost" Color="#00252B34"/> <!-- SurfaceHover at 0 alpha: rest state for ghost buttons so the hover fade never passes through white -->
    <SolidColorBrush x:Key="ButtonBg" Color="#1E232B"/>
    <SolidColorBrush x:Key="BorderHairline" Color="#262B33"/>

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimary" Color="#E6E9EF"/>
    <SolidColorBrush x:Key="TextMuted" Color="#8A93A6"/>
    <SolidColorBrush x:Key="OnAccent" Color="#0B0D10"/>       <!-- text on Accent/Success/Danger fills -->

    <!-- Signature accent -->
    <SolidColorBrush x:Key="AccentBrush" Color="#8B8BF5"/>
    <SolidColorBrush x:Key="AccentHover" Color="#A5A5F8"/>
    <SolidColorBrush x:Key="AccentSelection" Color="#268B8BF5"/> <!-- translucent selection tint -->

    <!-- Semantic -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#42B968"/>
    <SolidColorBrush x:Key="SuccessHover" Color="#5BCB7F"/>
    <SolidColorBrush x:Key="DangerBrush" Color="#F87171"/>
    <SolidColorBrush x:Key="DangerHover" Color="#FA8C8C"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#E3B341"/>
    <SolidColorBrush x:Key="InfoBrush" Color="#58A6FF"/>

    <!-- Commit-graph lanes (decoupled from semantics) -->
    <!-- Lanes are deliberately decoupled from the semantic status tokens (DESIGN.md §2): none of
         Lane1-5 is hex-identical to AccentBrush/WarningBrush/InfoBrush/SuccessBrush, so graph
         topology never accidentally implies status. Retuned per ThemeRefinement Finding B. -->
    <SolidColorBrush x:Key="Lane1" Color="#9A9AF4"/>
    <SolidColorBrush x:Key="Lane2" Color="#E860A4"/>
    <SolidColorBrush x:Key="Lane3" Color="#C0EAE3"/>
    <SolidColorBrush x:Key="Lane4" Color="#E8A217"/>
    <SolidColorBrush x:Key="Lane5" Color="#0B87F5"/>

    <!-- Diff line backgrounds -->
    <SolidColorBrush x:Key="DiffAddedBg" Color="#11271B"/>
    <SolidColorBrush x:Key="DiffRemovedBg" Color="#33191E"/>
    <!-- Intra-line (word-level) emphasis + trailing-whitespace marker (T-13) -->
    <SolidColorBrush x:Key="DiffAddedEmphasis" Color="#6642B968"/>
    <SolidColorBrush x:Key="DiffRemovedEmphasis" Color="#66F87171"/>
    <SolidColorBrush x:Key="DiffWhitespaceMarker" Color="#55E3B341"/>

    <!-- Blame age-heat gutter (T-11): recent edits interpolate toward BlameAgeNew,
         old edits toward BlameAgeOld. The margin lerps between the two by commit age. -->
    <SolidColorBrush x:Key="BlameAgeNew" Color="#E3B341"/>
    <SolidColorBrush x:Key="BlameAgeOld" Color="#3B4252"/>

    <!-- Terminal cell palette (P2-03 interim engine). Default surface + the 16 ANSI
         colours as tokens so the cell renderer follows the active theme and Daylight
         Loom stays readable; the 256-colour cube (16-255) is computed in code. -->
    <SolidColorBrush x:Key="TerminalBackground" Color="#0B0D10"/>
    <SolidColorBrush x:Key="TerminalForeground" Color="#E6E9EF"/>
    <SolidColorBrush x:Key="TerminalCursor" Color="#8B8BF5"/>
    <SolidColorBrush x:Key="TerminalAnsi0" Color="#000000"/>
    <SolidColorBrush x:Key="TerminalAnsi1" Color="#CD3131"/>
    <SolidColorBrush x:Key="TerminalAnsi2" Color="#2AA745"/>
    <SolidColorBrush x:Key="TerminalAnsi3" Color="#C7C43B"/>
    <SolidColorBrush x:Key="TerminalAnsi4" Color="#3B6FD6"/>
    <SolidColorBrush x:Key="TerminalAnsi5" Color="#B454C9"/>
    <SolidColorBrush x:Key="TerminalAnsi6" Color="#2EC5CE"/>
    <SolidColorBrush x:Key="TerminalAnsi7" Color="#D0D0D0"/>
    <SolidColorBrush x:Key="TerminalAnsi8" Color="#6A737D"/>
    <SolidColorBrush x:Key="TerminalAnsi9" Color="#F14C4C"/>
    <SolidColorBrush x:Key="TerminalAnsi10" Color="#3FC56B"/>
    <SolidColorBrush x:Key="TerminalAnsi11" Color="#EAE05B"/>
    <SolidColorBrush x:Key="TerminalAnsi12" Color="#5C8DF0"/>
    <SolidColorBrush x:Key="TerminalAnsi13" Color="#D67BEA"/>
    <SolidColorBrush x:Key="TerminalAnsi14" Color="#4FE0E8"/>
    <SolidColorBrush x:Key="TerminalAnsi15" Color="#FFFFFF"/>
</ResourceDictionary>
