<!-- ATELIER — warm craftsman dark.
     Warm charcoal surfaces, cream text, copper/brass accent, sage and
     oxblood semantics. Plays on the "Loom" weaving-craft heritage. -->
<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Surfaces -->
    <SolidColorBrush x:Key="SurfaceWindow" Color="#171512"/>
    <SolidColorBrush x:Key="SurfacePanel" Color="#1D1A16"/>
    <SolidColorBrush x:Key="SurfaceDeep" Color="#121009"/>
    <SolidColorBrush x:Key="SurfaceCard" Color="#24201A"/>
    <SolidColorBrush x:Key="SurfaceHover" Color="#2E2921"/>
    <SolidColorBrush x:Key="SurfaceHoverGhost" Color="#002E2921"/>
    <SolidColorBrush x:Key="ButtonBg" Color="#272219"/>
    <SolidColorBrush x:Key="BorderHairline" Color="#322D25"/>

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimary" Color="#EDE7DB"/>
    <SolidColorBrush x:Key="TextMuted" Color="#9C9284"/>
    <SolidColorBrush x:Key="OnAccent" Color="#171512"/>

    <!-- Signature accent -->
    <SolidColorBrush x:Key="AccentBrush" Color="#D8A25A"/>
    <SolidColorBrush x:Key="AccentHover" Color="#E4B677"/>
    <SolidColorBrush x:Key="AccentSelection" Color="#26D8A25A"/>

    <!-- Semantic -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#8FBC7F"/>
    <SolidColorBrush x:Key="SuccessHover" Color="#A5CC97"/>
    <SolidColorBrush x:Key="DangerBrush" Color="#E5726A"/>
    <SolidColorBrush x:Key="DangerHover" Color="#EC8F88"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#D9B04C"/>
    <SolidColorBrush x:Key="InfoBrush" Color="#6E96BE"/>

    <!-- Commit-graph lanes -->
    <!-- Lanes decoupled from semantic status tokens (DESIGN.md §2); retuned per ThemeRefinement Finding B. -->
    <SolidColorBrush x:Key="Lane1" Color="#E4C399"/>
    <SolidColorBrush x:Key="Lane2" Color="#AC57A5"/>
    <SolidColorBrush x:Key="Lane3" Color="#C7E0BF"/>
    <SolidColorBrush x:Key="Lane4" Color="#3A698E"/>
    <SolidColorBrush x:Key="Lane5" Color="#DA9A91"/>

    <!-- Diff line backgrounds -->
    <SolidColorBrush x:Key="DiffAddedBg" Color="#1E2A1A"/>
    <SolidColorBrush x:Key="DiffRemovedBg" Color="#33201D"/>
    <!-- Intra-line (word-level) emphasis + trailing-whitespace marker (T-13) -->
    <SolidColorBrush x:Key="DiffAddedEmphasis" Color="#668FBC7F"/>
    <SolidColorBrush x:Key="DiffRemovedEmphasis" Color="#66E5726A"/>
    <SolidColorBrush x:Key="DiffWhitespaceMarker" Color="#55D9B04C"/>

    <!-- Blame age-heat gutter (T-11): recent → BlameAgeNew, old → BlameAgeOld. -->
    <SolidColorBrush x:Key="BlameAgeNew" Color="#D9A441"/>
    <SolidColorBrush x:Key="BlameAgeOld" Color="#4A4238"/>
</ResourceDictionary>
