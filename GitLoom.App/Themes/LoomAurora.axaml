<!-- LOOM AURORA — cool indigo-tinted night.
     Deep blue-violet surfaces with an aurora-teal accent and violet/rose
     lanes. The flashier sibling of Midnight Loom. -->
<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Surfaces -->
    <SolidColorBrush x:Key="SurfaceWindow" Color="#111322"/>
    <SolidColorBrush x:Key="SurfacePanel" Color="#161930"/>
    <SolidColorBrush x:Key="SurfaceDeep" Color="#0C0E1A"/>
    <SolidColorBrush x:Key="SurfaceCard" Color="#1C2038"/>
    <SolidColorBrush x:Key="SurfaceHover" Color="#262B4A"/>
    <SolidColorBrush x:Key="SurfaceHoverGhost" Color="#00262B4A"/>
    <SolidColorBrush x:Key="ButtonBg" Color="#1F2440"/>
    <SolidColorBrush x:Key="BorderHairline" Color="#2A2F52"/>

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimary" Color="#E4E7F7"/>
    <SolidColorBrush x:Key="TextMuted" Color="#8D93B8"/>
    <SolidColorBrush x:Key="OnAccent" Color="#0C0E1A"/>

    <!-- Signature accent -->
    <SolidColorBrush x:Key="AccentBrush" Color="#4FD1C5"/>
    <SolidColorBrush x:Key="AccentHover" Color="#76E0D6"/>
    <SolidColorBrush x:Key="AccentSelection" Color="#264FD1C5"/>

    <!-- Semantic -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#4ADE80"/>
    <SolidColorBrush x:Key="SuccessHover" Color="#6EE79B"/>
    <SolidColorBrush x:Key="DangerBrush" Color="#F8719D"/>
    <SolidColorBrush x:Key="DangerHover" Color="#FA92B3"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#FACC6B"/>
    <SolidColorBrush x:Key="InfoBrush" Color="#60A5FA"/>

    <!-- Commit-graph lanes -->
    <!-- Lanes decoupled from semantic status tokens (DESIGN.md §2); retuned per ThemeRefinement Finding B. -->
    <SolidColorBrush x:Key="Lane1" Color="#79E0D5"/>
    <SolidColorBrush x:Key="Lane2" Color="#8B69F3"/>
    <SolidColorBrush x:Key="Lane3" Color="#F365B1"/>
    <SolidColorBrush x:Key="Lane4" Color="#FDF0D7"/>
    <SolidColorBrush x:Key="Lane5" Color="#0B63C9"/>

    <!-- Diff line backgrounds -->
    <SolidColorBrush x:Key="DiffAddedBg" Color="#10291F"/>
    <SolidColorBrush x:Key="DiffRemovedBg" Color="#351A26"/>
    <!-- Intra-line (word-level) emphasis + trailing-whitespace marker (T-13) -->
    <SolidColorBrush x:Key="DiffAddedEmphasis" Color="#664ADE80"/>
    <SolidColorBrush x:Key="DiffRemovedEmphasis" Color="#66F8719D"/>
    <SolidColorBrush x:Key="DiffWhitespaceMarker" Color="#55FACC6B"/>

    <!-- Blame age-heat gutter (T-11): recent → BlameAgeNew, old → BlameAgeOld. -->
    <SolidColorBrush x:Key="BlameAgeNew" Color="#FACC6B"/>
    <SolidColorBrush x:Key="BlameAgeOld" Color="#33395C"/>

    <!-- Terminal cell palette (P2-03 interim engine). Default surface + the 16 ANSI
         colours as tokens so the cell renderer follows the active theme and Daylight
         Loom stays readable; the 256-colour cube (16-255) is computed in code. -->
    <SolidColorBrush x:Key="TerminalBackground" Color="#0A0F14"/>
    <SolidColorBrush x:Key="TerminalForeground" Color="#E4EEF5"/>
    <SolidColorBrush x:Key="TerminalCursor" Color="#4CC2FF"/>
    <SolidColorBrush x:Key="TerminalAnsi0" Color="#000000"/>
    <SolidColorBrush x:Key="TerminalAnsi1" Color="#CD3131"/>
    <SolidColorBrush x:Key="TerminalAnsi2" Color="#2AA745"/>
    <SolidColorBrush x:Key="TerminalAnsi3" Color="#C7C43B"/>
    <SolidColorBrush x:Key="TerminalAnsi4" Color="#3B6FD6"/>
    <SolidColorBrush x:Key="TerminalAnsi5" Color="#B454C9"/>
    <SolidColorBrush x:Key="TerminalAnsi6" Color="#2EC5CE"/>
    <SolidColorBrush x:Key="TerminalAnsi7" Color="#D0D0D0"/>
    <SolidColorBrush x:Key="TerminalAnsi8" Color="#6A737D"/>
    <SolidColorBrush x:Key="TerminalAnsi9" Color="#F14C4C"/>
    <SolidColorBrush x:Key="TerminalAnsi10" Color="#3FC56B"/>
    <SolidColorBrush x:Key="TerminalAnsi11" Color="#EAE05B"/>
    <SolidColorBrush x:Key="TerminalAnsi12" Color="#5C8DF0"/>
    <SolidColorBrush x:Key="TerminalAnsi13" Color="#D67BEA"/>
    <SolidColorBrush x:Key="TerminalAnsi14" Color="#4FE0E8"/>
    <SolidColorBrush x:Key="TerminalAnsi15" Color="#FFFFFF"/>
</ResourceDictionary>
