<!-- COMMAND DECK — mission-control tactical dark.
     Near-black OLED surfaces, phosphor-teal accent, amber/rose/violet
     tactical status hues. -->
<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Surfaces -->
    <SolidColorBrush x:Key="SurfaceWindow" Color="#0A0C0E"/>
    <SolidColorBrush x:Key="SurfacePanel" Color="#0E1114"/>
    <SolidColorBrush x:Key="SurfaceDeep" Color="#07090B"/>
    <SolidColorBrush x:Key="SurfaceCard" Color="#13171B"/>
    <SolidColorBrush x:Key="SurfaceHover" Color="#1B2227"/>
    <SolidColorBrush x:Key="SurfaceHoverGhost" Color="#001B2227"/>
    <SolidColorBrush x:Key="ButtonBg" Color="#141A1E"/>
    <SolidColorBrush x:Key="BorderHairline" Color="#1F2529"/>

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimary" Color="#DCE3E8"/>
    <SolidColorBrush x:Key="TextMuted" Color="#7C8A94"/>
    <SolidColorBrush x:Key="OnAccent" Color="#07090B"/>

    <!-- Signature accent -->
    <SolidColorBrush x:Key="AccentBrush" Color="#2DD4BF"/>
    <SolidColorBrush x:Key="AccentHover" Color="#5EEAD4"/>
    <SolidColorBrush x:Key="AccentSelection" Color="#242DD4BF"/>

    <!-- Semantic -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#34D399"/>
    <SolidColorBrush x:Key="SuccessHover" Color="#6EE7B7"/>
    <SolidColorBrush x:Key="DangerBrush" Color="#FB7185"/>
    <SolidColorBrush x:Key="DangerHover" Color="#FDA4AF"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#FBBF24"/>
    <SolidColorBrush x:Key="InfoBrush" Color="#38BDF8"/>

    <!-- Commit-graph lanes -->
    <!-- Lanes decoupled from semantic status tokens (DESIGN.md §2); retuned per ThemeRefinement Finding B. -->
    <SolidColorBrush x:Key="Lane1" Color="#7AE7D9"/>
    <SolidColorBrush x:Key="Lane2" Color="#9D4AF0"/>
    <SolidColorBrush x:Key="Lane3" Color="#34CF82"/>
    <SolidColorBrush x:Key="Lane4" Color="#FCE091"/>
    <SolidColorBrush x:Key="Lane5" Color="#086EA1"/>

    <!-- Diff line backgrounds -->
    <SolidColorBrush x:Key="DiffAddedBg" Color="#0D251F"/>
    <SolidColorBrush x:Key="DiffRemovedBg" Color="#2A161B"/>
    <!-- Intra-line (word-level) emphasis + trailing-whitespace marker (T-13) -->
    <SolidColorBrush x:Key="DiffAddedEmphasis" Color="#6634D399"/>
    <SolidColorBrush x:Key="DiffRemovedEmphasis" Color="#66FB7185"/>
    <SolidColorBrush x:Key="DiffWhitespaceMarker" Color="#55FBBF24"/>

    <!-- Blame age-heat gutter (T-11): recent → BlameAgeNew, old → BlameAgeOld. -->
    <SolidColorBrush x:Key="BlameAgeNew" Color="#FBBF24"/>
    <SolidColorBrush x:Key="BlameAgeOld" Color="#2E3A40"/>

    <!-- Terminal cell palette (P2-03 interim engine). Default surface + the 16 ANSI
         colours as tokens so the cell renderer follows the active theme and Daylight
         Loom stays readable; the 256-colour cube (16-255) is computed in code. -->
    <SolidColorBrush x:Key="TerminalBackground" Color="#07100E"/>
    <SolidColorBrush x:Key="TerminalForeground" Color="#D6F5E8"/>
    <SolidColorBrush x:Key="TerminalCursor" Color="#39D98A"/>
    <SolidColorBrush x:Key="TerminalAnsi0" Color="#000000"/>
    <SolidColorBrush x:Key="TerminalAnsi1" Color="#CD3131"/>
    <SolidColorBrush x:Key="TerminalAnsi2" Color="#2AA745"/>
    <SolidColorBrush x:Key="TerminalAnsi3" Color="#C7C43B"/>
    <SolidColorBrush x:Key="TerminalAnsi4" Color="#3B6FD6"/>
    <SolidColorBrush x:Key="TerminalAnsi5" Color="#B454C9"/>
    <SolidColorBrush x:Key="TerminalAnsi6" Color="#2EC5CE"/>
    <SolidColorBrush x:Key="TerminalAnsi7" Color="#D0D0D0"/>
    <SolidColorBrush x:Key="TerminalAnsi8" Color="#6A737D"/>
    <SolidColorBrush x:Key="TerminalAnsi9" Color="#F14C4C"/>
    <SolidColorBrush x:Key="TerminalAnsi10" Color="#3FC56B"/>
    <SolidColorBrush x:Key="TerminalAnsi11" Color="#EAE05B"/>
    <SolidColorBrush x:Key="TerminalAnsi12" Color="#5C8DF0"/>
    <SolidColorBrush x:Key="TerminalAnsi13" Color="#D67BEA"/>
    <SolidColorBrush x:Key="TerminalAnsi14" Color="#4FE0E8"/>
    <SolidColorBrush x:Key="TerminalAnsi15" Color="#FFFFFF"/>
</ResourceDictionary>
