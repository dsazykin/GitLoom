<!-- DAYLIGHT LOOM — the light theme.
     Paper-white layered surfaces, ink text, the Loom violet accent deepened
     for contrast on light backgrounds. Registered with ThemeVariant.Light so
     built-in control chrome (menus, combo boxes) follows. -->
<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Surfaces (window → raised card; SurfaceDeep is the editor, brightest here) -->
    <SolidColorBrush x:Key="SurfaceWindow" Color="#EDEFF4"/>
    <SolidColorBrush x:Key="SurfacePanel" Color="#F7F8FB"/>
    <SolidColorBrush x:Key="SurfaceDeep" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SurfaceCard" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SurfaceHover" Color="#E3E6EE"/>
    <SolidColorBrush x:Key="SurfaceHoverGhost" Color="#00E3E6EE"/>
    <SolidColorBrush x:Key="ButtonBg" Color="#E9EBF1"/>
    <SolidColorBrush x:Key="BorderHairline" Color="#D8DBE4"/>

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimary" Color="#1D2130"/>
    <SolidColorBrush x:Key="TextMuted" Color="#5C6470"/>
    <SolidColorBrush x:Key="OnAccent" Color="#FFFFFF"/>

    <!-- Signature accent -->
    <SolidColorBrush x:Key="AccentBrush" Color="#6467E8"/>
    <SolidColorBrush x:Key="AccentHover" Color="#5457DE"/>
    <SolidColorBrush x:Key="AccentSelection" Color="#266467E8"/>

    <!-- Semantic -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#1F9D55"/>
    <SolidColorBrush x:Key="SuccessHover" Color="#178246"/>
    <SolidColorBrush x:Key="DangerBrush" Color="#D64545"/>
    <SolidColorBrush x:Key="DangerHover" Color="#C43A3A"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#A9770F"/>
    <SolidColorBrush x:Key="InfoBrush" Color="#0B78CE"/>

    <!-- Commit-graph lanes -->
    <!-- Lanes decoupled from semantic status tokens (DESIGN.md §2); retuned per ThemeRefinement Finding B. -->
    <SolidColorBrush x:Key="Lane1" Color="#3232E2"/>
    <SolidColorBrush x:Key="Lane2" Color="#C62A83"/>
    <SolidColorBrush x:Key="Lane3" Color="#075B55"/>
    <SolidColorBrush x:Key="Lane4" Color="#7B420A"/>
    <SolidColorBrush x:Key="Lane5" Color="#138BE6"/>

    <!-- Diff line backgrounds -->
    <SolidColorBrush x:Key="DiffAddedBg" Color="#DDF3E4"/>
    <SolidColorBrush x:Key="DiffRemovedBg" Color="#FBE2E2"/>
    <!-- Intra-line (word-level) emphasis + trailing-whitespace marker (T-13) -->
    <SolidColorBrush x:Key="DiffAddedEmphasis" Color="#661F9D55"/>
    <SolidColorBrush x:Key="DiffRemovedEmphasis" Color="#66D64545"/>
    <SolidColorBrush x:Key="DiffWhitespaceMarker" Color="#55A9770F"/>

    <!-- Blame age-heat gutter (T-11): recent → BlameAgeNew, old → BlameAgeOld. -->
    <SolidColorBrush x:Key="BlameAgeNew" Color="#C77D2E"/>
    <SolidColorBrush x:Key="BlameAgeOld" Color="#B9C0CC"/>

    <!-- Terminal cell palette (P2-03 interim engine). Default surface + the 16 ANSI
         colours as tokens so the cell renderer follows the active theme and Daylight
         Loom stays readable; the 256-colour cube (16-255) is computed in code. -->
    <SolidColorBrush x:Key="TerminalBackground" Color="#FBFBFD"/>
    <SolidColorBrush x:Key="TerminalForeground" Color="#1F2430"/>
    <SolidColorBrush x:Key="TerminalCursor" Color="#5B5BD6"/>
    <SolidColorBrush x:Key="TerminalAnsi0" Color="#000000"/>
    <SolidColorBrush x:Key="TerminalAnsi1" Color="#CD3131"/>
    <SolidColorBrush x:Key="TerminalAnsi2" Color="#2AA745"/>
    <SolidColorBrush x:Key="TerminalAnsi3" Color="#C7C43B"/>
    <SolidColorBrush x:Key="TerminalAnsi4" Color="#3B6FD6"/>
    <SolidColorBrush x:Key="TerminalAnsi5" Color="#B454C9"/>
    <SolidColorBrush x:Key="TerminalAnsi6" Color="#2EC5CE"/>
    <SolidColorBrush x:Key="TerminalAnsi7" Color="#D0D0D0"/>
    <SolidColorBrush x:Key="TerminalAnsi8" Color="#6A737D"/>
    <SolidColorBrush x:Key="TerminalAnsi9" Color="#F14C4C"/>
    <SolidColorBrush x:Key="TerminalAnsi10" Color="#3FC56B"/>
    <SolidColorBrush x:Key="TerminalAnsi11" Color="#EAE05B"/>
    <SolidColorBrush x:Key="TerminalAnsi12" Color="#5C8DF0"/>
    <SolidColorBrush x:Key="TerminalAnsi13" Color="#D67BEA"/>
    <SolidColorBrush x:Key="TerminalAnsi14" Color="#4FE0E8"/>
    <SolidColorBrush x:Key="TerminalAnsi15" Color="#FFFFFF"/>
</ResourceDictionary>
