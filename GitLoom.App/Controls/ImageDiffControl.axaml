<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GitLoom.App.ViewModels"
             x:Class="GitLoom.App.Controls.ImageDiffControl"
             x:DataType="vm:ImageDiffViewModel">

    <!--
      T-13 image diff. GROUNDWORK: shows the before/after image blobs side-by-side plus a size
      summary, and exposes an opacity slider bound to SwipePosition.
      TODO(T-13 human-review): image-diff swipe control feel — the onion-skin / drag-to-swipe
      overlay interaction is deferred for human review; this side-by-side + opacity slider is the
      reachable placeholder that keeps the detected image pair rendering.
    -->
    <Grid RowDefinitions="Auto, *, Auto" Margin="15">

        <TextBlock Grid.Row="0" Text="{Binding SizeSummary}" Foreground="{DynamicResource TextMuted}"
                   FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <Grid Grid.Row="1" ColumnDefinitions="*, Auto, *">
            <!-- Before -->
            <Border Grid.Column="0" Classes="Card" Background="{DynamicResource SurfaceCard}" Padding="8">
                <Grid RowDefinitions="Auto, *">
                    <TextBlock Grid.Row="0" Text="Before" Foreground="{DynamicResource TextMuted}"
                               FontSize="11" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <Image Grid.Row="1" Source="{Binding OldImage}" Stretch="Uniform"
                           IsVisible="{Binding HasOldImage}"/>
                    <TextBlock Grid.Row="1" Text="(none)" Foreground="{DynamicResource TextMuted}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               IsVisible="{Binding !HasOldImage}"/>
                </Grid>
            </Border>

            <Border Grid.Column="1" Width="1" Background="{DynamicResource BorderHairline}" Margin="10,0"/>

            <!-- After -->
            <Border Grid.Column="2" Classes="Card" Background="{DynamicResource SurfaceCard}" Padding="8">
                <Grid RowDefinitions="Auto, *">
                    <TextBlock Grid.Row="0" Text="After" Foreground="{DynamicResource TextMuted}"
                               FontSize="11" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <Image Grid.Row="1" Source="{Binding NewImage}" Stretch="Uniform"
                           IsVisible="{Binding HasNewImage}"/>
                    <TextBlock Grid.Row="1" Text="(none)" Foreground="{DynamicResource TextMuted}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               IsVisible="{Binding !HasNewImage}"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Opacity slider (swipe/onion-skin feel is the deferred, human-reviewed part) -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center" Margin="0,10,0,0">
            <TextBlock Text="Before" Foreground="{DynamicResource TextMuted}" FontSize="11" VerticalAlignment="Center"/>
            <Slider Minimum="0" Maximum="1" Width="220" Value="{Binding SwipePosition}" VerticalAlignment="Center"/>
            <TextBlock Text="After" Foreground="{DynamicResource TextMuted}" FontSize="11" VerticalAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>
