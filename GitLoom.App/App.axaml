<Application xmlns="https://github.com/avaloniaui"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 x:Class="GitLoom.App.App"
                 xmlns:local="using:GitLoom.App"
                 RequestedThemeVariant="Dark">

        <Application.DataTemplates>
            <local:ViewLocator/>
        </Application.DataTemplates>

        <Application.Resources>
            <!-- ============================================================
                 Color tokens live in Themes/*.axaml (Midnight Loom is the
                 default; ThemeManager swaps dictionaries at runtime).
                 Views MUST reference color tokens with DynamicResource.
                 Everything below is theme-INDEPENDENT: fonts and icons.
                 ============================================================ -->
            <ResourceDictionary>
                <ResourceDictionary.MergedDictionaries>
                    <ResourceInclude Source="avares://GitLoom.App/Themes/MidnightLoom.axaml"/>
                </ResourceDictionary.MergedDictionaries>

                <!-- Typography -->
                <FontFamily x:Key="FontUi">Inter, SF Pro Text, Segoe UI Variable, Segoe UI, Cantarell, Noto Sans, sans-serif</FontFamily>
                <FontFamily x:Key="FontMono">JetBrains Mono, Cascadia Mono, SF Mono, Consolas, DejaVu Sans Mono, monospace</FontFamily>

                <!-- Icons -->
                <StreamGeometry x:Key="CheckmarkIcon">M9,16.17L4.83,12L3.41,13.41L9,19L21,7L19.59,5.59L9,16.17Z</StreamGeometry>
                <StreamGeometry x:Key="SearchIcon">M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z</StreamGeometry>
                <StreamGeometry x:Key="ChevronRightIcon">M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z</StreamGeometry>
                <StreamGeometry x:Key="ChevronDownIcon">M7.41,8.58L12,13.17L16.59,8.58L18,10L12,16L6,10L7.41,8.58Z</StreamGeometry>
                <StreamGeometry x:Key="PlayIcon">M8 5v14l11-7z</StreamGeometry>
                <StreamGeometry x:Key="RefreshIcon">M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z</StreamGeometry>
                <StreamGeometry x:Key="EyeIcon">M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z</StreamGeometry>
                <StreamGeometry x:Key="CloudIcon">M19.35 10.04C18.67 6.59 15.64 4 12 4 9.11 4 6.6 5.64 5.35 8.04 2.34 8.36 0 10.91 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.65-4.96z</StreamGeometry>
                <StreamGeometry x:Key="FolderIcon">M10 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2h-8l-2-2z</StreamGeometry>
                <StreamGeometry x:Key="ArrowUpIcon">M4 12l1.41 1.41L11 7.83V20h2V7.83l5.58 5.59L20 12l-8-8-8 8z</StreamGeometry>
                <StreamGeometry x:Key="ArrowDownIcon">M20 12l-1.41-1.41L13 16.17V4h-2v12.17l-5.58-5.59L4 12l8 8 8-8z</StreamGeometry>
                <StreamGeometry x:Key="WarningIcon">M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z</StreamGeometry>
                <StreamGeometry x:Key="MenuIcon">M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z</StreamGeometry>
                <StreamGeometry x:Key="UndoIcon">M12.5 8c-2.65 0-5.05.99-6.9 2.6L2 7v9h9l-3.62-3.62c1.39-1.16 3.16-1.88 5.12-1.88 3.54 0 6.55 2.31 7.6 5.5l2.37-.78C21.08 11.03 17.15 8 12.5 8z</StreamGeometry>
                <StreamGeometry x:Key="DocumentAddIcon">M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 14h-3v3h-2v-3H8v-2h3v-3h2v3h3v2zm-3-7V3.5L18.5 9H13z</StreamGeometry>
                <StreamGeometry x:Key="DismissIcon">M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12 19 6.41Z</StreamGeometry>
                <StreamGeometry x:Key="DocumentIcon">M6 2c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6H6zm7 7V3.5L18.5 9H13z</StreamGeometry>
                <StreamGeometry x:Key="LockIcon">M12 17c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm6-9h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zM9 6c0-1.66 1.34-3 3-3s3 1.34 3 3v2H9V6zm9 14H6V10h12v10z</StreamGeometry>
                <StreamGeometry x:Key="GitHubIcon">M12 .5C5.37.5 0 5.87 0 12.5c0 5.3 3.44 9.8 8.21 11.39.6.11.82-.26.82-.58v-2.03c-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.09-.75.08-.73.08-.73 1.21.09 1.84 1.24 1.84 1.24 1.07 1.84 2.81 1.31 3.5 1 .11-.78.42-1.31.76-1.61-2.67-.3-5.47-1.34-5.47-5.95 0-1.31.47-2.39 1.24-3.23-.13-.3-.54-1.53.11-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 016 0c2.28-1.55 3.29-1.23 3.29-1.23.66 1.65.25 2.88.12 3.18.77.84 1.24 1.92 1.24 3.23 0 4.62-2.81 5.64-5.49 5.94.43.37.81 1.1.81 2.22v3.29c0 .32.22.7.83.58C20.57 22.29 24 17.79 24 12.5 24 5.87 18.63.5 12 .5z</StreamGeometry>
                <StreamGeometry x:Key="TagIcon">M21.41 11.58l-9-9C12.05 2.22 11.55 2 11 2H4c-1.1 0-2 .9-2 2v7c0 .55.22 1.05.59 1.42l9 9c.36.36.86.58 1.41.58s1.05-.22 1.41-.59l7-7c.37-.36.59-.86.59-1.41s-.23-1.06-.59-1.42zM5.5 7C4.67 7 4 6.33 4 5.5S4.67 4 5.5 4 7 4.67 7 5.5 6.33 7 5.5 7z</StreamGeometry>

                <!-- Custom window-control glyphs (24 viewbox; hollow shapes use nonzero-winding holes) -->
                <StreamGeometry x:Key="WindowMinimizeIcon">M4,11.25 H20 V12.75 H4 Z</StreamGeometry>
                <StreamGeometry x:Key="WindowMaximizeIcon">M4,5 H20 V19 H4 Z M6,7 V17 H18 V7 Z</StreamGeometry>
                <StreamGeometry x:Key="WindowRestoreIcon">M8,4 H20 V16 H16 V14 H18 V6 H10 V8 H8 Z M4,8 H14 V20 H4 Z M6,10 V18 H12 V10 Z</StreamGeometry>
            </ResourceDictionary>
        </Application.Resources>

        <Application.Styles>
            <FluentTheme />
            <StyleInclude Source="avares://AvaloniaEdit/Themes/Fluent/AvaloniaEdit.xaml" />

            <!-- App-wide typography -->
            <Style Selector="Window">
                <Setter Property="FontFamily" Value="{StaticResource FontUi}"/>
            </Style>
            <Style Selector="TextBlock.Mono">
                <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
            </Style>

            <!-- Hover states fade instead of snapping (depth & motion) -->
            <Style Selector="Button /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Transitions">
                    <Transitions>
                        <BrushTransition Property="Background" Duration="0:0:0.13"/>
                    </Transitions>
                </Setter>
            </Style>

            <!-- Default (class-less) buttons: pin every state to an OPAQUE token.
                 Fluent's ButtonBackground* brushes are pure white tinted only by
                 the brush's Opacity property (0.1). The BrushTransition above
                 interpolates the Color channel but drops that Opacity mid-flight,
                 so a plain button flashed opaque white before settling. Giving
                 each state an opaque token removes the flash. Declared BEFORE the
                 class styles below so .Primary/.Accent/.Danger/etc. still win. -->
            <Style Selector="Button">
                <Setter Property="Background" Value="{DynamicResource ButtonBg}"/>
            </Style>
            <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Background" Value="{DynamicResource SurfaceHover}"/>
            </Style>
            <Style Selector="Button:pressed /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Background" Value="{DynamicResource SurfaceCard}"/>
            </Style>

            <!-- Inputs: rounded with an accent focus ring -->
            <Style Selector="TextBox">
                <Setter Property="CornerRadius" Value="8"/>
            </Style>
            <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            </Style>

            <!-- Floating panel card: the rounded surface workspace panes sit on -->
            <Style Selector="Border.Card">
                <Setter Property="Background" Value="{DynamicResource SurfacePanel}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderHairline}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="12"/>
                <Setter Property="ClipToBounds" Value="True"/>
            </Style>

            <!-- Neutral / default action -->
            <Style Selector="Button.Primary">
                <Setter Property="Background" Value="{DynamicResource ButtonBg}"/>
                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderHairline}"/>
                <Setter Property="CornerRadius" Value="6"/>
            </Style>
            <Style Selector="Button.Primary:pointerover /template/ ContentPresenter">
                <Setter Property="Background" Value="{DynamicResource SurfaceHover}"/>
            </Style>
            <Style Selector="Button.Primary:pressed /template/ ContentPresenter">
                <Setter Property="Background" Value="{DynamicResource SurfaceCard}"/>
            </Style>

            <!-- Accent CTA: the single emphasized action in a view (WCAG AA on-fill text) -->
            <Style Selector="Button.Accent">
                <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource OnAccent}"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="CornerRadius" Value="6"/>
            </Style>
            <Style Selector="Button.Accent:pointerover /template/ ContentPresenter">
                <Setter Property="Background" Value="{DynamicResource AccentHover}"/>
            </Style>

            <!-- Success: positive / confirming action -->
            <Style Selector="Button.Success">
                <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource OnAccent}"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="CornerRadius" Value="6"/>
            </Style>
            <Style Selector="Button.Success:pointerover /template/ ContentPresenter">
                <Setter Property="Background" Value="{DynamicResource SuccessHover}"/>
            </Style>

            <!-- Danger: destructive action -->
            <Style Selector="Button.Danger">
                <Setter Property="Background" Value="{DynamicResource DangerBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource OnAccent}"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="CornerRadius" Value="6"/>
            </Style>
            <Style Selector="Button.Danger:pointerover /template/ ContentPresenter">
                <Setter Property="Background" Value="{DynamicResource DangerHover}"/>
            </Style>

            <!-- Secondary / cancel: transparent, muted, hairline border -->
            <Style Selector="Button.Secondary">
                <Setter Property="Background" Value="{DynamicResource SurfaceHoverGhost}"/>
                <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderHairline}"/>
                <Setter Property="CornerRadius" Value="6"/>
            </Style>
            <Style Selector="Button.Secondary:pointerover /template/ ContentPresenter">
                <Setter Property="Background" Value="{DynamicResource SurfaceHover}"/>
            </Style>

            <!-- Icon button: toolbar/inline icon actions get a circular hover -->
            <Style Selector="Button.IconButton">
                <Setter Property="Background" Value="{DynamicResource SurfaceHoverGhost}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="CornerRadius" Value="999"/>
                <Setter Property="Padding" Value="6"/>
            </Style>
            <Style Selector="Button.IconButton:pointerover /template/ ContentPresenter">
                <Setter Property="Background" Value="{DynamicResource SurfaceHover}"/>
            </Style>

            <!-- Pill: capsule-shaped button (branch selector, chips with actions) -->
            <Style Selector="Button.Pill">
                <Setter Property="CornerRadius" Value="999"/>
            </Style>

            <!-- Segmented control: a rounded track with segment buttons inside -->
            <Style Selector="Border.SegmentTrack">
                <Setter Property="Background" Value="{DynamicResource SurfaceCard}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderHairline}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding" Value="3"/>
            </Style>
            <Style Selector="Button.Segment">
                <Setter Property="Background" Value="{DynamicResource SurfaceHoverGhost}"/>
                <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="CornerRadius" Value="6"/>
                <Setter Property="Padding" Value="12,3"/>
                <Setter Property="FontSize" Value="12"/>
            </Style>
            <Style Selector="Button.Segment:pointerover /template/ ContentPresenter">
                <Setter Property="Background" Value="{DynamicResource SurfaceHover}"/>
            </Style>
            <Style Selector="Button.Segment.Active">
                <Setter Property="Background" Value="{DynamicResource SurfaceHover}"/>
                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </Style>

            <!-- Window controls (custom title-bar chrome): full-height square buttons -->
            <Style Selector="Button.WindowButton">
                <Setter Property="Background" Value="{DynamicResource SurfaceHoverGhost}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="CornerRadius" Value="0"/>
                <Setter Property="Width" Value="46"/>
                <Setter Property="VerticalAlignment" Value="Stretch"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
            </Style>
            <Style Selector="Button.WindowButton:pointerover /template/ ContentPresenter">
                <Setter Property="Background" Value="{DynamicResource SurfaceHover}"/>
            </Style>
            <Style Selector="Button.WindowButton:pointerover PathIcon">
                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            </Style>
            <Style Selector="Button.WindowButton.Close:pointerover /template/ ContentPresenter">
                <Setter Property="Background" Value="{DynamicResource DangerBrush}"/>
            </Style>
            <Style Selector="Button.WindowButton.Close:pointerover PathIcon">
                <Setter Property="Foreground" Value="{DynamicResource OnAccent}"/>
            </Style>

            <!-- ComboBox: match the theme (closed control + drop-down popup + items) -->
            <Style Selector="ComboBox">
                <Setter Property="Background" Value="{DynamicResource SurfaceCard}"/>
                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderHairline}"/>
                <Setter Property="CornerRadius" Value="6"/>
            </Style>
            <Style Selector="ComboBox /template/ Border#PopupBorder">
                <Setter Property="Background" Value="{DynamicResource SurfacePanel}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderHairline}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="8"/>
            </Style>
            <Style Selector="ComboBoxItem">
                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                <Setter Property="CornerRadius" Value="4"/>
                <Setter Property="Margin" Value="3,1"/>
            </Style>
            <Style Selector="ComboBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Background" Value="{DynamicResource SurfaceHover}"/>
            </Style>
            <Style Selector="ComboBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Background" Value="{DynamicResource AccentSelection}"/>
            </Style>

            <!-- Flyouts, menus, and context menus: themed surface + rounded card -->
            <Style Selector="FlyoutPresenter">
                <Setter Property="Background" Value="{DynamicResource SurfacePanel}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderHairline}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="10"/>
            </Style>
            <Style Selector="MenuFlyoutPresenter">
                <Setter Property="Background" Value="{DynamicResource SurfacePanel}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderHairline}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="8"/>
            </Style>
            <Style Selector="ContextMenu">
                <Setter Property="Background" Value="{DynamicResource SurfacePanel}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderHairline}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="8"/>
            </Style>
            <Style Selector="MenuItem:selected /template/ Border#PART_LayoutRoot">
                <Setter Property="Background" Value="{DynamicResource SurfaceHover}"/>
                <Setter Property="CornerRadius" Value="4"/>
            </Style>

            <!-- Checkboxes are sized to match their label text (left-anchored so layout doesn't shift).
                 Default = "select all" / option size; .FileRow = the smaller per-item list size. -->
            <Style Selector="CheckBox">
                <Setter Property="RenderTransform" Value="scale(0.85)"/>
                <Setter Property="RenderTransformOrigin" Value="0%,50%"/>
            </Style>
            <Style Selector="CheckBox.FileRow">
                <Setter Property="RenderTransform" Value="scale(0.65)"/>
                <Setter Property="RenderTransformOrigin" Value="0%,50%"/>
            </Style>

            <!-- Shared expand/collapse chevron (data swaps on .expanded) -->
            <Style Selector="PathIcon.Chevron">
                <Setter Property="Data" Value="{StaticResource ChevronRightIcon}" />
            </Style>
            <Style Selector="PathIcon.Chevron.expanded">
                <Setter Property="Data" Value="{StaticResource ChevronDownIcon}" />
            </Style>

            <Style Selector="PathIcon.spinning">
                <Style.Animations>
                    <Animation Duration="0:0:1" IterationCount="Infinite">
                        <KeyFrame Cue="0%">
                            <Setter Property="RotateTransform.Angle" Value="0"/>
                        </KeyFrame>
                        <KeyFrame Cue="100%">
                            <Setter Property="RotateTransform.Angle" Value="360"/>
                        </KeyFrame>
                    </Animation>
                </Style.Animations>
            </Style>
        </Application.Styles>
    </Application>
