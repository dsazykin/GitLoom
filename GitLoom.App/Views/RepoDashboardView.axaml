<UserControl xmlns="https://github.com/avaloniaui"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:vm="using:GitLoom.App.ViewModels"
                 xmlns:models="using:GitLoom.Core.Models"
                 x:Class="GitLoom.App.Views.RepoDashboardView"
                 x:DataType="vm:RepoDashboardViewModel">
    
    <UserControl.Styles>
        <Style Selector="Border.IsAdded">
            <Setter Property="Background" Value="#1A3A22"/>
        </Style>
        <Style Selector="Border.IsRemoved">
            <Setter Property="Background" Value="#4D1D22"/>
        </Style>
        <Style Selector="Border.IsHeader">
            <Setter Property="Background" Value="#252526"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto, *">
            <!-- Header -->
            <Border Grid.Row="0" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,0,1" Padding="20">
                <TextBlock Text="{Binding RepositoryName}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
            </Border>

            <!-- Main Content Splitter -->
            <Grid Grid.Row="1" ColumnDefinitions="300, *">

                <!-- LEFT PANEL: Source Control Lists -->
                <Border Grid.Column="0" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,1,0" Padding="15">
                    <StackPanel Spacing="15">

                        <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,5">
                            <TextBlock Grid.Column="0" Text="STAGED CHANGES" Foreground="{StaticResource TextMuted}" FontWeight="Bold" FontSize="11"
                                       LetterSpacing="1" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Classes="Primary" Content="Unstage Selected" Padding="8,4" FontSize="11"
                                    Command="{Binding UnstageSelectedFilesCommand}"
                                    CommandParameter="{Binding #StagedListBox.SelectedItems}" />
                        </Grid>

                        <ListBox x:Name="StagedListBox" SelectedItem="{Binding SelectedFile}" SelectionMode="Multiple" ItemsSource="{Binding StagedFiles}" Background="Transparent" BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="models:GitFileStatus">
                                    <Grid ColumnDefinitions="Auto, *" Background="Transparent">
                                        <Button Grid.Column="0" Classes="Primary" Content="-" Padding="8,2" FontSize="14" FontWeight="Bold" Margin="0,0,10,0"
                                                Command="{Binding $parent[UserControl].((vm:RepoDashboardViewModel)DataContext).UnstageFileCommand}"
                                                CommandParameter="{Binding}" />

                                        <TextBlock Grid.Column="1" Text="{Binding FilePath}" Foreground="{StaticResource BranchGreen}" FontSize="13"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,5">
                            <TextBlock Grid.Column="0" Text="CHANGES" Foreground="{StaticResource TextMuted}" FontWeight="Bold" FontSize="11"
                                       LetterSpacing="1" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Classes="Primary" Content="Stage Selected" Padding="8,4" FontSize="11"
                                    Command="{Binding StageSelectedFilesCommand}"
                                    CommandParameter="{Binding #UnstagedListBox.SelectedItems}" />
                        </Grid>

                        <ListBox x:Name="UnstagedListBox" SelectedItem="{Binding SelectedFile}" SelectionMode="Multiple" ItemsSource="{Binding UnstagedFiles}" Background="Transparent" BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="models:GitFileStatus">
                                    <Grid ColumnDefinitions="Auto, *" Background="Transparent">
                                        <Button Grid.Column="0" Classes="Primary" Content="+" Padding="8,2" FontSize="14" FontWeight="Bold" Margin="0,0,10,0"
                                                Command="{Binding $parent[UserControl].((vm:RepoDashboardViewModel)DataContext).StageFileCommand}"
                                                CommandParameter="{Binding}" />

                                        <TextBlock Grid.Column="1" Text="{Binding FilePath}" Foreground="{StaticResource BranchRed}" FontSize="13"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                    </StackPanel>
                </Border>

                <!-- RIGHT PANEL: Plain-Text Diff Viewer -->
                <ScrollViewer Grid.Column="1" Background="{StaticResource BgWindow}">
                    <ItemsControl ItemsSource="{Binding DiffLines}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:GitDiffLine">
                                <!-- Avalonia will dynamically apply these Classes if the boolean properties are true! -->
                                <Border Classes.IsAdded="{Binding IsAdded}"
                                        Classes.IsRemoved="{Binding IsRemoved}"
                                        Classes.IsHeader="{Binding IsHeader}">

                                    <TextBlock Text="{Binding Content}"
                                               FontFamily="Consolas, Courier New, Monospace"
                                               FontSize="13"
                                               Foreground="{StaticResource TextPrimary}"
                                               Margin="10,0"
                                               LineHeight="20"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </UserControl>