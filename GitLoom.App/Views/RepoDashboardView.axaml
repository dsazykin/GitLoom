<UserControl xmlns="https://github.com/avaloniaui"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:vm="using:GitLoom.App.ViewModels"
                 xmlns:models="using:GitLoom.Core.Models"
                 x:Class="GitLoom.App.Views.RepoDashboardView"
                 x:DataType="vm:RepoDashboardViewModel">
    
    <UserControl.Styles>
        <Style Selector="Border.IsAdded">
            <Setter Property="Background" Value="#1A3A22"/>
        </Style>
        <Style Selector="Border.IsRemoved">
            <Setter Property="Background" Value="#4D1D22"/>
        </Style>
        <Style Selector="Border.IsHeader">
            <Setter Property="Background" Value="#252526"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto, *">
        <!-- Header -->
        <Border Grid.Row="0" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,0,1" Padding="20">
            <Grid ColumnDefinitions="*, Auto">

                <!-- Repository Name -->
                <TextBlock Grid.Column="0" Text="{Binding RepositoryName}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"
                           VerticalAlignment="Center"/>

                <!-- Sync Controls -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                    <Button Classes="Primary" Content="↓ Pull" Padding="15,6" FontWeight="SemiBold" Command="{Binding PullCommand}"/>
                    <Button Classes="Primary" Content="↑ Push" Padding="15,6" FontWeight="SemiBold" Command="{Binding PushCommand}"/>
                </StackPanel>

            </Grid>
        </Border>

            <!-- Main Content Splitter -->
            <Grid Grid.Row="1" ColumnDefinitions="300, 350, *">

                <!-- LEFT PANEL: Source Control Lists -->
                <Border Grid.Column="0" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,1,0" Padding="15">
                    <Grid RowDefinitions="*, Auto">

                        <!-- Scrollable File Lists -->
                        <ScrollViewer Grid.Row="0" Margin="0,0,0,15">
                            <StackPanel Spacing="15">

                                <!-- Staged Block -->
                                <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,5">
                                    <TextBlock Grid.Column="0" Text="STAGED CHANGES" Foreground="{StaticResource TextMuted}" FontWeight="Bold" FontSize="11" LetterSpacing="1" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="5">
                                        <Button Classes="Primary" Content="Unstage" Padding="8,4" FontSize="11" Command="{Binding UnstageSelectedFilesCommand}" CommandParameter="{Binding #StagedListBox.SelectedItems}" />
                                        <Button Classes="Primary" Content="Unstage All" Padding="8,4" FontSize="11" Command="{Binding UnstageAllFilesCommand}" />
                                    </StackPanel>
                                </Grid>
                                <ListBox x:Name="StagedListBox" SelectionMode="Multiple" ItemsSource="{Binding StagedFiles}" Background="Transparent" BorderThickness="0">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="models:GitFileStatus">
                                            <Grid ColumnDefinitions="Auto, *" Background="Transparent">
                                                <Button Grid.Column="0" Classes="Primary" Content="-" Padding="8,2" FontSize="14" FontWeight="Bold" Margin="0,0,10,0" Command="{Binding $parent[UserControl].((vm:RepoDashboardViewModel)DataContext).UnstageFileCommand}" CommandParameter="{Binding}" />
                                                <TextBlock Grid.Column="1" Text="{Binding FilePath}" Foreground="{StaticResource BranchGreen}" FontSize="13" VerticalAlignment="Center"/>                                           </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <!-- Unstaged Block -->
                                <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,5">
                                    <TextBlock Grid.Column="0" Text="CHANGES" Foreground="{StaticResource TextMuted}" FontWeight="Bold" FontSize="11" LetterSpacing="1" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="5">
                                        <Button Classes="Primary" Content="Stage" Padding="8,4" FontSize="11" Command="{Binding StageSelectedFilesCommand}" CommandParameter="{Binding #UnstagedListBox.SelectedItems}" />
                                        <Button Classes="Primary" Content="Stage All" Padding="8,4" FontSize="11" Command="{Binding StageAllFilesCommand}" />
                                    </StackPanel>
                                </Grid>
                                <ListBox x:Name="UnstagedListBox" SelectedItem="{Binding SelectedFile}" SelectionMode="Multiple" ItemsSource="{Binding UnstagedFiles}" Background="Transparent" BorderThickness="0">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="models:GitFileStatus">
                                            <Grid ColumnDefinitions="Auto, *" Background="Transparent">
                                                <Button Grid.Column="0" Classes="Primary" Content="+" Padding="8,2" FontSize="14" FontWeight="Bold" Margin="0,0,10,0" Command="{Binding $parent[UserControl].((vm:RepoDashboardViewModel)DataContext).StageFileCommand}" CommandParameter="{Binding}" />
                                                <TextBlock Grid.Column="1" Text="{Binding FilePath}" Foreground="{StaticResource BranchRed}" FontSize="13" VerticalAlignment="Center"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                            </StackPanel>
                        </ScrollViewer>

                        <!-- Fixed Commit Composer -->
                        <Border Grid.Row="1" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,1,0,0" Padding="0,15,0,0">
                            <StackPanel Spacing="10">
                                <TextBox Text="{Binding CommitMessage}" Watermark="Commit message..." Height="80" AcceptsReturn="True" TextWrapping="Wrap"/>
                                <Button Classes="Primary" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="0,8"
                                        Command="{Binding CommitCommand}">
                                    <TextBlock Text="Commit" FontWeight="SemiBold"/>
                                </Button>
                            </StackPanel>
                        </Border>

                    </Grid>
                </Border>
                
                <!-- CENTER PANEL: Commit History Timeline -->
                <Border Grid.Column="1" Background="{StaticResource BgWindow}" 
                BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,1,0">
                    <Grid RowDefinitions="Auto, *">
                        <!-- Optional Title for the center pane -->
                        <TextBlock Grid.Row="0" Text="COMMIT HISTORY" Foreground="{StaticResource TextMuted}" FontWeight="Bold" FontSize="11" LetterSpacing="1" Margin="15,15,15,10"/>

                        <!-- Paste the ListBox from the previous step here! -->
                        <ListBox Grid.Row="1" ItemsSource="{Binding Commits}" Background="Transparent" BorderThickness="0" Margin="10,0">
                            <!-- ... ItemsPanel and ItemTemplate go here ... -->
                        </ListBox>
                    </Grid>
                </Border>

                <!-- RIGHT PANEL: Diff Viewer -->
                    <Grid Grid.Column="2" Background="{StaticResource BgWindow}" 
                    RowDefinitions="Auto, *">

                        <!-- View Toggle Button -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
                            <ToggleButton Content="Side-by-Side View" IsChecked="{Binding IsSideBySideView}"
                                          Background="{StaticResource ButtonBg}" Foreground="{StaticResource TextPrimary}"
                                          BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1" CornerRadius="4" Padding="12,6"/>
                        </StackPanel>

                        <!-- UNIFIED VIEW -->
                        <ScrollViewer Grid.Row="1" IsVisible="{Binding !IsSideBySideView}">
                            <ItemsControl ItemsSource="{Binding DiffLines}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:GitDiffLine">
                                        <Border Classes.IsAdded="{Binding IsAdded}"
                                                Classes.IsRemoved="{Binding IsRemoved}"
                                                Classes.IsHeader="{Binding IsHeader}">
                                            <TextBlock Text="{Binding Content}" FontFamily="Consolas, Courier New, Monospace" FontSize="13" Foreground="{StaticResource TextPrimary}" Margin="10,0" LineHeight="20"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- SIDE-BY-SIDE VIEW -->
                        <ScrollViewer Grid.Row="1" IsVisible="{Binding IsSideBySideView}">
                            <ItemsControl ItemsSource="{Binding SideBySideLines}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:SideBySideDiffRow">
                                        <Grid ColumnDefinitions="*, *">

                                            <!-- Left Column (Deletions) -->
                                            <Border Grid.Column="0" Classes.IsRemoved="{Binding LeftLine.IsRemoved}" Classes.IsHeader="{Binding LeftLine.IsHeader}">
                                                <TextBlock Text="{Binding LeftLine.Content}" FontFamily="Consolas, Courier New, Monospace" FontSize="13" Foreground="{StaticResource TextPrimary}" Margin="10,0" LineHeight="20"/>
                                            </Border>

                                            <!-- Right Column (Additions) -->
                                            <Border Grid.Column="1" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1,0,0,0"
                                                    Classes.IsAdded="{Binding RightLine.IsAdded}" Classes.IsHeader="{Binding RightLine.IsHeader}">
                                                <TextBlock Text="{Binding RightLine.Content}" FontFamily="Consolas, Courier New, Monospace" FontSize="13" Foreground="{StaticResource TextPrimary}" Margin="10,0" LineHeight="20"/>
                                            </Border>

                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
            </Grid>
        </Grid>
    </UserControl>