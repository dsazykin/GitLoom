<UserControl xmlns="https://github.com/avaloniaui"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:vm="using:GitLoom.App.ViewModels"
                 xmlns:models="using:GitLoom.Core.Models"
                 xmlns:controls="clr-namespace:GitLoom.App.Controls"
                 xmlns:views="clr-namespace:GitLoom.App.Views"
                 x:Class="GitLoom.App.Views.RepoDashboardView"
                 x:DataType="vm:RepoDashboardViewModel">

    <UserControl.Styles>
        <Style Selector="Border.toast">
            <Setter Property="Background" Value="{StaticResource BranchGreen}" />
        </Style>
        <Style Selector="Border.toast.error">
            <Setter Property="Background" Value="{StaticResource BranchRed}" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="*">
        
        <!-- Skeleton Ghost Loader -->
        <Border Grid.Row="0" IsVisible="{Binding IsLoading}" Background="{StaticResource BgWindow}" ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20">
                <TextBlock Text="Parsing Repository..." FontSize="18" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center"/>
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Foreground="{StaticResource BranchCyan}" Background="{StaticResource PanelSurface}"/>
            </StackPanel>
        </Border>
        
        <!-- Main Content Splitter -->
        <Grid Grid.Row="0" RowDefinitions="7*, Auto, 3*" IsVisible="{Binding !IsLoading}">
            
            <!-- TOP HALF (70%): Creator & Diff Viewer -->
            <Grid Grid.Row="0" ColumnDefinitions="350, Auto, *">

                <!-- LEFT PANEL: Source Control Lists -->
                <Border Grid.Column="0" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,1,0" Padding="15">
                    <views:StagingPanelView DataContext="{Binding StagingPanel}" />
                </Border>

                <!-- Vertical Drag Handle -->
                <GridSplitter Grid.Column="1" Width="4" Background="{StaticResource BorderSubtle}"
                              ResizeDirection="Columns"/>
                
                <!-- RIGHT PANEL: Diff Viewer -->
                <views:DiffViewerView Grid.Column="2" DataContext="{Binding DiffViewer}" />
            </Grid>
            
            <!-- Horizontal Drag Handle -->
            <GridSplitter Grid.Row="1" Height="4" Background="{StaticResource BorderSubtle}" ResizeDirection="Rows"/>

            <!-- BOTTOM HALF (30%): Commit History Timeline -->
            <Border Grid.Row="2" Background="{StaticResource BgWindow}" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,1,0">
                <views:CommitTimelineView DataContext="{Binding CommitTimeline}" />
            </Border>

        </Grid>
        
        <!-- Floating Notification Toast -->
        <Border Grid.Row="1" Classes="toast" Classes.error="{Binding IsErrorNotification}" CornerRadius="6" Padding="15,10"
                HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="20"
                IsVisible="{Binding IsNotificationVisible}"
                BoxShadow="0 4 10 0 #40000000">
            <TextBlock Text="{Binding NotificationMessage}" Foreground="White" FontWeight="SemiBold" />
        </Border>
    </Grid>
</UserControl>