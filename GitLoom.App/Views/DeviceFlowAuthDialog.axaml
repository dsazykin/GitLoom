<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="GitLoom.App.Views.DeviceFlowAuthDialog"
        Title="GitHub Authorization"
        Width="450" Height="250"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{StaticResource BgSidebar}">
    
    <Grid RowDefinitions="Auto, *, Auto" Margin="20">
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10">
            <PathIcon Data="{StaticResource GitHubIcon}" Width="24" Height="24" Foreground="{StaticResource TextPrimary}"/>
            <TextBlock Text="Connect to GitHub" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Spacing="10" VerticalAlignment="Center">
            <TextBlock Text="1. Go to the following URL in your browser:" Foreground="{StaticResource TextPrimary}" FontSize="14"/>
            <SelectableTextBlock x:Name="UrlText" Text="https://github.com/login/device" Foreground="{StaticResource BranchCyan}" FontSize="14" FontWeight="SemiBold" Cursor="Hand" PointerPressed="Url_PointerPressed"/>
            
            <TextBlock Text="2. Enter this code to authenticate GitLoom:" Foreground="{StaticResource TextPrimary}" FontSize="14" Margin="0,10,0,0"/>
            <Border Background="{StaticResource PanelSurface}" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1" CornerRadius="4" Padding="10">
                <Grid ColumnDefinitions="*, Auto">
                    <SelectableTextBlock x:Name="CodeText" Grid.Column="0" Text="XXXX-YYYY" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center"/>
                    <Button Grid.Column="1" Content="Copy" Click="CopyCode_Click" Background="Transparent" Foreground="{StaticResource BranchCyan}"/>
                </Grid>
            </Border>
        </StackPanel>

        <Button Grid.Row="2" Content="Cancel" Click="Cancel_Click" Background="Transparent" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Right"/>
    </Grid>
</Window>
