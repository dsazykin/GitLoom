<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="GitLoom.App.Views.DeviceFlowAuthDialog"
        Title="GitHub Authorization"
        Width="450" Height="250"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{StaticResource BgSidebar}">
    
    <Grid RowDefinitions="Auto, *, Auto" Margin="20">
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
            <PathIcon Data="{StaticResource GitHubIcon}" Width="24" Height="24" Foreground="{StaticResource TextPrimary}"/>
            <TextBlock Text="Connect to GitHub" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Spacing="10" VerticalAlignment="Center" HorizontalAlignment="Stretch">
            <TextBlock Text="1. Your browser will open automatically." Foreground="{StaticResource TextPrimary}" FontSize="14" TextAlignment="Center"/>
            <TextBlock Text="(If it didn't, click the URL below:)" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,-5,0,0" TextAlignment="Center"/>
            <SelectableTextBlock x:Name="UrlText" Text="https://github.com/login/device" Foreground="{StaticResource BranchCyan}" FontSize="14" FontWeight="SemiBold" Cursor="Hand" PointerPressed="Url_PointerPressed" TextAlignment="Center"/>
            
            <TextBlock Text="2. The following code was copied to your clipboard!" Foreground="{StaticResource TextPrimary}" FontSize="14" Margin="0,10,0,0" TextAlignment="Center"/>
            <Border Background="{StaticResource PanelSurface}" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1" CornerRadius="4" Padding="10" HorizontalAlignment="Center">
                <Grid ColumnDefinitions="*, Auto" Width="250">
                    <SelectableTextBlock x:Name="CodeText" Grid.Column="0" Text="XXXX-YYYY" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="Copy Again" Click="CopyCode_Click" Background="Transparent" Foreground="{StaticResource BranchCyan}" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </StackPanel>

        <Button Grid.Row="2" Content="Cancel" Click="Cancel_Click" Background="Transparent" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Right"/>
    </Grid>
</Window>
