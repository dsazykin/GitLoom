<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GitLoom.App.ViewModels"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             xmlns:controls="clr-namespace:GitLoom.App.Controls"
             xmlns:converters="using:GitLoom.App.Converters"
             x:Class="GitLoom.App.Views.CommitTimelineView"
             x:DataType="vm:CommitTimelineViewModel"
             x:Name="Root">
    <UserControl.Resources>
        <converters:FileExtensionToIconConverter x:Key="FileExtensionToIconConverter" />
    </UserControl.Resources>
    <UserControl.Styles>
        <Style Selector="TreeViewItem">
            <Setter Property="MinHeight" Value="24"/>
        </Style>
        <Style Selector="PathIcon.spinning">
            <Style.Animations>
                <Animation Duration="0:0:1" IterationCount="Infinite">
                    <KeyFrame Cue="0%">
                        <Setter Property="RotateTransform.Angle" Value="0"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="RotateTransform.Angle" Value="360"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </UserControl.Styles>
    
    <Grid ColumnDefinitions="250, 4, *, 4, 300">
        
        <!-- LEFT PANEL: Branches -->
        <Border Grid.Column="0" Background="{StaticResource BgSidebar}" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto, *">
                <Grid Grid.Row="0" Margin="10,10,10,5">
                    <TextBox Classes="searchBox" Watermark="Branch or tag" BorderThickness="1" BorderBrush="Transparent" Background="Transparent" FontSize="13" Padding="25,5,5,5" />
                    <PathIcon Data="{StaticResource SearchIcon}" Width="12" Height="12" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Left" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </Grid>
                
                <TreeView Grid.Row="1" ItemsSource="{Binding BranchBrowser.BranchCategories}" SelectedItem="{Binding SelectedBranchMenuItem, Mode=TwoWay}" Background="Transparent" BorderThickness="0">
                    <TreeView.ItemTemplate>
                        <TreeDataTemplate DataType="vm:BranchCategoryViewModel" ItemsSource="{Binding Branches}">
                            <TextBlock Text="{Binding CategoryName}" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                        </TreeDataTemplate>
                    </TreeView.ItemTemplate>
                    <TreeView.DataTemplates>
                        <DataTemplate DataType="vm:MenuItemViewModel">
                            <StackPanel Orientation="Horizontal" Spacing="5" Background="Transparent">
                                <PathIcon Data="{StaticResource CheckmarkIcon}" IsVisible="{Binding IsCurrentBranch}" Foreground="{StaticResource BranchCyan}" Width="12" Height="12"/>
                                <TextBlock Text="{Binding Header}" FontSize="12" VerticalAlignment="Center" Foreground="{StaticResource TextPrimary}"/>
                            </StackPanel>
                        </DataTemplate>
                    </TreeView.DataTemplates>
                </TreeView>
            </Grid>
        </Border>

        <!-- Vertical Drag Handle 1 -->
        <GridSplitter Grid.Column="1" Width="4" Background="{StaticResource BorderSubtle}" ResizeDirection="Columns"/>

        <!-- CENTER PANEL: Timeline -->
        <Grid Grid.Column="2" RowDefinitions="Auto, *">
            <!-- TOOLBAR HEADER -->
            <Border Grid.Row="0" Background="{StaticResource PanelSurface}" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,0,1" Padding="10,5">
                <Grid ColumnDefinitions="Auto, Auto, Auto, Auto, Auto, Auto, *, Auto">
                    <!-- Search Box -->
                    <Grid Grid.Column="0" Margin="0,0,10,0" Width="200">
                        <TextBox Classes="searchBox" Watermark="Text or hash" Text="{Binding SearchText, Mode=TwoWay}" BorderThickness="1" BorderBrush="Transparent" Background="Transparent" FontSize="13" Padding="25,5,5,5" Foreground="{StaticResource TextPrimary}" />
                        <PathIcon Data="{StaticResource SearchIcon}" Width="12" Height="12" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Left" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,5,0" Spacing="4">
                            <TextBlock Text=".*" FontSize="10" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" FontWeight="Bold"/>
                            <TextBlock Text="Cc" FontSize="10" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>

                    <ComboBox Grid.Column="1" ItemsSource="{Binding Branches}" SelectedItem="{Binding SelectedBranchItem}" PlaceholderText="Branch" Background="Transparent" BorderThickness="0" Margin="0,0,5,0">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <ComboBox Grid.Column="2" ItemsSource="{Binding Authors}" SelectedItem="{Binding SelectedAuthor}" PlaceholderText="User" Background="Transparent" BorderThickness="0" Margin="0,0,5,0" />

                    <ComboBox Grid.Column="3" ItemsSource="{Binding DateFilters}" SelectedItem="{Binding SelectedDateFilter}" PlaceholderText="Date" Background="Transparent" BorderThickness="0" Margin="0,0,5,0" />

                    <Button Grid.Column="4" Background="Transparent" BorderThickness="0" Padding="8,4" Foreground="{StaticResource TextPrimary}">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <TextBlock Text="Paths" />
                            <PathIcon Data="{StaticResource ChevronRightIcon}" Width="8" Height="8" RenderTransform="rotate(90deg)" />
                        </StackPanel>
                        <Button.Flyout>
                            <Flyout>
                                <Grid Width="350" Height="400" RowDefinitions="*, Auto">
                                    <TabControl Grid.Row="0">
                                        <TabItem Header="Select">
                                            <TextBox AcceptsReturn="True" Text="{Binding CustomPathsText}" Watermark="Enter paths separated by new lines" Margin="5" />
                                        </TabItem>
                                        <TabItem Header="Select in Tree">
                                            <TreeView ItemsSource="{Binding RepoTree}" Margin="5">
                                                <TreeView.ItemTemplate>
                                                    <TreeDataTemplate ItemsSource="{Binding Children}">
                                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                                            <CheckBox IsChecked="{Binding IsChecked}" />
                                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </TreeDataTemplate>
                                                </TreeView.ItemTemplate>
                                            </TreeView>
                                        </TabItem>
                                    </TabControl>
                                    <Button Grid.Row="1" Content="Apply" Command="{Binding ApplyPathsFilterCommand}" HorizontalAlignment="Right" Classes="Primary" Margin="5" />
                                </Grid>
                            </Flyout>
                        </Button.Flyout>
                    </Button>

                    <!-- Action Icons -->
                    <StackPanel Grid.Column="7" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center" Margin="0,0,5,0">
                        <Button Background="Transparent" BorderThickness="0" Padding="4,2">
                            <PathIcon Data="{StaticResource PlayIcon}" Width="14" Height="14" Foreground="{StaticResource TextMuted}"/>
                            <Button.Flyout>
                                <MenuFlyout>
                                    <MenuItem Header="Enable Git Log Indexing" Command="{Binding EnableGitLogIndexingCommand}" />
                                    <MenuItem Header="Indexing project repositories improves&#x0a;working with history of changes across IDE:&#x0a;- Fast log filtering and computing precise history&#x0a;- Branch filter in file history for revision&#x0a;- Searching across history in Search Everywhere" IsEnabled="False" />
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                        <Button Command="{Binding RefreshCommitsCommand}" Background="Transparent" BorderThickness="0" Padding="4,2">
                            <PathIcon Classes.spinning="{Binding IsRefreshing}" Data="{StaticResource RefreshIcon}" Width="14" Height="14" Foreground="{StaticResource TextMuted}">
                                <PathIcon.RenderTransform>
                                    <RotateTransform/>
                                </PathIcon.RenderTransform>
                            </PathIcon>
                        </Button>
                        <Button Background="Transparent" BorderThickness="0" Padding="4,2">
                            <PathIcon Data="{StaticResource EyeIcon}" Width="14" Height="14" Foreground="{StaticResource TextMuted}"/>
                            <Button.Flyout>
                                <Flyout Placement="BottomEdgeAlignedRight">
                                    <StackPanel Spacing="5" Margin="5">
                                        <TextBlock Text="Show" Foreground="{StaticResource TextMuted}" FontWeight="Bold" Margin="0,0,0,2"/>
                                        <CheckBox Content="Compact References View" IsChecked="{Binding #Root.((vm:CommitTimelineViewModel)DataContext).CompactReferencesView, Mode=TwoWay}" MinHeight="24"/>
                                        <CheckBox Content="Tag Names" IsChecked="{Binding #Root.((vm:CommitTimelineViewModel)DataContext).TagNames, Mode=TwoWay}" MinHeight="24"/>
                                        <CheckBox Content="Long Edges" IsChecked="{Binding #Root.((vm:CommitTimelineViewModel)DataContext).LongEdges, Mode=TwoWay}" MinHeight="24"/>
                                        <CheckBox Content="Commit Timestamp" IsChecked="{Binding #Root.((vm:CommitTimelineViewModel)DataContext).CommitTimestamp, Mode=TwoWay}" MinHeight="24"/>
                                        <CheckBox Content="References on the Left" IsChecked="{Binding #Root.((vm:CommitTimelineViewModel)DataContext).ReferencesOnTheLeft, Mode=TwoWay}" MinHeight="24"/>
                                        
                                        <TextBlock Text="Columns" Foreground="{StaticResource TextMuted}" FontWeight="Bold" Margin="0,5,0,2"/>
                                        <CheckBox Content="Author" IsChecked="True" IsEnabled="False" MinHeight="24"/>
                                        <CheckBox Content="Date" IsChecked="True" IsEnabled="False" MinHeight="24"/>
                                        <CheckBox Content="Hash" IsChecked="True" IsEnabled="False" MinHeight="24"/>

                                        <Separator Margin="0,5"/>
                                        
                                        <TextBlock Text="Highlight" Foreground="{StaticResource TextMuted}" FontWeight="Bold" Margin="0,0,0,2"/>
                                        <CheckBox Content="My Commits" IsChecked="{Binding #Root.((vm:CommitTimelineViewModel)DataContext).HighlightMyCommits, Mode=TwoWay}" MinHeight="24"/>
                                        <CheckBox Content="Merge Commits" IsChecked="{Binding #Root.((vm:CommitTimelineViewModel)DataContext).HighlightMergeCommits, Mode=TwoWay}" MinHeight="24"/>
                                        <CheckBox Content="Current Branch" IsChecked="{Binding #Root.((vm:CommitTimelineViewModel)DataContext).HighlightCurrentBranch, Mode=TwoWay}" MinHeight="24"/>
                                        <CheckBox Content="Not Cherry-Picked Commits" IsChecked="{Binding #Root.((vm:CommitTimelineViewModel)DataContext).HighlightNotCherryPickedCommits, Mode=TwoWay}" MinHeight="24"/>
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <ListBox x:Name="CommitsListBox" Grid.Row="1" ItemsSource="{Binding Commits}" SelectedItem="{Binding SelectedCommit, Mode=TwoWay}" Background="Transparent" BorderThickness="0">
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="MinHeight" Value="24"/>
                    </Style>
                </ListBox.Styles>
                
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>

                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:CommitRowViewModel">
                        <Grid ColumnDefinitions="100, *, 120, 140" Background="Transparent" MinHeight="24">
                            <Grid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Copy commit hash" Command="{Binding #CommitsListBox.((vm:CommitTimelineViewModel)DataContext).CopyCommitHashCommand}" CommandParameter="{Binding Commit.Sha}" />
                                    <Separator />
                                    <MenuItem Header="Cherry-pick commit" Command="{Binding #CommitsListBox.((vm:CommitTimelineViewModel)DataContext).CherryPickCommitCommand}" CommandParameter="{Binding Commit.Sha}" />
                                    <Separator />
                                    <MenuItem Header="Checkout revision" Command="{Binding #CommitsListBox.((vm:CommitTimelineViewModel)DataContext).CheckoutRevisionCommand}" CommandParameter="{Binding Commit.Sha}" />
                                    <MenuItem Header="Reset current branch to here">
                                        <MenuItem Header="Soft - Keep all changes staged" Command="{Binding #CommitsListBox.((vm:CommitTimelineViewModel)DataContext).ResetCommitSoftCommand}" CommandParameter="{Binding Commit.Sha}" />
                                        <MenuItem Header="Mixed - Keep all changes unstaged" Command="{Binding #CommitsListBox.((vm:CommitTimelineViewModel)DataContext).ResetCommitMixedCommand}" CommandParameter="{Binding Commit.Sha}" />
                                        <MenuItem Header="Hard - Discard all changes" Command="{Binding #CommitsListBox.((vm:CommitTimelineViewModel)DataContext).ResetCommitHardCommand}" CommandParameter="{Binding Commit.Sha}" Foreground="{StaticResource BranchRed}" />
                                    </MenuItem>
                                    <MenuItem Header="Revert commit" Command="{Binding #CommitsListBox.((vm:CommitTimelineViewModel)DataContext).RevertCommitCommand}" CommandParameter="{Binding Commit.Sha}" />
                                    <Separator />
                                    <MenuItem Header="Edit commit message" Command="{Binding #CommitsListBox.((vm:CommitTimelineViewModel)DataContext).AmendCommitCommand}" CommandParameter="{Binding Commit.Sha}" />
                                    <Separator />
                                    <MenuItem Header="Go to parent commit" Command="{Binding #CommitsListBox.((vm:CommitTimelineViewModel)DataContext).GoToParentCommitCommand}" CommandParameter="{Binding Commit.Sha}" />
                                    <MenuItem Header="Go to child commit" Command="{Binding #CommitsListBox.((vm:CommitTimelineViewModel)DataContext).GoToChildCommitCommand}" CommandParameter="{Binding Commit.Sha}" />
                                </ContextMenu>
                            </Grid.ContextMenu>

                            <!-- Graph Canvas -->
                            <controls:CommitGraphCanvas Grid.Column="0" Node="{Binding Node}" Width="100" MinHeight="24" ClipToBounds="False" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

                            <!-- Commit Message -->
                            <Panel Grid.Column="1" VerticalAlignment="Center" Margin="5,0,15,0">
                                <TextBlock Text="{Binding Commit.MessageShort}" Foreground="{StaticResource TextPrimary}" FontWeight="Bold" FontSize="13" TextTrimming="CharacterEllipsis" IsVisible="{Binding IsHighlighted}"/>
                                <TextBlock Text="{Binding Commit.MessageShort}" Foreground="{StaticResource TextPrimary}" FontWeight="Normal" FontSize="13" TextTrimming="CharacterEllipsis" IsVisible="{Binding !IsHighlighted}"/>
                            </Panel>

                            <!-- Author -->
                            <TextBlock Grid.Column="2" Text="{Binding Commit.AuthorName}" Foreground="{StaticResource TextMuted}" FontSize="13" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Margin="5,0,5,0"/>

                            <!-- Date -->
                            <TextBlock Grid.Column="3" Text="{Binding Commit.CommitDate, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}" Foreground="{StaticResource TextMuted}" FontSize="13" VerticalAlignment="Center" Margin="5,0,15,0"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!-- Vertical Drag Handle 2 -->
        <GridSplitter Grid.Column="3" Width="4" Background="{StaticResource BorderSubtle}" ResizeDirection="Columns"/>

        <!-- RIGHT PANEL: Commit Details -->
        <Border Grid.Column="4" Background="{StaticResource BgSidebar}" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1,0,0,0">
            <Grid RowDefinitions="*, Auto">
                
                <!-- Modified Files List -->
                <Grid Grid.Row="0" RowDefinitions="Auto, *">
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="10,10,10,5">
                        <TextBlock Text="{Binding SelectedCommitFileCount, StringFormat='{}{0} files'}" VerticalAlignment="Center" Foreground="{StaticResource TextMuted}" FontSize="12" FontWeight="SemiBold"/>
                    </StackPanel>
                    
                    <TreeView Grid.Row="1" ItemsSource="{Binding SelectedCommitFiles}" Background="Transparent" BorderThickness="0">
                        <TreeView.ItemTemplate>
                            <TreeDataTemplate DataType="vm:FileGroupViewModel" ItemsSource="{Binding Files}">
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <TextBlock Text="{Binding GroupName}" FontSize="12" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold"/>
                                </StackPanel>
                            </TreeDataTemplate>
                        </TreeView.ItemTemplate>
                        <TreeView.DataTemplates>
                            <DataTemplate DataType="vm:FileItemViewModel">
                                <StackPanel Orientation="Horizontal" Spacing="5" Margin="20,0,0,0">
                                    <TextBlock Text="{Binding FileName, Converter={StaticResource FileExtensionToIconConverter}}" Foreground="{StaticResource BranchGreen}" FontSize="12" VerticalAlignment="Center" Width="18" TextAlignment="Center"/>
                                    <TextBlock Text="{Binding FileName}" FontSize="12" VerticalAlignment="Center" Foreground="{StaticResource TextPrimary}" />
                                </StackPanel>
                            </DataTemplate>
                        </TreeView.DataTemplates>
                    </TreeView>
                </Grid>

                <!-- Commit Info Card -->
                <Border Grid.Row="1" Background="{StaticResource PanelSurface}" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderSubtle}" Padding="15">
                    <StackPanel Spacing="10" IsVisible="{Binding SelectedCommit, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <!-- Commit Title -->
                        <TextBlock Text="{Binding SelectedCommit.Commit.MessageShort}" FontWeight="Bold" FontSize="14" Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap"/>
                        
                        <!-- Branches & Tags -->
                        <ItemsControl ItemsSource="{Binding SelectedCommitBranches}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type sys:String}">
                                    <Border Background="{StaticResource ButtonHover}" CornerRadius="3" Padding="4,2" Margin="0,0,5,5">
                                        <TextBlock Text="{Binding}" FontSize="10" Foreground="{StaticResource BranchCyan}"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Meta Info -->
                        <Grid ColumnDefinitions="Auto, *">
                            <StackPanel Grid.Column="0" Spacing="5">
                                <TextBlock Text="Author:" Foreground="{StaticResource TextMuted}" FontSize="12"/>
                                <TextBlock Text="Date:" Foreground="{StaticResource TextMuted}" FontSize="12"/>
                                <TextBlock Text="Hash:" Foreground="{StaticResource TextMuted}" FontSize="12"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="5" Margin="10,0,0,0">
                                <TextBlock Text="{Binding SelectedCommit.Commit.AuthorName}" Foreground="{StaticResource TextPrimary}" FontSize="12"/>
                                <TextBlock Text="{Binding SelectedCommit.Commit.CommitDate, StringFormat='{}{0:g}'}" Foreground="{StaticResource TextPrimary}" FontSize="12"/>
                                <TextBlock Text="{Binding SelectedCommit.Commit.ShortSha}" FontFamily="Consolas, monospace" Foreground="{StaticResource BranchCyan}" FontSize="12"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

    </Grid>
</UserControl>
