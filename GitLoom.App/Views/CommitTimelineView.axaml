<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GitLoom.App.ViewModels"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             xmlns:controls="clr-namespace:GitLoom.App.Controls"
             x:Class="GitLoom.App.Views.CommitTimelineView"
             x:DataType="vm:CommitTimelineViewModel">
    <UserControl.Styles>
        <Style Selector="TreeViewItem">
            <Setter Property="MinHeight" Value="24"/>
        </Style>
    </UserControl.Styles>
    
    <Grid ColumnDefinitions="250, 4, *, 4, 300">
        
        <!-- LEFT PANEL: Branches -->
        <Border Grid.Column="0" Background="{StaticResource BgSidebar}" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto, *">
                <Grid Grid.Row="0" Margin="10,10,10,5">
                    <TextBox Classes="searchBox" Watermark="Branch or tag" BorderThickness="1" BorderBrush="Transparent" Background="Transparent" FontSize="13" Padding="25,5,5,5" />
                    <PathIcon Data="{StaticResource SearchIcon}" Width="12" Height="12" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Left" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </Grid>
                
                <TreeView Grid.Row="1" ItemsSource="{Binding BranchBrowser.BranchCategories}" SelectedItem="{Binding SelectedBranchMenuItem, Mode=TwoWay}" Background="Transparent" BorderThickness="0">
                    <TreeView.ItemTemplate>
                        <TreeDataTemplate DataType="vm:BranchCategoryViewModel" ItemsSource="{Binding Branches}">
                            <TextBlock Text="{Binding CategoryName}" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                        </TreeDataTemplate>
                    </TreeView.ItemTemplate>
                    <TreeView.DataTemplates>
                        <DataTemplate DataType="vm:MenuItemViewModel">
                            <StackPanel Orientation="Horizontal" Spacing="5" Background="Transparent">
                                <TextBlock Text="✓" IsVisible="{Binding IsCurrentBranch}" Foreground="{StaticResource BranchCyan}" VerticalAlignment="Center" FontSize="12"/>
                                <TextBlock Text="{Binding Header}" FontSize="12" VerticalAlignment="Center" Foreground="{StaticResource TextPrimary}"/>
                            </StackPanel>
                        </DataTemplate>
                    </TreeView.DataTemplates>
                </TreeView>
            </Grid>
        </Border>

        <!-- Vertical Drag Handle 1 -->
        <GridSplitter Grid.Column="1" Width="4" Background="{StaticResource BorderSubtle}" ResizeDirection="Columns"/>

        <!-- CENTER PANEL: Timeline -->
        <Grid Grid.Column="2" RowDefinitions="Auto, *">
            <!-- TOOLBAR HEADER -->
            <Border Grid.Row="0" Background="{StaticResource PanelSurface}" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,0,1" Padding="10,5">
                <Grid ColumnDefinitions="Auto, Auto, Auto, Auto, Auto, Auto, *, Auto">
                    <!-- Search Box -->
                    <Grid Grid.Column="0" Margin="0,0,10,0" Width="200">
                        <TextBox Classes="searchBox" Watermark="Text or hash" BorderThickness="1" BorderBrush="Transparent" Background="Transparent" FontSize="13" Padding="25,5,5,5" Foreground="{StaticResource TextPrimary}" />
                        <PathIcon Data="{StaticResource SearchIcon}" Width="12" Height="12" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Left" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,5,0" Spacing="4">
                            <TextBlock Text=".*" FontSize="10" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" FontWeight="Bold"/>
                            <TextBlock Text="Cc" FontSize="10" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>

                    <Button Grid.Column="1" Background="Transparent" BorderThickness="0" Padding="8,4" Foreground="{StaticResource TextMuted}">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <TextBlock Text="Branch" />
                            <PathIcon Data="{StaticResource ChevronRightIcon}" Width="8" Height="8" RenderTransform="rotate(90deg)" />
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="2" Background="Transparent" BorderThickness="0" Padding="8,4" Foreground="{StaticResource TextMuted}">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <TextBlock Text="User" />
                            <PathIcon Data="{StaticResource ChevronRightIcon}" Width="8" Height="8" RenderTransform="rotate(90deg)" />
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="3" Background="Transparent" BorderThickness="0" Padding="8,4" Foreground="{StaticResource TextMuted}">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <TextBlock Text="Date" />
                            <PathIcon Data="{StaticResource ChevronRightIcon}" Width="8" Height="8" RenderTransform="rotate(90deg)" />
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="4" Background="Transparent" BorderThickness="0" Padding="8,4" Foreground="{StaticResource TextMuted}">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <TextBlock Text="Paths" />
                            <PathIcon Data="{StaticResource ChevronRightIcon}" Width="8" Height="8" RenderTransform="rotate(90deg)" />
                        </StackPanel>
                    </Button>

                    <!-- Action Icons -->
                    <StackPanel Grid.Column="7" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center" Margin="0,0,5,0">
                        <Button Content="▶" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextMuted}" Padding="4,2"/>
                        <Button Content="↻" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextMuted}" Padding="4,2"/>
                        <Button Content="👓" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextMuted}" Padding="4,2"/>
                        <Button Content="👁" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextMuted}" Padding="4,2"/>
                        <Button Content="🔍" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextMuted}" Padding="4,2"/>
                    </StackPanel>
                </Grid>
            </Border>

            <ListBox Grid.Row="1" ItemsSource="{Binding Commits}" SelectedItem="{Binding SelectedCommit, Mode=TwoWay}" Background="Transparent" BorderThickness="0">
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="MinHeight" Value="24"/>
                    </Style>
                </ListBox.Styles>
                
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>

                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:CommitRowViewModel">
                        <Grid ColumnDefinitions="100, *, 120, 140" Background="Transparent" MinHeight="24">
                            <!-- Graph Canvas -->
                            <controls:CommitGraphCanvas Grid.Column="0" Node="{Binding Node}" Width="100" MinHeight="24" ClipToBounds="False" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

                            <!-- Commit Message -->
                            <TextBlock Grid.Column="1" Text="{Binding Commit.MessageShort}" Foreground="{StaticResource TextPrimary}" FontWeight="Normal" FontSize="13" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Margin="5,0,15,0"/>

                            <!-- Author -->
                            <TextBlock Grid.Column="2" Text="{Binding Commit.AuthorName}" Foreground="{StaticResource TextMuted}" FontSize="13" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Margin="5,0,5,0"/>

                            <!-- Date -->
                            <TextBlock Grid.Column="3" Text="{Binding Commit.CommitDate, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}" Foreground="{StaticResource TextMuted}" FontSize="13" VerticalAlignment="Center" Margin="5,0,15,0"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!-- Vertical Drag Handle 2 -->
        <GridSplitter Grid.Column="3" Width="4" Background="{StaticResource BorderSubtle}" ResizeDirection="Columns"/>

        <!-- RIGHT PANEL: Commit Details -->
        <Border Grid.Column="4" Background="{StaticResource BgSidebar}" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1,0,0,0">
            <Grid RowDefinitions="*, Auto">
                
                <!-- Modified Files List -->
                <Grid Grid.Row="0" RowDefinitions="Auto, *">
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="10,10,10,5">
                        <TextBlock Text="{Binding SelectedCommitFileCount, StringFormat='{}{0} files'}" VerticalAlignment="Center" Foreground="{StaticResource TextMuted}" FontSize="12" FontWeight="SemiBold"/>
                    </StackPanel>
                    
                    <TreeView Grid.Row="1" ItemsSource="{Binding SelectedCommitFiles}" Background="Transparent" BorderThickness="0">
                        <TreeView.ItemTemplate>
                            <TreeDataTemplate DataType="vm:FileGroupViewModel" ItemsSource="{Binding Files}">
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <TextBlock Text="{Binding GroupName}" FontSize="12" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold"/>
                                </StackPanel>
                            </TreeDataTemplate>
                        </TreeView.ItemTemplate>
                        <TreeView.DataTemplates>
                            <DataTemplate DataType="{x:Type sys:String}">
                                <StackPanel Orientation="Horizontal" Spacing="5" Margin="20,0,0,0">
                                    <TextBlock Text="{Binding}" FontSize="12" Foreground="{StaticResource TextPrimary}" />
                                </StackPanel>
                            </DataTemplate>
                        </TreeView.DataTemplates>
                    </TreeView>
                </Grid>

                <!-- Commit Info Card -->
                <Border Grid.Row="1" Background="{StaticResource PanelSurface}" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderSubtle}" Padding="15">
                    <StackPanel Spacing="10" IsVisible="{Binding SelectedCommit, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <!-- Commit Title -->
                        <TextBlock Text="{Binding SelectedCommit.Commit.MessageShort}" FontWeight="Bold" FontSize="14" Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap"/>
                        
                        <!-- Branches & Tags -->
                        <ItemsControl ItemsSource="{Binding SelectedCommitBranches}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type sys:String}">
                                    <Border Background="{StaticResource ButtonHover}" CornerRadius="3" Padding="4,2" Margin="0,0,5,5">
                                        <TextBlock Text="{Binding}" FontSize="10" Foreground="{StaticResource BranchCyan}"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Meta Info -->
                        <Grid ColumnDefinitions="Auto, *">
                            <StackPanel Grid.Column="0" Spacing="5">
                                <TextBlock Text="Author:" Foreground="{StaticResource TextMuted}" FontSize="12"/>
                                <TextBlock Text="Date:" Foreground="{StaticResource TextMuted}" FontSize="12"/>
                                <TextBlock Text="Hash:" Foreground="{StaticResource TextMuted}" FontSize="12"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="5" Margin="10,0,0,0">
                                <TextBlock Text="{Binding SelectedCommit.Commit.AuthorName}" Foreground="{StaticResource TextPrimary}" FontSize="12"/>
                                <TextBlock Text="{Binding SelectedCommit.Commit.CommitDate, StringFormat='{}{0:g}'}" Foreground="{StaticResource TextPrimary}" FontSize="12"/>
                                <TextBlock Text="{Binding SelectedCommit.Commit.ShortSha}" FontFamily="Consolas, monospace" Foreground="{StaticResource BranchCyan}" FontSize="12"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

    </Grid>
</UserControl>
