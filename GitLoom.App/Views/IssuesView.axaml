<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GitLoom.App.ViewModels"
             x:Class="GitLoom.App.Views.IssuesView"
             x:DataType="vm:IssuesViewModel">
    <Border Padding="20">
        <Grid RowDefinitions="Auto,Auto,*,Auto,Auto">

            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="0,0,0,15">
                <PathIcon Data="{StaticResource IssueIcon}" Width="18" Height="18" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                <TextBlock Text="Issues" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                <TextBlock Text="Triage, open, and close issues without leaving GitLoom" FontSize="12" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" Margin="6,3,0,0"/>
            </StackPanel>

            <!-- Toolbar (only when the host is supported) -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="10" Margin="0,0,0,12"
                        IsVisible="{Binding IsSupported}">
                <Button Content="New issue" Classes="Primary" Padding="12,6"
                        Command="{Binding BeginCreateCommand}"
                        ToolTip.Tip="Open a new issue on the origin host"/>

                <!-- Open / Closed filter -->
                <Border Classes="SegmentTrack" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Open" Classes="Segment" Classes.Active="{Binding !ShowClosed}"
                                Command="{Binding ShowOpenCommand}"/>
                        <Button Content="Closed" Classes="Segment" Classes.Active="{Binding ShowClosed}"
                                Command="{Binding ShowClosedIssuesCommand}"/>
                    </StackPanel>
                </Border>

                <Button Classes="IconButton" Command="{Binding RefreshListCommand}" ToolTip.Tip="Refresh"
                        Background="{DynamicResource SurfaceHoverGhost}">
                    <PathIcon Data="{StaticResource RefreshIcon}" Width="14" Height="14" Foreground="{DynamicResource TextMuted}"/>
                </Button>
            </StackPanel>

            <!-- Body -->
            <Grid Grid.Row="2">

                <!-- Unsupported / no-token affordance -->
                <StackPanel Spacing="12" VerticalAlignment="Top" IsVisible="{Binding !IsSupported}">
                    <Border Classes="Card" Background="{DynamicResource SurfaceCard}" Padding="18" CornerRadius="8">
                        <StackPanel Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="{StaticResource CloudIcon}" Width="16" Height="16" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                                <TextBlock Text="Not connected" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{Binding UnsupportedHint}" FontSize="12" Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Supported: create form + list -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" IsVisible="{Binding IsSupported}">
                    <StackPanel Spacing="10">

                        <!-- New-issue form -->
                        <Border Classes="Card" Background="{DynamicResource SurfaceCard}" Padding="14" CornerRadius="8"
                                IsVisible="{Binding IsCreating}">
                            <StackPanel Spacing="10">
                                <TextBlock Text="New issue" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                                <TextBox Text="{Binding NewTitle}" Watermark="Title" FontSize="13"/>
                                <TextBox Text="{Binding NewBody}" Watermark="Description (optional)" FontSize="12"
                                         AcceptsReturn="True" TextWrapping="Wrap" MinHeight="80"/>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBox Text="{Binding NewLabels}" Watermark="labels (comma-separated)" MinWidth="200" FontSize="12"/>
                                    <TextBox Text="{Binding NewAssignees}" Watermark="assignees (comma-separated)" MinWidth="200" FontSize="12"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                    <Button Content="Create" Classes="Success" Padding="14,6" Command="{Binding SubmitCreateCommand}"/>
                                    <Button Content="Cancel" Classes="Secondary" Padding="14,6" Command="{Binding CancelCreateCommand}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Issue list -->
                        <ItemsControl ItemsSource="{Binding Issues}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:IssueRowViewModel">
                                    <Border Classes="Card" Background="{DynamicResource SurfaceCard}" Padding="14" Margin="0,0,0,2" CornerRadius="8">
                                        <StackPanel Spacing="8">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <StackPanel Grid.Column="0" Spacing="6" VerticalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock Text="{Binding NumberText}" Classes="Mono" FontSize="12" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                                    </StackPanel>

                                                    <!-- Label chips (host-colored, auto-contrast text) -->
                                                    <ItemsControl ItemsSource="{Binding Labels}" IsVisible="{Binding HasLabels}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <WrapPanel Orientation="Horizontal"/>
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate DataType="vm:IssueLabelChipViewModel">
                                                                <Border Background="{Binding Background}" CornerRadius="999" Padding="8,2" Margin="0,0,4,4">
                                                                    <TextBlock Text="{Binding Name}" Foreground="{Binding Foreground}" FontSize="10" FontWeight="SemiBold"/>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>

                                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                                        <TextBlock Text="{Binding AuthorText}" FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                                                        <TextBlock Text="{Binding AssigneesText}" FontSize="11" Foreground="{DynamicResource AccentBrush}" IsVisible="{Binding HasAssignees}"/>
                                                        <TextBlock Text="{Binding CommentCountText}" FontSize="11" Foreground="{DynamicResource TextMuted}" IsVisible="{Binding HasComments}"/>
                                                        <TextBlock Text="{Binding UpdatedText}" FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                                                    </StackPanel>
                                                </StackPanel>

                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                    <Button Content="Comment" Classes="Primary" Padding="12,4" Command="{Binding BeginCommentCommand}"/>
                                                    <Button Content="{Binding StateActionText}" Classes="Secondary" Padding="12,4" Command="{Binding ToggleStateCommand}"/>
                                                    <Button Classes="IconButton" Command="{Binding OpenInBrowserCommand}"
                                                            IsVisible="{Binding HasUrl}" ToolTip.Tip="Open in browser"
                                                            Background="{DynamicResource SurfaceHoverGhost}">
                                                        <PathIcon Data="{StaticResource EyeIcon}" Width="14" Height="14" Foreground="{DynamicResource TextMuted}"/>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>

                                            <!-- Inline comment box -->
                                            <StackPanel Spacing="6" IsVisible="{Binding IsCommenting}">
                                                <TextBox Text="{Binding CommentDraft}" Watermark="Leave a comment" FontSize="12"
                                                         AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60"/>
                                                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                                    <Button Content="Comment" Classes="Success" Padding="12,4" Command="{Binding SubmitCommentCommand}"/>
                                                    <Button Content="Cancel" Classes="Secondary" Padding="12,4" Command="{Binding CancelCommentCommand}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="No issues match this filter. Open one with “New issue” to get started."
                                   Foreground="{DynamicResource TextMuted}" FontSize="12"
                                   IsVisible="{Binding IsEmpty}" Margin="4,8" TextWrapping="Wrap"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Error -->
            <TextBlock Grid.Row="3" Text="{Binding ErrorMessage}" Foreground="{DynamicResource DangerBrush}"
                       TextWrapping="Wrap" Margin="0,10,0,0" FontSize="12"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

            <!-- Footer -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                <Button Content="Close" Classes="Secondary" Padding="15,6" Command="{Binding CloseCommand}"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
