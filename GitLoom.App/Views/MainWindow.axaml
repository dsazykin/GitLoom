<Window xmlns="https://github.com/avaloniaui"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:vm="using:GitLoom.App.ViewModels"
            xmlns:views="using:GitLoom.App.Views"
            xmlns:models="using:GitLoom.Core.Models"
            xmlns:converters="using:GitLoom.App.Converters"
            x:Class="GitLoom.App.Views.MainWindow"
            x:DataType="vm:MainWindowViewModel"
            x:Name="Root"
            Icon="/Assets/avalonia-logo.ico"
            Title="GitLoom"
            MinWidth="800" MinHeight="600"
            WindowStartupLocation="CenterScreen"
            Background="{DynamicResource SurfaceWindow}"
            ExtendClientAreaToDecorationsHint="True"
            ExtendClientAreaChromeHints="NoChrome"
            ExtendClientAreaTitleBarHeightHint="-1">
    
    <!-- Global keyboard shortcuts (T-18) are built at runtime from the ShortcutMap in code-behind.
         Escape stays declarative so the palette always closes regardless of the bindings. -->
    <Window.KeyBindings>
        <KeyBinding Gesture="Escape" Command="{Binding CloseCommandPaletteCommand}" />
    </Window.KeyBindings>

    <Window.Styles>
        <!-- Scoped to MenuFlyoutPresenter.dynamicMenu (see FlyoutPresenterClasses below) so this
             MenuItemViewModel-shaped binding can never shadow the static File/branch-pill menus
             that live inside their own MenuFlyoutPresenter popups (#62). -->
        <Style Selector="MenuFlyoutPresenter.dynamicMenu MenuItem" x:DataType="vm:MenuItemViewModel">
            <Setter Property="Header" Value="{Binding Header}"/>
            <!-- Long generated headers (e.g. "Rebase <long-branch> onto <long-branch>") wrap instead
                 of getting cut off (#80); MaxWidth below caps overall growth so wrapping actually
                 triggers rather than the item just stretching wider. -->
            <Setter Property="HeaderTemplate">
                <DataTemplate>
                    <TextBlock Text="{Binding}" TextWrapping="Wrap"/>
                </DataTemplate>
            </Setter>
            <Setter Property="MaxWidth" Value="420"/>
            <Setter Property="Command" Value="{Binding Command}"/>
            <Setter Property="CommandParameter" Value="{Binding CommandParameter}"/>
            <Setter Property="IsEnabled" Value="{Binding IsEnabled}"/>
            <Setter Property="ItemsSource" Value="{Binding SubItems}"/>
        </Style>
        
        <!-- Section rail (control-center integration): 44px icons-only collapsed, 208px expanded.
             The width eases between the two states so expand/collapse glides (200ms, ease-out) —
             the one place animating a layout dimension is the point. -->
        <Style Selector="Border.sectionRail">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Width" Duration="0:0:0.20" Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.sectionRail.expanded"><Setter Property="Width" Value="208"/></Style>
        <Style Selector="Button.railItem">
            <Setter Property="Background" Value="{DynamicResource SurfaceHoverGhost}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Height" Value="32"/>
            <!-- Selection tint glides in rather than snapping (precision, not decoration). -->
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.14" Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>
        <!-- Items highlight only on hover; disabled items dim instead of filling. -->
        <Style Selector="Button.railItem:disabled">
            <Setter Property="Opacity" Value="0.45"/>
        </Style>
        <Style Selector="Button.railItem:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <!-- Hover is an explicit token so the transition never lerps through the Fluent
             default (the white flash); the active tint keeps itself under the cursor. -->
        <Style Selector="Button.railItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SurfaceHover}"/>
        </Style>
        <!-- The active section carries the shipped selection tint. -->
        <Style Selector="Button.railItem.active">
            <Setter Property="Background" Value="{DynamicResource AccentSelection}"/>
        </Style>
        <Style Selector="Button.railItem.active:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentSelection}"/>
        </Style>
        <!-- The agent micro-badge: colour comes from the ONE AgentStatusBrushConverter (bound on
             the element); the state change cross-fades so a status flip reads as a transition, not
             a jump. Shape (the glyph) is the primary channel, colour the second (E1/E2). -->
        <Style Selector="PathIcon.railBadge">
            <Setter Property="Width" Value="10"/>
            <Setter Property="Height" Value="10"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Foreground" Duration="0:0:0.18" Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>
        <!-- The kill switch at the rail's foot: red at rest (feedback 2026-07-11), solid Danger
             fill on hover and while engaged. -->
        <Style Selector="Button.railKill PathIcon"><Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/></Style>
        <Style Selector="Button.railKill TextBlock"><Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/></Style>
        <Style Selector="Button.railKill:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource DangerBrush}"/>
        </Style>
        <Style Selector="Button.railKill:pointerover PathIcon"><Setter Property="Foreground" Value="{DynamicResource OnAccent}"/></Style>
        <Style Selector="Button.railKill:pointerover TextBlock"><Setter Property="Foreground" Value="{DynamicResource OnAccent}"/></Style>
        <Style Selector="Button.railKill.frozen">
            <Setter Property="Background" Value="{DynamicResource DangerBrush}"/>
        </Style>
        <Style Selector="Button.railKill.frozen PathIcon"><Setter Property="Foreground" Value="{DynamicResource OnAccent}"/></Style>
        <Style Selector="Button.railKill.frozen TextBlock"><Setter Property="Foreground" Value="{DynamicResource OnAccent}"/></Style>

        <Style Selector="TextBox.searchBox:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="TextBox.searchBox:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        
        <!-- Dim highlight for buttons in dropdown -->
        <Style Selector="Button.BranchItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SurfaceHover}" />
        </Style>
        <Style Selector="ToggleButton.BranchCategory:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SurfaceHover}" />
        </Style>
        <Style Selector="ToggleButton.BranchCategory:checked /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="ToggleButton.BranchCategory:checked:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SurfaceHover}" />
        </Style>


        <!-- (Chevron data-swap style is defined globally in App.axaml; the repo-tree styles
             moved to RepoPickerWindow with the tree itself.) -->

    </Window.Styles>

    <!-- Repository/WorkspaceCategory tree templates moved to RepoPickerWindow (2026-07-11). -->

    <Window.DataTemplates>
        <!-- Custom TreeDataTemplate for deeply nested menus -->
        <TreeDataTemplate DataType="vm:MenuItemViewModel" ItemsSource="{Binding SubItems}">
            <StackPanel Orientation="Horizontal" Spacing="5">
                <PathIcon Data="{StaticResource CheckmarkIcon}" IsVisible="{Binding IsCurrentBranch}" Foreground="{DynamicResource AccentBrush}" Width="10" Height="10" />
                <TextBlock Text="{Binding Header}" />
            </StackPanel>
        </TreeDataTemplate>
    </Window.DataTemplates>

    <!-- Issue #71: recursive branch-tree row template for the sidebar Local/Remote/Recent branch
         lists. A folder node (IsFolder) renders as a collapsible header (chevron + segment name)
         whose Children re-use this same keyed template (self-reference is fine — lazily applied);
         a leaf node renders the original click-to-open-actions branch row, unchanged except its
         label now binds to DisplayHeader (the last path segment once nested) instead of Header. -->
    <Window.Resources>
        <DataTemplate x:Key="BranchTreeItemTemplate" DataType="vm:MenuItemViewModel">
            <StackPanel>
                <ToggleButton Classes="BranchCategory" IsChecked="{Binding IsExpanded, Mode=TwoWay}" IsVisible="{Binding IsFolder}"
                              HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="Transparent" BorderThickness="0" Padding="10,4">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <PathIcon Classes="Chevron" Classes.expanded="{Binding IsExpanded}" Width="9" Height="9" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding Header}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" />
                    </StackPanel>
                </ToggleButton>

                <ItemsControl ItemsSource="{Binding Children}" ItemTemplate="{StaticResource BranchTreeItemTemplate}"
                              IsVisible="{Binding IsFolder}" Margin="15,0,0,0" />

                <Button Classes="BranchItem" IsVisible="{Binding !IsFolder}" Background="{DynamicResource SurfaceHoverGhost}" BorderThickness="0"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="25,5,10,5" CornerRadius="4">
                    <Button.Flyout>
                        <MenuFlyout Placement="RightEdgeAlignedTop" ItemsSource="{Binding SubItems}" FlyoutPresenterClasses="dynamicMenu" />
                    </Button.Flyout>
                    <Grid ColumnDefinitions="20,*">
                        <PathIcon Grid.Column="0" Data="{StaticResource CheckmarkIcon}" IsVisible="{Binding IsCurrentBranch}" Foreground="{DynamicResource AccentBrush}" Width="12" Height="12" Margin="0,0,4,0"/>
                        <TextBlock Grid.Column="1" Text="{Binding DisplayHeader}" VerticalAlignment="Center" FontSize="13"/>
                    </Grid>
                </Button>
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <!-- OffScreenMargin keeps client-area content off the screen edges when maximized -->
    <Grid Margin="{Binding #Root.OffScreenMargin}">
        <Grid RowDefinitions="Auto, *">
        <!-- UNIFIED CUSTOM TITLE BAR (client-area chrome; whole bar drags the window) -->
        <Border Grid.Row="0" Background="{DynamicResource SurfacePanel}" BorderBrush="{DynamicResource BorderHairline}" BorderThickness="0,0,0,1" Padding="12,0,8,0" MinHeight="44"
                PointerPressed="TitleBar_PointerPressed" DoubleTapped="TitleBar_DoubleTapped">
            <Grid ColumnDefinitions="Auto, *, Auto, Auto">

                <!-- Left Side: Hamburger, Menu, Repo Name, Branch Dropdown -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <!-- Hamburger Button -->
                    <Button ToolTip.Tip="Repositories" Classes="IconButton" Command="{Binding OpenRepoPickerCommand}"
                            VerticalAlignment="Center">
                        <PathIcon Data="{StaticResource MenuIcon}" Width="18" Height="18" Foreground="{DynamicResource TextPrimary}"/>
                    </Button>

                    <Menu Background="Transparent" VerticalAlignment="Center">
                        <MenuItem Header="{ReflectionBinding CurrentWorkspace.RepositoryName, FallbackValue='File', TargetNullValue='File'}" Foreground="{DynamicResource TextPrimary}">
                            <MenuItem Header="Close Repository" Command="{Binding CloseRepositoryCommand}" IsVisible="{Binding CurrentWorkspace, Converter={x:Static ObjectConverters.IsNotNull}}" />
                            <MenuItem Header="Theme">
                                <MenuItem Header="Midnight Loom" Command="{Binding SetThemeCommand}" CommandParameter="MidnightLoom" />
                                <MenuItem Header="Daylight Loom" Command="{Binding SetThemeCommand}" CommandParameter="DaylightLoom" />
                                <MenuItem Header="Command Deck" Command="{Binding SetThemeCommand}" CommandParameter="CommandDeck" />
                                <MenuItem Header="Atelier" Command="{Binding SetThemeCommand}" CommandParameter="Atelier" />
                                <MenuItem Header="Loom Aurora" Command="{Binding SetThemeCommand}" CommandParameter="LoomAurora" />
                            </MenuItem>
                            <MenuItem Header="Layout">
                                <MenuItem Header="Flight Deck" Command="{Binding SetLayoutCommand}" CommandParameter="FlightDeck" />
                                <MenuItem Header="Conversation Deck" Command="{Binding SetLayoutCommand}" CommandParameter="ConversationDeck" />
                            </MenuItem>
                            <MenuItem Header="Agent prompting">
                                <MenuItem Header="Direct to agents" Command="{Binding SetAgentPromptingCommand}" CommandParameter="Direct" />
                                <MenuItem Header="Through the Coordinator" Command="{Binding SetAgentPromptingCommand}" CommandParameter="Coordinator" />
                            </MenuItem>
                            <MenuItem Header="Keyboard Shortcuts…" Command="{Binding OpenShortcutSettingsCommand}" />
                            <MenuItem Header="Settings…" Command="{Binding OpenSettingsCommand}" />
                            <MenuItem Header="Window &amp; Exit">
                                <MenuItem Header="Close button hides to tray" ToggleType="CheckBox" IsChecked="{Binding CloseToTray, Mode=TwoWay}" />
                                <MenuItem Header="Stop GitLoom OS on exit" ToggleType="CheckBox" IsChecked="{Binding StopVmOnExit, Mode=TwoWay}" />
                            </MenuItem>
                            <Separator />
                            <!-- FULL exit: bypasses close-to-tray and stops the VM if configured. -->
                            <MenuItem Header="Exit" Command="{Binding ExitApplicationCommand}" />
                        </MenuItem>
                    </Menu>

                    <!-- Branch Dropdown (Visible only when workspace active) -->
                    <StackPanel Orientation="Horizontal" Spacing="10" 
                                DataContext="{Binding CurrentWorkspace}" 
                                x:DataType="vm:RepoDashboardViewModel"
                                IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).CurrentWorkspace, Converter={x:Static ObjectConverters.IsNotNull}}">

                        <Button Classes="Pill" Background="{DynamicResource SurfaceCard}" Foreground="{DynamicResource TextPrimary}"
                                BorderBrush="{DynamicResource BorderHairline}" BorderThickness="1" Padding="12,4" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="{Binding BranchBrowser.CurrentBranchName}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                                <PathIcon Data="{StaticResource ChevronDownIcon}" Width="10" Height="10" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button.Flyout>
                                <!-- Branch ops only (#67) — Fetch/Remotes/Collaborate/Tools moved to their own sibling menus below. -->
                                <Flyout Placement="BottomEdgeAlignedLeft">
                                    <StackPanel>
                                        <Grid ColumnDefinitions="Auto,*,Auto" Margin="10,10,10,5">
                                            <PathIcon Grid.Column="0" Data="{StaticResource SearchIcon}" Width="12" Height="12" Foreground="{DynamicResource TextMuted}" Margin="0,0,5,0"/>
                                            <TextBox Classes="searchBox" Grid.Column="1" Watermark="Search for branches and actions" BorderThickness="1" BorderBrush="Transparent" Background="Transparent" FontSize="13" Padding="5"/>
                                            <Button Grid.Column="2" Content="+" Command="{Binding BranchBrowser.OpenCreateBranchDialogCommand}" ToolTip.Tip="New Branch..." Background="{DynamicResource SurfaceHoverGhost}" BorderThickness="0" Foreground="{DynamicResource TextMuted}"/>
                                        </Grid>
                                        <!-- #67: branch ops only — Fetch/Sync/Remotes/Tools live in the sibling
                                             Sync and Tools pills; PRs/Issues/Notifications/Releases live in the
                                             section rail (single home). -->
                                        <Separator Background="{DynamicResource BorderHairline}" Margin="0,5"/>

                                        <ScrollViewer Height="230" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                                            <ItemsControl ItemsSource="{Binding BranchBrowser.BranchCategories}" Background="Transparent" BorderThickness="0" Margin="0,0,0,10">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="vm:BranchCategoryViewModel">
                                                        <StackPanel>
                                                            <ToggleButton Classes="BranchCategory" IsChecked="{Binding IsExpanded, Mode=TwoWay}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="Transparent" BorderThickness="0" Padding="10,5">
                                                                <StackPanel Orientation="Horizontal" Spacing="5">
                                                                    <PathIcon Classes="Chevron" Classes.expanded="{Binding IsExpanded}" Width="10" Height="10" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" />
                                                                    <TextBlock Text="{Binding CategoryName}" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" />
                                                                </StackPanel>
                                                            </ToggleButton>
                                                            
                                                            <!-- Issue #71: Branches is now a grouped tree (folder nodes for shared
                                                                 slash-delimited prefixes + leaf branch rows); BranchTreeItemTemplate
                                                                 (declared in Window.Resources) renders both node kinds and recurses
                                                                 into folder Children. -->
                                                            <ItemsControl ItemsSource="{Binding Branches}" IsVisible="{Binding IsExpanded}"
                                                                          ItemTemplate="{StaticResource BranchTreeItemTemplate}" />
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                        <Button Content="New Branch from Current" Command="{Binding BranchBrowser.CreateBranchFromCurrentCommand}" Classes="Primary" Margin="5" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>

                        <!-- Remote / Sync menu (#67): fetch/pull + remotes/accounts/SSH — split out of the branch dropdown. -->
                        <Button Classes="Pill" Content="Sync" Background="{DynamicResource SurfaceCard}" Foreground="{DynamicResource TextPrimary}"
                                BorderBrush="{DynamicResource BorderHairline}" BorderThickness="1" Padding="12,4" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold">
                            <Button.Flyout>
                                <Flyout Placement="BottomEdgeAlignedLeft">
                                    <StackPanel Width="200">
                                        <Button Content="Fetch" Command="{Binding FetchCommand}" Background="{DynamicResource SurfaceHoverGhost}" BorderThickness="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="15,7" FontSize="13"/>
                                        <Button Content="Update Project" Command="{Binding UpdateProjectCommand}" Background="{DynamicResource SurfaceHoverGhost}" BorderThickness="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="15,7" FontSize="13"/>
                                        <Separator Background="{DynamicResource BorderHairline}" Margin="0,5"/>
                                        <Button Content="Manage Remotes…" Command="{Binding ManageRemotesCommand}" Background="{DynamicResource SurfaceHoverGhost}" BorderThickness="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="15,7" FontSize="13"/>
                                        <Button Content="Accounts…" Command="{Binding ManageAccountsCommand}" Background="{DynamicResource SurfaceHoverGhost}" BorderThickness="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="15,7" FontSize="13"/>
                                        <Button Content="SSH Keys…" Command="{Binding ManageSshKeysCommand}" Background="{DynamicResource SurfaceHoverGhost}" BorderThickness="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="15,7" FontSize="13"/>
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>

                        <!-- No Collaborate menu on phase2: PRs/Issues/Notifications/Releases are
                             section-rail tabs (single home) — main's #67 Collaborate pill dropped. -->

                        <!-- Repository / Tools menu (#67): everything else that used to crowd the branch dropdown. -->
                        <Button Classes="Pill" Content="Tools" Background="{DynamicResource SurfaceCard}" Foreground="{DynamicResource TextPrimary}"
                                BorderBrush="{DynamicResource BorderHairline}" BorderThickness="1" Padding="12,4" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold">
                            <Button.Flyout>
                                <Flyout Placement="BottomEdgeAlignedLeft">
                                    <StackPanel Width="200">
                                        <Button Content="Submodules…" Command="{Binding ManageSubmodulesCommand}" Background="{DynamicResource SurfaceHoverGhost}" BorderThickness="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="15,7" FontSize="13"/>
                                        <Button Content="Git LFS…" Command="{Binding ManageLfsCommand}" Background="{DynamicResource SurfaceHoverGhost}" BorderThickness="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="15,7" FontSize="13"/>
                                        <Button Content="Worktrees…" Command="{Binding ManageWorktreesCommand}" Background="{DynamicResource SurfaceHoverGhost}" BorderThickness="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="15,7" FontSize="13"/>
                                        <Separator Background="{DynamicResource BorderHairline}" Margin="0,5"/>
                                        <Button Content="Reflog…" Command="{Binding ViewReflogCommand}" Background="{DynamicResource SurfaceHoverGhost}" BorderThickness="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="15,7" FontSize="13"/>
                                        <Button Content="Operation History…" Command="{Binding ManageOperationHistoryCommand}" Background="{DynamicResource SurfaceHoverGhost}" BorderThickness="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="15,7" FontSize="13"/>
                                        <Separator Background="{DynamicResource BorderHairline}" Margin="0,5"/>
                                        <Button Content="Git Profiles…" Command="{Binding ManageProfilesCommand}" Background="{DynamicResource SurfaceHoverGhost}" BorderThickness="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="15,7" FontSize="13"/>
                                        <Button Content="AI Providers…" Command="{Binding ManageApiKeysCommand}" Background="{DynamicResource SurfaceHoverGhost}" BorderThickness="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="15,7" FontSize="13"/>
                                        <Button Content="Agent CLIs…" Command="{Binding ManageAgentClisCommand}" Background="{DynamicResource SurfaceHoverGhost}" BorderThickness="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="15,7" FontSize="13"/>
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>

                        <!-- Auto-fetch freshness (T-10): dims once the picture is >15 min stale. -->
                        <TextBlock Text="{Binding LastFetchedText}" FontSize="11" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextMuted}"
                                   Opacity="{Binding IsLastFetchStale, Converter={x:Static converters:BoolToOpacityConverter.Instance}}"
                                   IsVisible="{Binding LastFetchedText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Right Side: Push/Pull Buttons. (main's #78 pinned-icon strip is not rendered
                     on phase2 — the section rail owns navigation; the top bar is dropdowns only.) -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center" Margin="0,0,10,0">

                    <StackPanel Orientation="Horizontal" Spacing="10"
                                DataContext="{Binding CurrentWorkspace}"
                                x:DataType="vm:RepoDashboardViewModel"
                                IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).CurrentWorkspace, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <Button Classes="Primary" Padding="15,4" Command="{Binding PullCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <PathIcon Data="{StaticResource ArrowDownIcon}" Width="14" Height="14"/>
                            <TextBlock Text="Pull" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                    <!-- Push split-button: primary Push + a flyout of push options (T-10). -->
                    <StackPanel Orientation="Horizontal" Spacing="0">
                        <Button Classes="Primary" Padding="15,4" Command="{Binding PushCommand}" CornerRadius="6,0,0,6">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <PathIcon Data="{StaticResource ArrowUpIcon}" Width="14" Height="14"/>
                                <TextBlock Text="Push" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                        <Button Classes="Primary" Padding="7,4" CornerRadius="0,6,6,0" BorderThickness="0,1,1,1"
                                ToolTip.Tip="Push options">
                            <PathIcon Data="{StaticResource ChevronDownIcon}" Width="10" Height="10"/>
                            <Button.Flyout>
                                <Flyout Placement="BottomEdgeAlignedRight">
                                    <StackPanel Width="220">
                                        <Button Content="Push" Command="{Binding PushCommand}" Background="{DynamicResource SurfaceHoverGhost}" BorderThickness="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="15,8" FontSize="13"/>
                                        <Button Content="Force Push (with lease)" Command="{Binding PushForceWithLeaseCommand}" Background="{DynamicResource SurfaceHoverGhost}" BorderThickness="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="15,8" FontSize="13" Foreground="{DynamicResource DangerBrush}"/>
                                        <Button Content="Push &amp; Set Upstream" Command="{Binding PushSetUpstreamCommand}" Background="{DynamicResource SurfaceHoverGhost}" BorderThickness="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="15,8" FontSize="13"/>
                                        <Button Content="Push Tags" Command="{Binding PushTagsCommand}" Background="{DynamicResource SurfaceHoverGhost}" BorderThickness="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="15,8" FontSize="13"/>
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                    </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Window controls (custom chrome) -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Stretch">
                    <Button Classes="WindowButton" ToolTip.Tip="Minimize" Click="MinimizeButton_Click">
                        <PathIcon Data="{StaticResource WindowMinimizeIcon}" Width="11" Height="11" Foreground="{DynamicResource TextMuted}"/>
                    </Button>
                    <Button Classes="WindowButton" ToolTip.Tip="Maximize" Click="MaximizeButton_Click">
                        <PathIcon x:Name="MaximizeIcon" Data="{StaticResource WindowMaximizeIcon}" Width="11" Height="11" Foreground="{DynamicResource TextMuted}"/>
                    </Button>
                    <Button Classes="WindowButton Close" ToolTip.Tip="Close" Click="CloseButton_Click">
                        <PathIcon Data="{StaticResource DismissIcon}" Width="12" Height="12" Foreground="{DynamicResource TextMuted}"/>
                    </Button>
                </StackPanel>

            </Grid>
        </Border>

        <!-- MAIN LAYOUT: [section rail][section content]. The rail navigates sections
             (Repo viewer / Coordinator / Resources / host windows / agents); collapsed it
             shows icons + tooltips only. The Repo viewer content is today's workspace,
             untouched; the coordinator surface swaps in per section. -->
        <Grid Grid.Row="1" ColumnDefinitions="Auto,*">

            <!-- SECTION RAIL -->
            <Border Grid.Column="0" Classes="sectionRail" Classes.expanded="{Binding IsRailExpanded}"
                    Background="{DynamicResource SurfacePanel}" BorderBrush="{DynamicResource BorderHairline}"
                    BorderThickness="1" CornerRadius="12" Margin="8,8,0,8">
                <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="4,8">

                    <!-- top third: git / coordinator / resources / host windows -->
                    <StackPanel Grid.Row="0" Spacing="2">
                        <Button Classes="railItem" Command="{Binding ToggleRailCommand}" ToolTip.Tip="Expand or collapse this sidebar">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="{StaticResource MenuIcon}" Width="14" Height="14" Foreground="{DynamicResource TextMuted}"/>
                                <TextBlock Text="Sections" FontSize="12" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" IsVisible="{Binding IsRailExpanded}"/>
                            </StackPanel>
                        </Button>
                        <Button Classes="railItem" Classes.active="{Binding IsRepoSectionActive}" Command="{Binding ShowRepoSectionCommand}" ToolTip.Tip="Repo viewer — the git workspace">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="{StaticResource CommitIcon}" Width="14" Height="14" Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="Repo viewer" FontSize="12" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" IsVisible="{Binding IsRailExpanded}"/>
                            </StackPanel>
                        </Button>
                        <Button Classes="railItem" Classes.active="{Binding IsCoordinatorSectionActive}" Command="{Binding ShowCoordinatorSectionCommand}" ToolTip.Tip="Coordinator — plan approvals, chat, and the merge queue">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <Panel Grid.Column="0" Width="14" Height="14">
                                    <PathIcon Data="{StaticResource DiscussionIcon}" Width="14" Height="14" Foreground="{DynamicResource TextPrimary}"/>
                                    <Ellipse Width="7" Height="7" Fill="{DynamicResource WarningBrush}" HorizontalAlignment="Right" VerticalAlignment="Top"
                                             IsVisible="{Binding ControlCenter.HasAttention}"/>
                                </Panel>
                                <TextBlock Grid.Column="1" Text="Coordinator" FontSize="12" Margin="8,0,0,0" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" IsVisible="{Binding IsRailExpanded}"/>
                                <Border Grid.Column="2" Background="{DynamicResource WarningBrush}" CornerRadius="999" Padding="6,1" IsVisible="{Binding IsRailExpanded}">
                                    <TextBlock Text="{Binding ControlCenter.AttentionCount}" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource OnAccent}"/>
                                </Border>
                            </Grid>
                        </Button>
                        <Button Classes="railItem" Classes.active="{Binding IsResourcesSectionActive}" Command="{Binding ShowResourcesSectionCommand}" ToolTip.Tip="Resources — sandbox CPU, RAM, and token spend">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="{StaticResource ResourceMonitorIcon}" Width="14" Height="14" Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="Resources" FontSize="12" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" IsVisible="{Binding IsRailExpanded}"/>
                                <TextBlock Classes="Mono" Text="{Binding ControlCenter.SpendText}" FontSize="11" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" IsVisible="{Binding IsRailExpanded}"/>
                            </StackPanel>
                        </Button>
                        <Border Height="1" Background="{DynamicResource BorderHairline}" Margin="4,6"/>
                        <Button Classes="railItem" Classes.active="{Binding IsPullRequestsSectionActive}" Command="{Binding ShowHostSectionCommand}" CommandParameter="PullRequests" ToolTip.Tip="Pull requests"
                                IsEnabled="{Binding CurrentWorkspace, Converter={x:Static ObjectConverters.IsNotNull}}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="{StaticResource PullRequestIcon}" Width="14" Height="14" Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="Pull requests" FontSize="12" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" IsVisible="{Binding IsRailExpanded}"/>
                            </StackPanel>
                        </Button>
                        <Button Classes="railItem" Classes.active="{Binding IsIssuesSectionActive}" Command="{Binding ShowHostSectionCommand}" CommandParameter="Issues" ToolTip.Tip="Issues"
                                IsEnabled="{Binding CurrentWorkspace, Converter={x:Static ObjectConverters.IsNotNull}}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="{StaticResource IssueIcon}" Width="14" Height="14" Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="Issues" FontSize="12" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" IsVisible="{Binding IsRailExpanded}"/>
                            </StackPanel>
                        </Button>
                        <Button Classes="railItem" Classes.active="{Binding IsNotificationsSectionActive}" Command="{Binding ShowHostSectionCommand}" CommandParameter="Notifications" ToolTip.Tip="Notifications"
                                IsEnabled="{Binding CurrentWorkspace, Converter={x:Static ObjectConverters.IsNotNull}}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="{StaticResource BellIcon}" Width="14" Height="14" Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="Notifications" FontSize="12" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" IsVisible="{Binding IsRailExpanded}"/>
                            </StackPanel>
                        </Button>
                        <Button Classes="railItem" Classes.active="{Binding IsReleasesSectionActive}" Command="{Binding ShowHostSectionCommand}" CommandParameter="Releases" ToolTip.Tip="Releases"
                                IsEnabled="{Binding CurrentWorkspace, Converter={x:Static ObjectConverters.IsNotNull}}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="{StaticResource TagIcon}" Width="14" Height="14" Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="Releases" FontSize="12" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" IsVisible="{Binding IsRailExpanded}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <Border Grid.Row="1" Height="1" Background="{DynamicResource BorderHairline}" Margin="4,6"/>

                    <!-- bottom two-thirds: the live agent list (tooltips carry state + task);
                         scrolls vertically in both states and horizontally when expanded -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                        <StackPanel Spacing="2">
                            <TextBlock Text="AGENTS" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" Margin="8,2,0,4" IsVisible="{Binding IsRailExpanded}"/>
                            <ItemsControl ItemsSource="{Binding ControlCenter.Agents}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:AgentRowViewModel">
                                        <Button Classes="railItem" Opacity="{Binding RowOpacity}" ToolTip.Tip="{Binding Tooltip}"
                                                Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ShowAgentCommand}"
                                                CommandParameter="{Binding AgentId}">
                                            <Grid ColumnDefinitions="14,*,Auto">
                                                <Panel Grid.Column="0" Width="10" Height="10" VerticalAlignment="Center">
                                                    <PathIcon Classes="railBadge"
                                                              Foreground="{Binding Status, Converter={x:Static converters:AgentStatusBrushConverter.Instance}}"
                                                              Data="{Binding BadgeGeometryKey, Converter={x:Static converters:ResourceKeyToGeometryConverter.Instance}}"/>
                                                </Panel>
                                                <StackPanel Grid.Column="1" Margin="8,0,0,0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center"
                                                            IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsRailExpanded}">
                                                    <TextBlock Classes="Mono" Text="{Binding Name}" FontSize="12" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                                                    <!-- PR3: the orchestration role as a quiet word ("coordinator" / "subagent"), never a color -->
                                                    <TextBlock Text="{Binding RoleLabel}" FontSize="9" Foreground="{DynamicResource TextMuted}"
                                                               VerticalAlignment="Center" IsVisible="{Binding HasRoleLabel}"/>
                                                    <TextBlock Text="{Binding Detail}" FontSize="10" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis" MaxWidth="88"/>
                                                </StackPanel>
                                                <!-- expanded-only "needs you" tag: a quiet word, not a pulse (§2.4). Colour is the
                                                     status token via the one converter; reads at a glance without decoding the glyph. -->
                                                <Border Grid.Column="2" Margin="6,0,2,0" VerticalAlignment="Center" CornerRadius="999"
                                                        Padding="6,1" Background="{DynamicResource AccentSelection}"
                                                        IsVisible="{Binding NeedsAttention}">
                                                    <TextBlock Text="needs you" FontSize="9" FontWeight="SemiBold" VerticalAlignment="Center"
                                                               Foreground="{Binding Status, Converter={x:Static converters:AgentStatusBrushConverter.Instance}}"
                                                               IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsRailExpanded}"/>
                                                </Border>
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- the always-visible kill switch, at the rail's foot in every section -->
                    <Button Grid.Row="3" Classes="railItem railKill" Classes.frozen="{Binding ControlCenter.IsFrozen}"
                            Command="{Binding ControlCenter.ToggleKillSwitchCommand}"
                            ToolTip.Tip="Stop all agents and freeze the merge queue — instant, nothing is lost, resume any time">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <PathIcon Data="{StaticResource SeverityBlockerIcon}" Width="13" Height="13"/>
                            <TextBlock Text="{Binding ControlCenter.KillSwitchLabel}" FontSize="12" VerticalAlignment="Center" IsVisible="{Binding IsRailExpanded}"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- SECTION CONTENT -->
            <Panel Grid.Column="1">

            <!-- Coordinator surface (chat / agent documents / merge queue) -->
            <Panel IsVisible="{Binding IsCoordinatorSectionActive}">
                <views:CoordinatorSurfaceView DataContext="{Binding ControlCenter}"/>
            </Panel>

            <!-- Resources tab (task-manager monitor) -->
            <Panel IsVisible="{Binding IsResourcesSectionActive}">
                <views:ResourceMonitorView DataContext="{Binding ResourceMonitor}"/>
            </Panel>

            <!-- Host surface tabs (PRs / Issues / Notifications / Releases): the VM resolves
                 to its View through ViewLocator — the same VMs the legacy dialogs use. -->
            <Panel IsVisible="{Binding IsHostSectionActive}" Margin="8">
                <ContentControl Content="{Binding HostSectionContent}"/>
            </Panel>

            <!-- Repo viewer: today's workspace, untouched -->
            <Grid IsVisible="{Binding IsRepoSectionActive}">
            <!-- The repositories tree moved to RepoPickerWindow (2026-07-11); the workspace runs full-width. -->

            <!-- MAIN WORKSPACE CONTENT -->
        <Grid Background="{DynamicResource SurfaceWindow}">
            <!-- Shows when nothing is selected -->
            <StackPanel IsVisible="{Binding CurrentWorkspace, Converter={x:Static ObjectConverters.IsNull}}" 
                            HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20">
                    <TextBlock Text="Select a repository to begin" Foreground="{DynamicResource TextMuted}" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <PathIcon Data="{StaticResource FolderIcon}" Width="48" Height="48" Foreground="{DynamicResource BorderHairline}" HorizontalAlignment="Center"/>
                    
                    <Border IsVisible="{Binding IsReopenRepoCardVisible}"
                            Background="{DynamicResource SurfaceCard}"
                            BorderBrush="{DynamicResource BorderHairline}" BorderThickness="1"
                            CornerRadius="12" Padding="18">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Reopen Last Repository?" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource TextPrimary}" />
                            <TextBlock Text="{Binding ReopenRepositoryPath}" Foreground="{DynamicResource TextMuted}" />
                            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                                <Button Content="Dismiss" Command="{Binding DismissReopenRepoCardCommand}" Background="{DynamicResource SurfaceHoverGhost}" Foreground="{DynamicResource TextMuted}"/>
                                <Button Content="Reopen" Command="{Binding ReopenLastRepoCommand}" Classes="Primary" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

            <!-- Automatically loads RepoDashboardView when a repository is selected! -->
            <ContentControl Content="{Binding CurrentWorkspace}" />

            <!-- Shown immediately while a repo is opening, before the dashboard's own loading
                 screen can render — the shell would otherwise look frozen (#63). -->
            <Border IsVisible="{Binding IsOpeningRepo}"
                    Background="{DynamicResource SurfaceWindow}"
                    ZIndex="60">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="14">
                    <TextBlock Text="Opening repository…" Foreground="{DynamicResource TextMuted}" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- INVALID REPO CARD (Floating Overlay) -->
        <Border Grid.Row="1" Grid.Column="0" 
                HorizontalAlignment="Left" VerticalAlignment="Bottom" 
                Margin="20" Padding="15" Background="{DynamicResource SurfacePanel}"
                BorderBrush="{DynamicResource BorderHairline}" BorderThickness="1" CornerRadius="12"
                IsVisible="{Binding IsInvalidRepoCardVisible}"
                ZIndex="100">
            <StackPanel Spacing="10" Width="300">
                <TextBlock Text="Repository Not Found" FontWeight="Bold" Foreground="{DynamicResource DangerBrush}" FontSize="14" />
                <TextBlock Text="{Binding InvalidRepository.Path}" Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap" FontSize="11" />
                <TextBlock Text="The repository folder was moved or deleted." Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap" FontSize="12" />
                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button Content="Cancel" Padding="8,4" Background="{DynamicResource SurfaceHoverGhost}" Foreground="{DynamicResource TextMuted}" Command="{Binding CancelInvalidRepoCardCommand}" />
                    <Button Content="Remove" Padding="8,4" Background="{DynamicResource SurfaceHoverGhost}" Foreground="{DynamicResource DangerBrush}" Command="{Binding RemoveInvalidRepoCommand}" />
                    <Button Content="Change Path" Classes="Primary" Padding="8,4" Command="{Binding ChangeInvalidRepoPathCommand}" />
                </StackPanel>
            </StackPanel>
        </Border>

        </Grid>
            </Panel>
        </Grid>

        <!-- COMMAND PALETTE OVERLAY (T-18): scrim + the reusable palette view bound to CommandPalette. -->
        <Border Grid.RowSpan="2" Background="#C0000000" ZIndex="1000" IsVisible="{Binding IsCommandPaletteOpen}"
                PointerPressed="CommandPaletteScrim_PointerPressed">
            <views:CommandPaletteView x:Name="CommandPalette" DataContext="{Binding CommandPalette}" />
        </Border>
    </Grid>
    </Grid>
</Window>
