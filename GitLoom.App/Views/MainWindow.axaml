<Window xmlns="https://github.com/avaloniaui"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:vm="using:GitLoom.App.ViewModels"
            xmlns:models="using:GitLoom.Core.Models"
            x:Class="GitLoom.App.Views.MainWindow"
            x:DataType="vm:MainWindowViewModel"
            x:Name="Root"
            Icon="/Assets/avalonia-logo.ico"
            Title="GitLoom"
            MinWidth="800" MinHeight="600"
            WindowStartupLocation="CenterScreen"
            Background="{StaticResource BgWindow}"
            KeyUp="Window_KeyUp">
    
    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+P" Command="{Binding OpenCommandPaletteCommand}" />
        <KeyBinding Gesture="Escape" Command="{Binding CloseCommandPaletteCommand}" />
    </Window.KeyBindings>

    <Window.Styles>
        <Style Selector="MenuFlyoutPresenter MenuItem" x:DataType="vm:MenuItemViewModel">
            <Setter Property="Header" Value="{Binding Header}"/>
            <Setter Property="Command" Value="{Binding Command}"/>
            <Setter Property="CommandParameter" Value="{Binding CommandParameter}"/>
            <Setter Property="IsEnabled" Value="{Binding IsEnabled}"/>
            <Setter Property="ItemsSource" Value="{Binding SubItems}"/>
        </Style>
        
        <Style Selector="TextBox.searchBox:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="{StaticResource BranchCyan}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="TextBox.searchBox:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        
        <!-- Dim highlight for buttons in dropdown -->
        <Style Selector="Button.BranchItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource ButtonHover}" />
        </Style>
        <Style Selector="ToggleButton.BranchCategory:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource ButtonHover}" />
        </Style>
        <Style Selector="ToggleButton.BranchCategory:checked /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="ToggleButton.BranchCategory:checked:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource ButtonHover}" />
        </Style>

        
        <!-- Chevron Data Swapping -->
        <Style Selector="PathIcon.Chevron">
            <Setter Property="Data" Value="{StaticResource ChevronRightIcon}" />
        </Style>
        <Style Selector="PathIcon.Chevron.expanded">
            <Setter Property="Data" Value="{StaticResource ChevronDownIcon}" />
        </Style>

        <Style Selector="ToggleButton.RepoCategory:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource ButtonHover}" />
        </Style>
        <Style Selector="ToggleButton.RepoCategory:checked /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="ToggleButton.RepoCategory:checked:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource ButtonHover}" />
        </Style>

        <!-- Selection Styles -->
        <Style Selector="Border.RepoItem.selected">
            <Setter Property="Background" Value="{StaticResource ButtonHover}" />
        </Style>
        <Style Selector="ToggleButton.RepoCategory.selected /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource ButtonHover}" />
        </Style>

    </Window.Styles>

    <Window.DataTemplates>
        <!-- Repository Template -->
        <DataTemplate DataType="{x:Type models:Repository}">
            <Border Classes="RepoItem" Classes.selected="{Binding IsSelected}" CornerRadius="4" Margin="25,2,10,2" Padding="5,3">
                <Border.Styles>
                    <Style Selector="Border">
                        <Setter Property="Background" Value="Transparent" />
                    </Style>
                    <Style Selector="Border:pointerover">
                        <Setter Property="Background" Value="{StaticResource ButtonHover}" />
                    </Style>
                    <Style Selector="Border:pressed">
                        <Setter Property="Background" Value="{StaticResource ButtonHover}" />
                    </Style>
                </Border.Styles>
                
                <Border.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Change Icon Color">
                            <MenuItem Header="Red" Command="{ReflectionBinding #Root.DataContext.SetRepoColorRedCommand}" CommandParameter="{Binding}" Foreground="#FF5252" />
                            <MenuItem Header="Green" Command="{ReflectionBinding #Root.DataContext.SetRepoColorGreenCommand}" CommandParameter="{Binding}" Foreground="#4CAF50" />
                            <MenuItem Header="Blue (Default)" Command="{ReflectionBinding #Root.DataContext.SetRepoColorBlueCommand}" CommandParameter="{Binding}" Foreground="#569CD6" />
                            <MenuItem Header="Yellow" Command="{ReflectionBinding #Root.DataContext.SetRepoColorYellowCommand}" CommandParameter="{Binding}" Foreground="#FFEB3B" />
                            <MenuItem Header="Purple" Command="{ReflectionBinding #Root.DataContext.SetRepoColorPurpleCommand}" CommandParameter="{Binding}" Foreground="#9C27B0" />
                        </MenuItem>
                        <MenuItem Header="Analytics" Command="{ReflectionBinding #Root.DataContext.OpenAnalyticsCommand}" CommandParameter="{Binding}" />
                        <MenuItem Header="Move to other category" Command="{ReflectionBinding #Root.DataContext.MoveRepositoryCommand}" CommandParameter="{Binding}" />
                        <MenuItem Header="Remove" Command="{ReflectionBinding #Root.DataContext.RemoveRepositoryCommand}" CommandParameter="{Binding}" Foreground="{StaticResource BranchRed}" />
                    </ContextMenu>
                </Border.ContextMenu>

                <StackPanel Orientation="Horizontal" Spacing="8"
                            PointerPressed="Repo_PointerPressed"
                            PointerMoved="Repo_PointerMoved"
                            DoubleTapped="Repo_DoubleTapped"
                            DragDrop.AllowDrop="True"
                            Background="Transparent">
                    
                    <Ellipse Width="8" Height="8" Fill="{Binding CustomIconColor, TargetNullValue='#569CD6'}" Margin="10,0,10,0" />
                    <TextBlock Text="{Binding DisplayName}" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- Category Template (Recursive) -->
        <DataTemplate DataType="{x:Type models:WorkspaceCategory}">
            <StackPanel>
                <Grid ColumnDefinitions="*, Auto" DragDrop.AllowDrop="True" PointerPressed="Category_PointerPressed" PointerMoved="Category_PointerMoved" Background="Transparent">
                    <ToggleButton Classes="RepoCategory" Classes.selected="{Binding IsSelected}" Grid.Column="0" IsChecked="{Binding IsExpanded, Mode=TwoWay}" Click="Category_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Background="Transparent" BorderThickness="0" Padding="10,5">
                        <ToggleButton.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Rename Category" Command="{ReflectionBinding #Root.DataContext.RenameCategoryCommand}" CommandParameter="{Binding}" />
                                <MenuItem Header="New Sub-Category" Command="{ReflectionBinding #Root.DataContext.CreateSubCategoryCommand}" CommandParameter="{Binding}" />
                                <MenuItem Header="Delete Category" Command="{ReflectionBinding #Root.DataContext.DeleteCategoryCommand}" CommandParameter="{Binding}" Foreground="{StaticResource BranchRed}" />
                            </ContextMenu>
                        </ToggleButton.ContextMenu>
                        <Grid ColumnDefinitions="Auto, *, Auto">
                            <PathIcon Grid.Column="0" Classes="Chevron" Classes.expanded="{Binding IsExpanded}" Width="10" Height="10" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Margin="0,0,5,0" />
                            <TextBlock Grid.Column="1" Text="{Binding Name}" IsVisible="{Binding !IsEditingName}" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" Margin="0,5" VerticalAlignment="Center" HorizontalAlignment="Left" />
                            <TextBox Grid.Column="1" Text="{Binding Name, Mode=TwoWay}" IsVisible="{Binding IsEditingName}" KeyUp="CategoryNameTextBox_KeyUp" AttachedToVisualTree="CategoryNameTextBox_AttachedToVisualTree" VerticalAlignment="Center" MinWidth="100" HorizontalAlignment="Stretch" Margin="0,0,10,0"/>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" IsVisible="{Binding IsEditingName}" HorizontalAlignment="Right">
                                <Button Command="{ReflectionBinding #Root.DataContext.SaveCategoryNameCommand}" CommandParameter="{Binding}" Background="Transparent" Foreground="{StaticResource BranchGreen}" Padding="4,0" Margin="4,0,0,0">
                                    <PathIcon Data="{StaticResource CheckmarkIcon}" Width="14" Height="14"/>
                                </Button>
                                <Button Command="{ReflectionBinding #Root.DataContext.CancelCategoryNameCommand}" CommandParameter="{Binding}" Background="Transparent" Foreground="{StaticResource BranchRed}" Padding="4,0" Margin="4,0,0,0">
                                    <PathIcon Data="{StaticResource DismissIcon}" Width="14" Height="14"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </ToggleButton>
                    <Button Grid.Column="1" Content="+" Padding="6,0" FontSize="16" FontWeight="Bold"
                            Command="{ReflectionBinding #Root.DataContext.AddRepositoryToCategoryCommand}"
                            CommandParameter="{Binding}"
                            Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextMuted}" Cursor="Hand" VerticalAlignment="Center" Margin="0,0,10,0"/>
                </Grid>
                
                <!-- Recursive Subcategories -->
                <ItemsControl Margin="15,0,0,0" ItemsSource="{Binding SubCategories}" IsVisible="{Binding IsExpanded}" />
                <!-- Repositories -->
                <ItemsControl ItemsSource="{Binding Repositories}" IsVisible="{Binding IsExpanded}" />
            </StackPanel>
        </DataTemplate>
    </Window.DataTemplates>

    <Window.DataTemplates>
        <!-- Custom TreeDataTemplate for deeply nested menus -->
        <TreeDataTemplate DataType="vm:MenuItemViewModel" ItemsSource="{Binding SubItems}">
            <StackPanel Orientation="Horizontal" Spacing="5">
                <PathIcon Data="{StaticResource CheckmarkIcon}" IsVisible="{Binding IsCurrentBranch}" Foreground="{StaticResource BranchCyan}" Width="10" Height="10" />
                <TextBlock Text="{Binding Header}" />
            </StackPanel>
        </TreeDataTemplate>
    </Window.DataTemplates>

    <Grid>
        <Grid RowDefinitions="Auto, *">
        <!-- TOP NAVBAR -->
        <Border Grid.Row="0" Background="{StaticResource BgSidebar}" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,0,1" Padding="10,5">
            <Grid ColumnDefinitions="Auto, *, Auto">
                
                <!-- Left Side: Hamburger, Menu, Repo Name, Branch Dropdown -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <!-- Hamburger Button -->
                    <Button Classes="Primary" Command="{Binding ToggleSidebarCommand}"
                            Padding="8,4" Background="Transparent" BorderThickness="0"
                            VerticalAlignment="Center">
                        <PathIcon Data="{StaticResource MenuIcon}" Width="18" Height="18" Foreground="{StaticResource TextPrimary}"/>
                    </Button>
                    
                    <Menu Background="Transparent" VerticalAlignment="Center">
                        <MenuItem Header="{ReflectionBinding CurrentWorkspace.RepositoryName, FallbackValue='File', TargetNullValue='File'}" Foreground="{StaticResource TextPrimary}">
                            <MenuItem Header="Close Repository" Command="{Binding CloseRepositoryCommand}" IsVisible="{Binding CurrentWorkspace, Converter={x:Static ObjectConverters.IsNotNull}}" />
                            <MenuItem Header="Settings" />
                            <Separator />
                            <MenuItem Header="Exit" />
                        </MenuItem>
                    </Menu>

                    <!-- Branch Dropdown (Visible only when workspace active) -->
                    <StackPanel Orientation="Horizontal" Spacing="10" 
                                DataContext="{Binding CurrentWorkspace}" 
                                x:DataType="vm:RepoDashboardViewModel"
                                IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).CurrentWorkspace, Converter={x:Static ObjectConverters.IsNotNull}}">

                        <Button Content="{Binding BranchBrowser.CurrentBranchName}" Background="Transparent" Foreground="{StaticResource TextPrimary}" BorderThickness="0" VerticalAlignment="Center">
                            <Button.Flyout>
                                <Flyout Placement="BottomEdgeAlignedLeft">
                                    <StackPanel>
                                        <Grid ColumnDefinitions="Auto,*,Auto" Margin="10,10,10,5">
                                            <PathIcon Grid.Column="0" Data="{StaticResource SearchIcon}" Width="12" Height="12" Foreground="{StaticResource TextMuted}" Margin="0,0,5,0"/>
                                            <TextBox Classes="searchBox" Grid.Column="1" Watermark="Search for branches and actions" BorderThickness="1" BorderBrush="Transparent" Background="Transparent" FontSize="13" Padding="5"/>
                                            <Button Grid.Column="2" Content="+" Command="{Binding BranchBrowser.OpenCreateBranchDialogCommand}" ToolTip.Tip="New Branch..." Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextMuted}"/>
                                        </Grid>
                                        
                                        <Button Content="Fetch" Command="{Binding FetchCommand}" Background="Transparent" BorderThickness="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="15,7" FontSize="13"/>
                                        <Button Content="Update Project" Command="{Binding UpdateProjectCommand}" Background="Transparent" BorderThickness="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="15,7" FontSize="13"/>
                                        <Separator Background="{StaticResource BorderSubtle}" Margin="0,5"/>
                                        
                                        <ScrollViewer Height="230" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                                            <ItemsControl ItemsSource="{Binding BranchBrowser.BranchCategories}" Background="Transparent" BorderThickness="0" Margin="0,0,0,10">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="vm:BranchCategoryViewModel">
                                                        <StackPanel>
                                                            <ToggleButton Classes="BranchCategory" IsChecked="{Binding IsExpanded, Mode=TwoWay}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="Transparent" BorderThickness="0" Padding="10,5">
                                                                <StackPanel Orientation="Horizontal" Spacing="5">
                                                                    <PathIcon Classes="Chevron" Classes.expanded="{Binding IsExpanded}" Width="10" Height="10" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" />
                                                                    <TextBlock Text="{Binding CategoryName}" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" />
                                                                </StackPanel>
                                                            </ToggleButton>
                                                            
                                                            <ItemsControl ItemsSource="{Binding Branches}" IsVisible="{Binding IsExpanded}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate DataType="vm:MenuItemViewModel">
                                                                        <Button Classes="BranchItem" Background="Transparent" BorderThickness="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="25,5,10,5" CornerRadius="4">
                                                                            <Button.Flyout>
                                                                                <MenuFlyout Placement="RightEdgeAlignedTop" ItemsSource="{Binding SubItems}" />
                                                                            </Button.Flyout>
                                                                            <Grid ColumnDefinitions="20,*">
                                                                                <PathIcon Grid.Column="0" Data="{StaticResource CheckmarkIcon}" IsVisible="{Binding IsCurrentBranch}" Foreground="{StaticResource BranchCyan}" Width="12" Height="12" Margin="0,0,4,0"/>
                                                                                <TextBlock Grid.Column="1" Text="{Binding Header}" VerticalAlignment="Center" FontSize="13"/>
                                                                            </Grid>
                                                                        </Button>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                        <Button Content="New Branch from Current" Command="{Binding BranchBrowser.CreateBranchFromCurrentCommand}" Margin="5" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="{StaticResource PanelSurface}" />
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                    </StackPanel>
                </StackPanel>

                <!-- Right Side: Push/Pull Buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center"
                            DataContext="{Binding CurrentWorkspace}" 
                            x:DataType="vm:RepoDashboardViewModel"
                            IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).CurrentWorkspace, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <Button Classes="Primary" Padding="15,4" Command="{Binding PullCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <PathIcon Data="{StaticResource ArrowDownIcon}" Width="14" Height="14"/>
                            <TextBlock Text="Pull" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                    <Button Classes="Primary" Padding="15,4" Command="{Binding PushCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <PathIcon Data="{StaticResource ArrowUpIcon}" Width="14" Height="14"/>
                            <TextBlock Text="Push" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                
            </Grid>
        </Border>

        <!-- MAIN LAYOUT -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{Binding SidebarColumnWidth, Mode=TwoWay}" MinWidth="200" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            
            <!-- SIDEBAR -->
            <Border Grid.Column="0" Background="{StaticResource BgSidebar}" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,1,0"
                Classes="Sidebar" IsVisible="{Binding IsSidebarOpen}">

            <Grid RowDefinitions="Auto, *, Auto" Margin="10, 15, 10, 15">

                <!-- Top Row: Title -->
                <Grid Grid.Row="0" Margin="0,0,0,15" ColumnDefinitions="*, Auto" IsVisible="{Binding IsSidebarOpen}">
                    
                    <!-- Sidebar Title -->
                    <TextBlock Grid.Column="0" Text="REPOSITORIES" Foreground="{StaticResource TextMuted}"
                                FontWeight="Bold" FontSize="11" LetterSpacing="1"
                                VerticalAlignment="Center" Margin="5,0,5,0" HorizontalAlignment="Left" 
                                TextTrimming="CharacterEllipsis" />

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2" HorizontalAlignment="Right">
                        <Button Content="+" ToolTip.Tip="New Category" Command="{Binding CreateCategoryCommand}" 
                                Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextMuted}"
                                VerticalAlignment="Center" Padding="4,2"/>

                        <Button ToolTip.Tip="Create Git Repository" Command="{Binding CreateGitRepositoryCommand}"
                                Background="Transparent" Padding="4">
                            <PathIcon Data="{StaticResource DocumentAddIcon}" Width="14" Height="14" Foreground="{StaticResource TextMuted}"/>
                        </Button>

                        <Button ToolTip.Tip="Clone from Cloud" Command="{Binding OpenCloudSyncCommand}"
                                Background="Transparent" Padding="4">
                            <PathIcon Data="{StaticResource CloudIcon}" Width="14" Height="14" Foreground="{StaticResource TextMuted}"/>
                        </Button>

                        <Button ToolTip.Tip="Select Auto-Detect Folder" Command="{Binding SelectAutoDetectFolderCommand}"
                                Background="Transparent" Padding="4">
                            <PathIcon Data="{StaticResource FolderIcon}" Width="14" Height="14" Foreground="{StaticResource TextMuted}"/>
                        </Button>

                        <Button ToolTip.Tip="Scan Auto-Detect Folder" Command="{Binding ScanAutoDetectFolderCommand}"
                                Background="Transparent" Padding="4">
                            <PathIcon Classes.spinning="{Binding IsScanning}" Data="{StaticResource RefreshIcon}" Width="14" Height="14" Foreground="{StaticResource TextMuted}">
                                <PathIcon.RenderTransform>
                                    <RotateTransform/>
                                </PathIcon.RenderTransform>
                            </PathIcon>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Category List -->
                <ScrollViewer Grid.Row="1" IsVisible="{Binding IsSidebarOpen}" Background="Transparent" HorizontalScrollBarVisibility="Auto"
                              DragDrop.AllowDrop="True" PointerPressed="SidebarBackground_PointerPressed">
                    <ScrollViewer.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="New Category" Command="{Binding CreateCategoryCommand}" />
                        </ContextMenu>
                    </ScrollViewer.ContextMenu>
                    <ItemsControl ItemsSource="{Binding Categories}" />
                </ScrollViewer>

            </Grid>
        </Border>

        <!-- GRID SPLITTER -->
        <GridSplitter Grid.Column="1" Width="4" Background="Transparent" IsVisible="{Binding IsSidebarOpen}" />

        <!-- MAIN WORKSPACE CONTENT -->
        <Grid Grid.Column="2" Background="{StaticResource BgWindow}">
            <!-- Shows when nothing is selected -->
            <StackPanel IsVisible="{Binding CurrentWorkspace, Converter={x:Static ObjectConverters.IsNull}}" 
                            HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20">
                    <TextBlock Text="Select a repository to begin" Foreground="{StaticResource TextMuted}" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <PathIcon Data="{StaticResource FolderIcon}" Width="48" Height="48" Foreground="{StaticResource BorderSubtle}" HorizontalAlignment="Center"/>
                    
                    <Border IsVisible="{Binding IsReopenRepoCardVisible}"
                            Background="{StaticResource ButtonBg}"
                            BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1"
                            CornerRadius="8" Padding="15">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Reopen Last Repository?" FontWeight="Bold" FontSize="16" Foreground="{StaticResource TextPrimary}" />
                            <TextBlock Text="{Binding ReopenRepositoryPath}" Foreground="{StaticResource TextMuted}" />
                            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                                <Button Content="Dismiss" Command="{Binding DismissReopenRepoCardCommand}" Background="Transparent" Foreground="{StaticResource TextMuted}"/>
                                <Button Content="Reopen" Command="{Binding ReopenLastRepoCommand}" Classes="Primary" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

            <!-- Automatically loads RepoDashboardView when a repository is selected! -->
            <ContentControl Content="{Binding CurrentWorkspace}" />
        </Grid>

        <!-- INVALID REPO CARD (Floating Overlay) -->
        <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" 
                HorizontalAlignment="Left" VerticalAlignment="Bottom" 
                Margin="20" Padding="15" Background="{StaticResource BgSidebar}" 
                BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1" CornerRadius="8"
                IsVisible="{Binding IsInvalidRepoCardVisible}"
                ZIndex="100">
            <StackPanel Spacing="10" Width="300">
                <TextBlock Text="Repository Not Found" FontWeight="Bold" Foreground="{StaticResource BranchRed}" FontSize="14" />
                <TextBlock Text="{Binding InvalidRepository.Path}" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" FontSize="11" />
                <TextBlock Text="The repository folder was moved or deleted." Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap" FontSize="12" />
                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button Content="Cancel" Padding="8,4" Background="Transparent" Foreground="{StaticResource TextMuted}" Command="{Binding CancelInvalidRepoCardCommand}" />
                    <Button Content="Remove" Padding="8,4" Background="Transparent" Foreground="{StaticResource BranchRed}" Command="{Binding RemoveInvalidRepoCommand}" />
                    <Button Content="Change Path" Classes="Primary" Padding="8,4" Command="{Binding ChangeInvalidRepoPathCommand}" />
                </StackPanel>
            </StackPanel>
        </Border>

        </Grid>
        
        <!-- DELETE CONFIRMATION OVERLAY -->
        <Border Grid.RowSpan="2" Background="#C0000000" ZIndex="2000" IsVisible="{Binding IsDeleteConfirmationVisible}">
            <Border Background="{StaticResource BgSidebar}" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1"
                    CornerRadius="8" Width="400" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="20">
                <Border.BoxShadow>
                    <BoxShadows>0 10 30 0 #40000000</BoxShadows>
                </Border.BoxShadow>
                <StackPanel Spacing="15">
                    <TextBlock Text="{Binding DeleteConfirmationTitle}" FontWeight="Bold" FontSize="16" Foreground="{StaticResource TextPrimary}" />
                    <TextBlock Text="{Binding DeleteConfirmationMessage}" TextWrapping="Wrap" Foreground="{StaticResource TextMuted}" FontSize="13" />
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,10,0,0">
                        <Button Content="Cancel" Classes="Secondary" Padding="15,6" Command="{Binding CancelDeleteCommand}" />
                        <Button Content="Delete" Padding="15,6" Background="{StaticResource BranchRed}" Foreground="White" FontWeight="Bold" Command="{Binding ConfirmDeleteCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
        
        <!-- COMMAND PALETTE OVERLAY -->
        <Border Grid.RowSpan="2" Background="#C0000000" ZIndex="1000" IsVisible="{Binding IsCommandPaletteOpen}" PointerPressed="CommandPaletteBackground_PointerPressed">
            <Border Background="{StaticResource BgSidebar}" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1"
                    CornerRadius="8" Width="500" VerticalAlignment="Top" Margin="0,100,0,0" Padding="10" PointerPressed="CommandPaletteWindow_PointerPressed">
                <Border.BoxShadow>
                    0 10 30 0 #A0000000
                </Border.BoxShadow>
                <Grid RowDefinitions="Auto, *">
                    <!-- Search Input -->
                    <TextBox Grid.Row="0" x:Name="CommandPaletteInput" Text="{Binding CommandPaletteSearchText, Mode=TwoWay}" Watermark="Search repositories (Ctrl+P to open)..." 
                             BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderSubtle}" Background="Transparent" FontSize="16" Padding="10">
                        <TextBox.KeyBindings>
                            <KeyBinding Gesture="Escape" Command="{Binding CloseCommandPaletteCommand}" />
                        </TextBox.KeyBindings>
                    </TextBox>

                    <!-- Search Results -->
                    <ListBox Grid.Row="1" ItemsSource="{Binding CommandPaletteSearchResults}" MaxHeight="350" Background="Transparent" BorderThickness="0" Margin="0,10,0,0"
                             SelectedItem="{Binding SelectedNode, Mode=TwoWay}">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:Repository}">
                                <Border Background="Transparent" CornerRadius="4" Padding="10,5">
                                    <Border.Styles>
                                        <Style Selector="Border:pointerover">
                                            <Setter Property="Background" Value="{StaticResource ButtonHover}" />
                                        </Style>
                                    </Border.Styles>
                                    <StackPanel Orientation="Horizontal" Spacing="10" Background="Transparent"
                                                DoubleTapped="Repo_DoubleTapped">
                                        <PathIcon Data="{StaticResource SearchIcon}" Width="14" Height="14" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Path}" Foreground="{StaticResource TextMuted}" FontSize="11" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Border>
    </Grid>
    </Grid>
</Window>
