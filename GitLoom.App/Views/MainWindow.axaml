<Window xmlns="https://github.com/avaloniaui"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:vm="using:GitLoom.App.ViewModels"
            xmlns:models="using:GitLoom.Core.Models"
            x:Class="GitLoom.App.Views.MainWindow"
            x:DataType="vm:MainWindowViewModel"
            Icon="/Assets/avalonia-logo.ico"
            Title="GitLoom"
            MinWidth="800" MinHeight="600"
            WindowStartupLocation="CenterScreen"
            Background="{StaticResource BgWindow}">

        <Grid ColumnDefinitions="300, *">

            <!-- SIDEBAR -->
            <!-- Right Border Thickness of 1 to cleanly separate sidebar from main content -->
            <Border Grid.Column="0" Background="{StaticResource BgSidebar}" BorderBrush="{StaticResource BorderSubtle}"
  BorderThickness="0,0,1,0">
                <Grid RowDefinitions="Auto, *, Auto" Margin="15, 20, 15, 15">

                    <!-- Title Header -->
                    <TextBlock Grid.Row="0" Text="GitLoom" Foreground="{StaticResource TextPrimary}"
                               FontSize="18" FontWeight="Bold" Margin="5,0,0,15"/>

                    <!-- Category List -->
                    <TreeView Grid.Row="1" ItemsSource="{Binding Categories}" Background="Transparent"
  BorderThickness="0">
                        <TreeView.DataTemplates>
                            <TreeDataTemplate DataType="{x:Type models:WorkspaceCategory}" ItemsSource="{Binding
  Repositories}">
                                <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextPrimary}"
  FontWeight="Bold" Margin="0,5"/>
                            </TreeDataTemplate>

                            <DataTemplate DataType="{x:Type models:Repository}">
                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,5">
                                    <Ellipse Width="8" Height="8" Fill="{StaticResource BranchCyan}"
  VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding DisplayName}" Foreground="{StaticResource TextPrimary}"
  VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </TreeView.DataTemplates>
                    </TreeView>

                    <!-- Add Button -->
                    <Button Classes="Primary" Grid.Row="2" Command="{Binding AddRepositoryCommand}"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="0,8">
                        <TextBlock Text="Add Repository" FontWeight="SemiBold"/>
                    </Button>
                </Grid>
            </Border>

            <!-- MAIN WORKSPACE CONTENT -->
            <Grid Grid.Column="1" Background="{StaticResource BgWindow}">
                <TextBlock Text="Select a repository to begin" Foreground="{StaticResource TextMuted}"
                           HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16"/>
            </Grid>
        </Grid>
    </Window>