<Window xmlns="https://github.com/avaloniaui"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:vm="using:GitLoom.App.ViewModels"
            xmlns:models="using:GitLoom.Core.Models"
            x:Class="GitLoom.App.Views.MainWindow"
            x:DataType="vm:MainWindowViewModel"
            Icon="/Assets/avalonia-logo.ico"
            Title="GitLoom"
            MinWidth="800" MinHeight="600"
            WindowStartupLocation="CenterScreen"
            Background="{StaticResource BgWindow}">
    
    <Window.Styles>
        <Style Selector="Border.Sidebar">
            <Setter Property="Width" Value="55"/>
        </Style>
        <Style Selector="Border.Sidebar.IsOpen">
            <Setter Property="Width" Value="300"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto, *">
        <!-- TOP NAVBAR -->
        <Border Grid.Row="0" Background="{StaticResource BgSidebar}" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,0,1">
            <Menu Background="Transparent">
                <MenuItem Header="File" Foreground="{StaticResource TextPrimary}">
                    <MenuItem Header="Settings" />
                    <Separator />
                    <MenuItem Header="Exit" />
                </MenuItem>
                <MenuItem Header="Repository" Foreground="{StaticResource TextPrimary}" 
                          DataContext="{Binding CurrentWorkspace}" 
                          x:DataType="vm:RepoDashboardViewModel"
                          IsEnabled="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).CurrentWorkspace, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <MenuItem Header="Pull" Command="{Binding PullCommand}" />
                    <MenuItem Header="Push" Command="{Binding PushCommand}" />
                </MenuItem>
                <MenuItem Header="Branches" Foreground="{StaticResource TextPrimary}" 
                          DataContext="{Binding CurrentWorkspace}" 
                          x:DataType="vm:RepoDashboardViewModel"
                          IsEnabled="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).CurrentWorkspace, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <MenuItem Header="Local Branches" ItemsSource="{Binding BranchBrowser.LocalBranches}" Classes="BranchList">
                        <MenuItem.Styles>
                            <Style Selector="MenuItem.BranchList > MenuItem" x:DataType="models:GitBranchItem">
                                <Setter Property="Header" Value="{Binding FriendlyName}"/>
                                <Setter Property="Command" Value="{Binding $parent[MenuItem].((vm:RepoDashboardViewModel)DataContext).BranchBrowser.CheckoutBranchCommand}"/>
                                <Setter Property="CommandParameter" Value="{Binding}"/>
                            </Style>
                        </MenuItem.Styles>
                    </MenuItem>
                    <MenuItem Header="Remote Branches" ItemsSource="{Binding BranchBrowser.RemoteBranches}" Classes="BranchList">
                        <MenuItem.Styles>
                            <Style Selector="MenuItem.BranchList > MenuItem" x:DataType="models:GitBranchItem">
                                <Setter Property="Header" Value="{Binding FriendlyName}"/>
                                <Setter Property="Command" Value="{Binding $parent[MenuItem].((vm:RepoDashboardViewModel)DataContext).BranchBrowser.CheckoutBranchCommand}"/>
                                <Setter Property="CommandParameter" Value="{Binding}"/>
                            </Style>
                        </MenuItem.Styles>
                    </MenuItem>
                </MenuItem>
            </Menu>
        </Border>

        <!-- MAIN LAYOUT -->
        <Grid Grid.Row="1" ColumnDefinitions="Auto, *">
            <!-- SIDEBAR -->
            <Border Grid.Column="0" Background="{StaticResource BgSidebar}" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,1,0"
                Classes="Sidebar" Classes.IsOpen="{Binding IsSidebarOpen}">

            <Grid RowDefinitions="Auto, *, Auto" Margin="10, 15, 10, 15">

                <!-- Top Row: Hamburger Button + Title -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="0,0,0,15">

                    <!-- Hamburger Button -->
                    <Button Classes="Primary" Command="{Binding ToggleSidebarCommand}"
                            Padding="8,4" Background="Transparent" BorderThickness="0"
                            VerticalAlignment="Center">
                        <TextBlock Text="☰" FontSize="18" Foreground="{StaticResource TextPrimary}"/>
                    </Button>

                    <!-- Sidebar Title -->
                    <TextBlock Text="REPOSITORIES" Foreground="{StaticResource TextMuted}"
                               FontWeight="Bold" FontSize="11" LetterSpacing="1"
                               VerticalAlignment="Center"
                               IsVisible="{Binding IsSidebarOpen}"/>

                </StackPanel>

                <!-- Category List -->
                <TreeView Grid.Row="1" ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedNode, Mode=TwoWay}"
                          Background="Transparent" BorderThickness="0"
                          IsVisible="{Binding IsSidebarOpen}">
                     <TreeView.DataTemplates>
                        <!-- CATEGORY HEADER -->
                        <TreeDataTemplate DataType="{x:Type models:WorkspaceCategory}" ItemsSource="{Binding Repositories}">
                            <Grid ColumnDefinitions="*, Auto" Background="Transparent"
                                  DragDrop.AllowDrop="True">

                                <TextBlock Grid.Column="0" Text="{Binding Name}" Foreground="{StaticResource TextPrimary}" FontWeight="Bold" Margin="0,5" VerticalAlignment="Center"/>
                                <Button Grid.Column="1" Content="+" Padding="6,0" FontSize="16" FontWeight="Bold"
                                        Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).AddRepositoryToCategoryCommand}"
                                        CommandParameter="{Binding}"
                                        Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextMuted}" Cursor="Hand"/>
                            </Grid>
                        </TreeDataTemplate>

                        <!-- REPOSITORY ITEM -->
                        <DataTemplate DataType="{x:Type models:Repository}">

                            <!-- ADD THE POINTER EVENTS TO THIS STACKPANEL -->
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,5" Background="Transparent"
                                        PointerPressed="Repo_PointerPressed"
                                        PointerMoved="Repo_PointerMoved"
                                        DoubleTapped="Repo_DoubleTapped"
                                        DragDrop.AllowDrop="True">

                                <StackPanel.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Move to other category" Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).MoveRepositoryCommand}"
                                                  CommandParameter="{Binding}" />
                                        <MenuItem Header="Remove" Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).RemoveRepositoryCommand}" CommandParameter="{Binding}"
                                                  Foreground="{StaticResource BranchRed}" />
                                    </ContextMenu>
                                </StackPanel.ContextMenu>

                                <Ellipse Width="8" Height="8" Fill="{StaticResource BranchCyan}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding DisplayName}" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </TreeView.DataTemplates>
                </TreeView>

            </Grid>
        </Border>

        <!-- MAIN WORKSPACE CONTENT -->
        <Grid Grid.Column="1" Background="{StaticResource BgWindow}">
            <!-- Shows when nothing is selected -->
            <TextBlock Text="Select a repository to begin" Foreground="{StaticResource TextMuted}"
                       HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16"
                       IsVisible="{Binding CurrentWorkspace, Converter={x:Static ObjectConverters.IsNull}}"/>

            <!-- Automatically loads RepoDashboardView when a repository is selected! -->
            <ContentControl Content="{Binding CurrentWorkspace}" />
        </Grid>

        <!-- INVALID REPO CARD (Floating Overlay) -->
        <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" 
                HorizontalAlignment="Left" VerticalAlignment="Bottom" 
                Margin="20" Padding="15" Background="{StaticResource BgSidebar}" 
                BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1" CornerRadius="8"
                IsVisible="{Binding IsInvalidRepoCardVisible}"
                ZIndex="100">
            <StackPanel Spacing="10" Width="300">
                <TextBlock Text="Repository Not Found" FontWeight="Bold" Foreground="{StaticResource BranchRed}" FontSize="14" />
                <TextBlock Text="{Binding InvalidRepository.Path}" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" FontSize="11" />
                <TextBlock Text="The repository folder was moved or deleted." Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap" FontSize="12" />
                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button Content="Cancel" Padding="8,4" Background="Transparent" Foreground="{StaticResource TextMuted}" Command="{Binding CancelInvalidRepoCardCommand}" />
                    <Button Content="Remove" Padding="8,4" Background="Transparent" Foreground="{StaticResource BranchRed}" Command="{Binding RemoveInvalidRepoCommand}" />
                    <Button Content="Change Path" Classes="Primary" Padding="8,4" Command="{Binding ChangeInvalidRepoPathCommand}" />
                </StackPanel>
            </StackPanel>
        </Border>

    </Grid>
</Grid>
</Window>