<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GitLoom.App.ViewModels"
        xmlns:controls="using:GitLoom.App.Controls"
        x:Class="GitLoom.App.Views.MergeConflictWindow"
        x:DataType="vm:MergeConflictViewModel"
        Title="Resolve Conflict"
        Width="1200" Height="800">
        
    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Top Toolbar -->
        <Border Grid.Row="0" Background="#2D2D2D" Padding="10">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="{Binding FilePath}" VerticalAlignment="Center" FontWeight="Bold"/>
                <Button Content="Previous Difference" />
                <Button Content="Next Difference" />
            </StackPanel>
        </Border>

        <!-- 3-Way Editors -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="30" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="30" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            
            <controls:MergeEditorControl Grid.Column="0" />
            <controls:MergeGutterControl Grid.Column="1" />
            <controls:MergeEditorControl Grid.Column="2" />
            <controls:MergeGutterControl Grid.Column="3" />
            <controls:MergeEditorControl Grid.Column="4" />
        </Grid>
        
        <!-- Bottom Action Bar -->
        <Border Grid.Row="2" Background="#2D2D2D" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                <Button Content="Accept Left" Command="{Binding AcceptLeftCommand}" />
                <Button Content="Accept Right" Command="{Binding AcceptRightCommand}" />
                <Button Content="Apply" Command="{Binding ApplyCommand}" />
                <Button Content="Cancel" Command="{Binding CancelCommand}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
