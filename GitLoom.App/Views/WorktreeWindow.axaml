<views:ChromedWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GitLoom.App.ViewModels"
        xmlns:views="using:GitLoom.App.Views"
        xmlns:controls="clr-namespace:GitLoom.App.Controls"
        x:Class="GitLoom.App.Views.WorktreeWindow"
        x:DataType="vm:WorktreePanelViewModel"
        Title="Worktrees"
        Width="700" Height="620"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SurfaceWindow}">
    <Grid RowDefinitions="Auto,*">
    <controls:CustomTitleBar Grid.Row="0"/>
    <Border Grid.Row="1" Padding="20">
        <Grid RowDefinitions="Auto,*,Auto,Auto,Auto">

            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="0,0,0,15">
                <PathIcon Data="{StaticResource SubmoduleIcon}" Width="18" Height="18" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                <TextBlock Text="Worktrees" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                <TextBlock Text="Multiple working trees off one repository" FontSize="12" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" Margin="6,3,0,0"/>
                <Button Classes="IconButton" Command="{Binding RefreshCommand}" ToolTip.Tip="Refresh" Background="{DynamicResource SurfaceHoverGhost}">
                    <PathIcon Data="{StaticResource RefreshIcon}" Width="14" Height="14" Foreground="{DynamicResource TextMuted}"/>
                </Button>
            </StackPanel>

            <!-- Worktree list -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Worktrees}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:WorktreeRowViewModel">
                            <Border Classes="Card" Background="{DynamicResource SurfaceCard}" Padding="12" Margin="0,0,0,8" CornerRadius="8">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding BranchLabel}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                            <TextBlock Classes="Mono" Text="{Binding ShortHead}" FontSize="11" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                                            <Border IsVisible="{Binding IsMain}" Background="{DynamicResource AccentSelection}" CornerRadius="999" Padding="8,2" VerticalAlignment="Center">
                                                <TextBlock Text="main" FontSize="10" Foreground="{DynamicResource AccentBrush}"/>
                                            </Border>
                                            <Border IsVisible="{Binding IsLocked}" Background="{DynamicResource SurfaceHover}" CornerRadius="999" Padding="8,2" VerticalAlignment="Center">
                                                <TextBlock Text="locked" FontSize="10" Foreground="{DynamicResource WarningBrush}"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Classes="Mono" Text="{Binding Path}" FontSize="11" Foreground="{DynamicResource TextMuted}" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <Button Content="Open" Classes="Primary" Padding="12,4" Command="{Binding OpenCommand}"/>
                                        <Button Content="Remove" Classes="Danger" Padding="12,4" Command="{Binding RemoveCommand}" IsVisible="{Binding CanRemove}"
                                                ToolTip.Tip="Remove this worktree (fails if it has changes — use Force)"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Create form -->
            <Border Grid.Row="2" Background="{DynamicResource SurfacePanel}" BorderBrush="{DynamicResource BorderHairline}"
                    BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,12,0,0">
                <StackPanel Spacing="10">
                    <TextBlock Text="Add worktree" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                    <StackPanel Spacing="8">
                        <Grid ColumnDefinitions="120,*">
                            <TextBlock Grid.Column="0" Text="Path" Foreground="{DynamicResource TextMuted}" FontSize="12" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding NewWorktreePath}" Watermark="../my-feature-worktree" FontSize="13"/>
                        </Grid>
                        <Grid ColumnDefinitions="120,*">
                            <CheckBox Grid.Column="1" IsChecked="{Binding CreateBranch}" Content="Create a new branch"
                                      Foreground="{DynamicResource TextPrimary}" FontSize="12"/>
                        </Grid>
                        <Grid ColumnDefinitions="120,*">
                            <TextBlock Grid.Column="0" Text="Branch" Foreground="{DynamicResource TextMuted}" FontSize="12" VerticalAlignment="Center"/>
                            <Panel Grid.Column="1">
                                <ComboBox IsVisible="{Binding !CreateBranch}" ItemsSource="{Binding Branches}" SelectedItem="{Binding SelectedBranch}"
                                          HorizontalAlignment="Stretch" FontSize="13"/>
                                <TextBox IsVisible="{Binding CreateBranch}" Text="{Binding NewBranchName}" Watermark="new-branch-name" FontSize="13"/>
                            </Panel>
                        </Grid>
                    </StackPanel>

                    <TextBlock Text="That branch is already checked out in another worktree — pick another or create a new branch."
                               Foreground="{DynamicResource WarningBrush}" FontSize="11" TextWrapping="Wrap"
                               IsVisible="{Binding SelectedBranchIsCheckedOut}"/>

                    <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                        <Button Content="Prune" Classes="Secondary" Padding="15,6" Command="{Binding PruneCommand}"
                                ToolTip.Tip="Clean up worktree admin files for deleted directories"/>
                        <Button Content="Add worktree" Classes="Accent" Padding="15,6" Command="{Binding CreateCommand}" IsEnabled="{Binding CanCreate}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Error -->
            <TextBlock Grid.Row="3" Text="{Binding ErrorMessage}" Foreground="{DynamicResource DangerBrush}" TextWrapping="Wrap"
                       Margin="0,10,0,0" FontSize="12"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

            <!-- Footer -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                <Button Content="Close" Classes="Secondary" Padding="15,6" Command="{Binding CloseCommand}"/>
            </StackPanel>
        </Grid>
    </Border>
    </Grid>
</views:ChromedWindow>
