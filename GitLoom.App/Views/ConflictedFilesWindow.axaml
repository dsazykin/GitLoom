<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GitLoom.App.ViewModels"
        x:Class="GitLoom.App.Views.ConflictedFilesWindow"
        x:DataType="vm:ConflictedFilesViewModel"
        Title="Merge Conflicts"
        Width="600" Height="400"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E" Foreground="#D4D4D4">
    
    <Grid RowDefinitions="*,Auto">
        <ListBox Grid.Row="0" ItemsSource="{Binding ConflictedFiles}" Background="Transparent" Margin="10">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="*, Auto" Margin="5">
                        <TextBlock Grid.Column="0" Text="{Binding FilePath}" VerticalAlignment="Center" FontWeight="Bold" Foreground="#D4D4D4"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                            <Button Content="Accept Incoming" Command="{Binding $parent[Window].((vm:ConflictedFilesViewModel)DataContext).AcceptIncomingCommand}" CommandParameter="{Binding}" Background="#4EC9B0" Foreground="Black" Padding="5,2" />
                            <Button Content="Accept Outgoing" Command="{Binding $parent[Window].((vm:ConflictedFilesViewModel)DataContext).AcceptOutgoingCommand}" CommandParameter="{Binding}" Background="#569CD6" Foreground="Black" Padding="5,2"/>
                            <Button Content="Modify" Command="{Binding $parent[Window].((vm:ConflictedFilesViewModel)DataContext).ModifyCommand}" CommandParameter="{Binding}" Background="#007ACC" Foreground="White" Padding="5,2"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <Button Content="Cancel Merge" Command="{Binding CancelCommand}" />
        </StackPanel>
    </Grid>
</Window>
