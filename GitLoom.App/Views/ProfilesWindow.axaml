<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GitLoom.App.ViewModels"
        x:Class="GitLoom.App.Views.ProfilesWindow"
        x:DataType="vm:ProfilesViewModel"
        Title="Git Profiles"
        Width="640" Height="600"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SurfaceWindow}">
    <Border Padding="20">
        <Grid RowDefinitions="Auto,*,Auto,Auto,Auto">

            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="0,0,0,15">
                <PathIcon Data="{StaticResource PersonIcon}" Width="18" Height="18" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                <TextBlock Text="Git Profiles" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                <TextBlock Text="Switchable identities — apply one to write this repo's local user.name / user.email"
                           FontSize="12" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" Margin="6,3,0,0"/>
            </StackPanel>

            <!-- Profile list -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="8">
                    <ItemsControl ItemsSource="{Binding Profiles}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:ProfileRowViewModel">
                                <Border Classes="Card" Background="{DynamicResource SurfaceCard}" Padding="12" Margin="0,0,0,2" CornerRadius="8">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Grid.Column="0" Spacing="3" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                                                <Border IsVisible="{Binding SignsCommits}" Background="{DynamicResource AccentSelection}" CornerRadius="999" Padding="8,2" VerticalAlignment="Center">
                                                    <TextBlock Text="signs" FontSize="10" Foreground="{DynamicResource AccentBrush}"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Classes="Mono" Text="{Binding Identity}" FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                            <Button Content="Apply" Classes="Primary" Padding="12,4" Command="{Binding ApplyCommand}"
                                                    IsEnabled="{Binding CanApply}" ToolTip.Tip="Write this identity to the open repo's local config"/>
                                            <Button Content="Edit" Classes="Secondary" Padding="12,4" Command="{Binding EditCommand}"/>
                                            <Button Content="Delete" Classes="Danger" Padding="12,4" Command="{Binding DeleteCommand}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="No profiles yet. Add one to switch Git identities per repository."
                               Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="4,8"
                               IsVisible="{Binding !Profiles.Count}" TextWrapping="Wrap"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Undo-delete toast (cancel-safe delete) -->
            <Border Grid.Row="2" IsVisible="{Binding CanUndoDelete}" Background="{DynamicResource SurfaceCard}"
                    BorderBrush="{DynamicResource BorderHairline}" BorderThickness="1" CornerRadius="8"
                    Padding="12,8" Margin="0,10,0,0">
                <Grid ColumnDefinitions="*,Auto,Auto">
                    <TextBlock Grid.Column="0" Text="{Binding UndoDeleteText}" Foreground="{DynamicResource TextPrimary}" FontSize="12" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="Undo" Classes="Accent" Padding="12,4" Command="{Binding UndoDeleteCommand}" Margin="0,0,8,0"/>
                    <Button Grid.Column="2" Content="Dismiss" Classes="Secondary" Padding="10,4" Command="{Binding DismissUndoCommand}"/>
                </Grid>
            </Border>

            <!-- Editor -->
            <Border Grid.Row="3" IsVisible="{Binding IsEditing}" Background="{DynamicResource SurfacePanel}"
                    BorderBrush="{DynamicResource BorderHairline}" BorderThickness="1" CornerRadius="12"
                    Padding="16" Margin="0,12,0,0">
                <StackPanel Spacing="10">
                    <TextBlock Text="Profile" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                    <StackPanel Spacing="8">
                        <Grid ColumnDefinitions="120,*">
                            <TextBlock Grid.Column="0" Text="Name" Foreground="{DynamicResource TextMuted}" FontSize="12" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding EditName}" Watermark="Work" FontSize="13"/>
                        </Grid>
                        <Grid ColumnDefinitions="120,*">
                            <TextBlock Grid.Column="0" Text="user.name" Foreground="{DynamicResource TextMuted}" FontSize="12" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding EditUserName}" Watermark="Ada Lovelace" FontSize="13"/>
                        </Grid>
                        <Grid ColumnDefinitions="120,*">
                            <TextBlock Grid.Column="0" Text="user.email" Foreground="{DynamicResource TextMuted}" FontSize="12" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding EditUserEmail}" Watermark="ada@example.com" FontSize="13"/>
                        </Grid>
                        <Grid ColumnDefinitions="120,*">
                            <TextBlock Grid.Column="0" Text="Sign commits" Foreground="{DynamicResource TextMuted}" FontSize="12" VerticalAlignment="Center"/>
                            <CheckBox Grid.Column="1" IsChecked="{Binding EditSignCommits}"/>
                        </Grid>
                        <Grid ColumnDefinitions="120,*" IsVisible="{Binding EditSignCommits}">
                            <TextBlock Grid.Column="0" Text="Signing key" Foreground="{DynamicResource TextMuted}" FontSize="12" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding EditSigningKey}" Watermark="key id or ~/.ssh/id_ed25519.pub" FontSize="13"/>
                        </Grid>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                        <Button Content="Cancel" Classes="Secondary" Padding="15,6" Command="{Binding CancelEditCommand}"/>
                        <Button Content="Save" Classes="Success" Padding="15,6" Command="{Binding SaveCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Footer + messages -->
            <StackPanel Grid.Row="4" Spacing="8" Margin="0,15,0,0">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource DangerBrush}" TextWrapping="Wrap" FontSize="12"
                           IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource SuccessBrush}" TextWrapping="Wrap" FontSize="12"
                           IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <Button Grid.Column="0" Content="New profile" Classes="Accent" Padding="15,6" Command="{Binding NewCommand}"/>
                    <Button Grid.Column="2" Content="Close" Classes="Secondary" Padding="15,6" Command="{Binding CloseCommand}"/>
                </Grid>
            </StackPanel>
        </Grid>
    </Border>
</Window>
