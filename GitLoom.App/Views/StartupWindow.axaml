<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GitLoom.App.ViewModels"
        x:Class="GitLoom.App.Views.StartupWindow"
        x:DataType="vm:StartupWindowViewModel"
        x:Name="Root"
        Icon="/Assets/avalonia-logo.ico"
        Title="Starting Mainguard"
        Width="640" Height="560"
        MinWidth="560" MinHeight="480"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource SurfaceWindow}"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1">

    <Grid Margin="{Binding #Root.OffScreenMargin}">
        <Grid RowDefinitions="Auto,*">

            <!-- Draggable brand bar (no window controls: startup is uninterruptible until updates finish). -->
            <Border Grid.Row="0" Background="{DynamicResource SurfacePanel}"
                    BorderBrush="{DynamicResource BorderHairline}" BorderThickness="0,0,0,1"
                    Padding="12,0,8,0" MinHeight="44"
                    PointerPressed="TitleBar_PointerPressed">
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <PathIcon Data="{StaticResource CloudIcon}" Width="16" Height="16"
                              Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="Mainguard" FontWeight="SemiBold" FontSize="13"
                               Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid HorizontalAlignment="Center" MaxWidth="480" Margin="32,28">

                    <!-- LOADING: checklist + changing status line -->
                    <StackPanel Spacing="18" IsVisible="{Binding !IsUpgrading}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <PathIcon Classes="spinning" Data="{StaticResource RefreshIcon}" Width="22" Height="22"
                                      Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="Getting Mainguard ready" FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock FontSize="13" TextWrapping="Wrap" Foreground="{DynamicResource TextMuted}"
                                   Text="Mainguard is waking its isolated environment and applying updates before you start — this keeps agents off a half-restarted daemon."/>

                        <ItemsControl ItemsSource="{Binding Stages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:BootstrapStageViewModel">
                                    <Border Classes="Card" Background="{DynamicResource SurfaceCard}"
                                            CornerRadius="8" Padding="12" Margin="0,0,0,8">
                                        <Grid ColumnDefinitions="Auto,*">
                                            <!-- State glyph (distinct icon per state — never colour alone) -->
                                            <Panel Grid.Column="0" Width="22" Height="22" Margin="0,0,12,0"
                                                   VerticalAlignment="Top">
                                                <PathIcon Data="{StaticResource AgentWorkingIcon}" Width="12" Height="12"
                                                          Foreground="{DynamicResource TextMuted}"
                                                          IsVisible="{Binding IsPending}"/>
                                                <PathIcon Classes="spinning" Data="{StaticResource RefreshIcon}"
                                                          Width="18" Height="18"
                                                          Foreground="{DynamicResource AccentBrush}"
                                                          IsVisible="{Binding IsRunning}"/>
                                                <PathIcon Data="{StaticResource CheckmarkIcon}" Width="18" Height="18"
                                                          Foreground="{DynamicResource SuccessBrush}"
                                                          IsVisible="{Binding IsDone}"/>
                                                <PathIcon Data="{StaticResource DismissIcon}" Width="18" Height="18"
                                                          Foreground="{DynamicResource DangerBrush}"
                                                          IsVisible="{Binding IsFailed}"/>
                                            </Panel>
                                            <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"
                                                           Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding LogTail}" FontSize="11" Classes="Mono"
                                                           Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"
                                                           IsVisible="{Binding HasLog}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- One-line changing status text (danger tint once degraded — never colour alone: warning glyph) -->
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <PathIcon Data="{StaticResource WarningIcon}" Width="14" Height="14"
                                      Foreground="{DynamicResource DangerBrush}" VerticalAlignment="Center"
                                      IsVisible="{Binding IsDegraded}"/>
                            <TextBlock Text="{Binding StatusText}" FontSize="12" TextWrapping="Wrap"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextMuted}"
                                       Classes.degraded="{Binding IsDegraded}">
                                <TextBlock.Styles>
                                    <Style Selector="TextBlock.degraded">
                                        <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                                    </Style>
                                </TextBlock.Styles>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>

                    <!-- TIER-2 OS UPGRADE (consent + progress) hosted inline. IsVisible resolves against
                         the StartupWindowViewModel (outer); the inner subtree rebinds to PendingUpgrade. -->
                    <StackPanel IsVisible="{Binding IsUpgrading}">
                    <StackPanel Spacing="12" x:CompileBindings="False" DataContext="{Binding PendingUpgrade}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <PathIcon Data="{StaticResource CloudIcon}" Width="20" Height="20"
                                      Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="A Mainguard OS update is available" FontSize="18" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border CornerRadius="999" Background="{DynamicResource AccentSelection}" Padding="8,1">
                                <TextBlock Classes="Mono" FontSize="10" Foreground="{DynamicResource AccentBrush}"
                                           Text="{Binding InstalledVersion, StringFormat='installed {0}'}"/>
                            </Border>
                            <PathIcon Data="{StaticResource ChevronRightIcon}" Width="10" Height="10"
                                      Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                            <Border CornerRadius="999" Background="{DynamicResource AccentSelection}" Padding="8,1">
                                <TextBlock Classes="Mono" FontSize="10" Foreground="{DynamicResource AccentBrush}"
                                           Text="{Binding ExpectedVersion, StringFormat='new {0}'}"/>
                            </Border>
                        </StackPanel>

                        <!-- Consent copy (offer state) -->
                        <Border Classes="Card" Background="{DynamicResource SurfaceCard}" CornerRadius="8"
                                Padding="14" IsVisible="{Binding IsOffering}">
                            <StackPanel Spacing="8">
                                <TextBlock FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource TextPrimary}"
                                           Text="This update replaces the Mainguard environment (the isolated WSL2 system your agents run in) with a newer, security-patched build. It takes a few minutes."/>
                                <TextBlock FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource TextMuted}"
                                           Text="Your provisioned repositories, worktrees, installed agent CLIs, and budget history are migrated and verified before the old environment is removed — if anything can't be verified, the update stops and nothing is lost. Your own WSL distros are untouched."/>
                            </StackPanel>
                        </Border>

                        <!-- Step checklist (visible once the run starts) -->
                        <ItemsControl ItemsSource="{Binding Steps}" IsVisible="{Binding !IsOffering}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Classes="Card" Background="{DynamicResource SurfaceCard}"
                                            CornerRadius="8" Padding="12" Margin="0,0,0,8">
                                        <Grid ColumnDefinitions="Auto,*">
                                            <Panel Grid.Column="0" Width="22" Height="22" Margin="0,0,12,0"
                                                   VerticalAlignment="Top">
                                                <PathIcon Data="{StaticResource AgentWorkingIcon}" Width="12" Height="12"
                                                          Foreground="{DynamicResource TextMuted}"
                                                          IsVisible="{Binding IsPending}"/>
                                                <PathIcon Classes="spinning" Data="{StaticResource RefreshIcon}"
                                                          Width="18" Height="18"
                                                          Foreground="{DynamicResource AccentBrush}"
                                                          IsVisible="{Binding IsRunning}"/>
                                                <PathIcon Data="{StaticResource CheckmarkIcon}" Width="18" Height="18"
                                                          Foreground="{DynamicResource SuccessBrush}"
                                                          IsVisible="{Binding IsDone}"/>
                                                <PathIcon Data="{StaticResource DismissIcon}" Width="18" Height="18"
                                                          Foreground="{DynamicResource DangerBrush}"
                                                          IsVisible="{Binding IsFailed}"/>
                                            </Panel>
                                            <StackPanel Grid.Column="1" Spacing="3">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"
                                                           Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding LogTail}" FontSize="11" Classes="Mono"
                                                           Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"
                                                           IsVisible="{Binding HasLog}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Success -->
                        <Border Classes="Card" Background="{DynamicResource SurfaceCard}" CornerRadius="8"
                                Padding="14" IsVisible="{Binding IsComplete}">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <PathIcon Data="{StaticResource CheckmarkIcon}" Width="16" Height="16"
                                          Foreground="{DynamicResource SuccessBrush}" VerticalAlignment="Top"/>
                                <TextBlock FontSize="12" TextWrapping="Wrap" MaxWidth="380"
                                           Foreground="{DynamicResource TextPrimary}"
                                           Text="Mainguard OS is up to date. Reconnecting to the upgraded environment…"/>
                            </StackPanel>
                        </Border>

                        <!-- Failure (typed, actionable) -->
                        <Border Classes="Card" Background="{DynamicResource SurfaceCard}" CornerRadius="8"
                                Padding="14" IsVisible="{Binding HasError}">
                            <StackPanel Spacing="10">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource WarningIcon}" Width="16" Height="16"
                                              Foreground="{DynamicResource DangerBrush}" VerticalAlignment="Top"/>
                                    <TextBlock Text="{Binding ErrorMessage}" FontSize="12" MaxWidth="380"
                                               Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap"/>
                                </StackPanel>
                                <SelectableTextBlock Text="{Binding StrandedVhdxPath}" FontSize="11" Classes="Mono"
                                                     Foreground="{DynamicResource DangerBrush}" TextWrapping="Wrap"
                                                     IsVisible="{Binding IsStranded}"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Margin="0,4,0,0" FontSize="11" TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextMuted}" IsVisible="{Binding IsRunning}"
                                   Text="Upgrading — please keep Mainguard open. The environment restarts once at the end."/>

                        <!-- Actions -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,8,0,0">
                            <Button Content="Later" Classes="Secondary" Padding="15,6"
                                    IsVisible="{Binding IsOffering}" Command="{Binding LaterCommand}"/>
                            <Button Content="Upgrade now" Classes="Primary" Padding="15,6"
                                    IsVisible="{Binding IsOffering}" Command="{Binding UpgradeCommand}"/>
                            <Button Content="Continue" Classes="Secondary" Padding="15,6"
                                    IsVisible="{Binding !IsOffering}" IsEnabled="{Binding !IsRunning}"
                                    Command="{Binding CloseCommand}"/>
                        </StackPanel>
                    </StackPanel>
                    </StackPanel>

                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
