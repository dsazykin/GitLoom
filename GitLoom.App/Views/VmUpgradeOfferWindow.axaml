<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GitLoom.App.ViewModels"
        x:Class="GitLoom.App.Views.VmUpgradeOfferWindow"
        x:DataType="vm:VmUpgradeOfferViewModel"
        Title="GitLoom OS update"
        Width="560" Height="560"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SurfaceWindow}">
    <Border Padding="24">
        <Grid RowDefinitions="Auto,Auto,*,Auto,Auto">

            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="0,0,0,6">
                <PathIcon Data="{StaticResource CloudIcon}" Width="20" Height="20"
                          Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                <TextBlock Text="A GitLoom OS update is available" FontSize="18" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Version line: installed → bundled -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
                <Border CornerRadius="999" Background="{DynamicResource AccentSelection}" Padding="8,1">
                    <TextBlock Classes="Mono" FontSize="10" Foreground="{DynamicResource AccentBrush}"
                               Text="{Binding InstalledVersion, StringFormat='installed {0}'}"/>
                </Border>
                <PathIcon Data="{StaticResource ChevronRightIcon}" Width="10" Height="10"
                          Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                <Border CornerRadius="999" Background="{DynamicResource AccentSelection}" Padding="8,1">
                    <TextBlock Classes="Mono" FontSize="10" Foreground="{DynamicResource AccentBrush}"
                               Text="{Binding ExpectedVersion, StringFormat='new {0}'}"/>
                </Border>
            </StackPanel>

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="8">

                    <!-- Consent copy (offer state) -->
                    <Border Classes="Card" Background="{DynamicResource SurfaceCard}" CornerRadius="8"
                            Padding="14" IsVisible="{Binding IsOffering}">
                        <StackPanel Spacing="8">
                            <TextBlock FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource TextPrimary}"
                                       Text="This update replaces the GitLoom environment (the isolated WSL2 system your agents run in) with a newer, security-patched build. It takes a few minutes."/>
                            <TextBlock FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource TextMuted}"
                                       Text="Your provisioned repositories, worktrees, installed agent CLIs, and budget history are migrated and verified before the old environment is removed — if anything can't be verified, the update stops and nothing is lost. Agents can't run while the update is in progress. Your own WSL distros are untouched."/>
                        </StackPanel>
                    </Border>

                    <!-- Step checklist (visible once the run starts) -->
                    <ItemsControl ItemsSource="{Binding Steps}" IsVisible="{Binding !IsOffering}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:BootstrapStageViewModel">
                                <Border Classes="Card" Background="{DynamicResource SurfaceCard}"
                                        CornerRadius="8" Padding="12" Margin="0,0,0,8">
                                    <Grid ColumnDefinitions="Auto,*">
                                        <!-- State glyph (distinct icon per state — never colour alone) -->
                                        <Panel Grid.Column="0" Width="22" Height="22" Margin="0,0,12,0"
                                               VerticalAlignment="Top">
                                            <PathIcon Data="{StaticResource AgentWorkingIcon}" Width="12" Height="12"
                                                      Foreground="{DynamicResource TextMuted}"
                                                      IsVisible="{Binding IsPending}"/>
                                            <PathIcon Classes="spinning" Data="{StaticResource RefreshIcon}" Width="18" Height="18"
                                                      Foreground="{DynamicResource AccentBrush}"
                                                      IsVisible="{Binding IsRunning}"/>
                                            <PathIcon Data="{StaticResource CheckmarkIcon}" Width="18" Height="18"
                                                      Foreground="{DynamicResource SuccessBrush}"
                                                      IsVisible="{Binding IsDone}"/>
                                            <PathIcon Data="{StaticResource DismissIcon}" Width="18" Height="18"
                                                      Foreground="{DynamicResource DangerBrush}"
                                                      IsVisible="{Binding IsFailed}"/>
                                        </Panel>
                                        <StackPanel Grid.Column="1" Spacing="3">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"
                                                       Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding LogTail}" FontSize="11" Classes="Mono"
                                                       Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"
                                                       IsVisible="{Binding HasLog}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Success -->
                    <Border Classes="Card" Background="{DynamicResource SurfaceCard}" CornerRadius="8"
                            Padding="14" IsVisible="{Binding IsComplete}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <PathIcon Data="{StaticResource CheckmarkIcon}" Width="16" Height="16"
                                      Foreground="{DynamicResource SuccessBrush}" VerticalAlignment="Top"/>
                            <TextBlock FontSize="12" TextWrapping="Wrap" MaxWidth="440"
                                       Foreground="{DynamicResource TextPrimary}"
                                       Text="GitLoom OS is up to date. Your repositories, worktrees, and budget history came along; the GitLoom daemon is starting on the upgraded environment."/>
                        </StackPanel>
                    </Border>

                    <!-- Failure (typed, actionable) -->
                    <Border Classes="Card" Background="{DynamicResource SurfaceCard}" CornerRadius="8"
                            Padding="14" IsVisible="{Binding HasError}">
                        <StackPanel Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <PathIcon Data="{StaticResource WarningIcon}" Width="16" Height="16"
                                          Foreground="{DynamicResource DangerBrush}" VerticalAlignment="Top"/>
                                <TextBlock Text="{Binding ErrorMessage}" FontSize="12" MaxWidth="440"
                                           Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap"/>
                            </StackPanel>
                            <!-- Stranded recovery: the VHDX path, selectable for copy/support -->
                            <SelectableTextBlock Text="{Binding StrandedVhdxPath}" FontSize="11" Classes="Mono"
                                                 Foreground="{DynamicResource DangerBrush}" TextWrapping="Wrap"
                                                 IsVisible="{Binding IsStranded}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Running note -->
            <TextBlock Grid.Row="3" Margin="0,10,0,0" FontSize="11" TextWrapping="Wrap"
                       Foreground="{DynamicResource TextMuted}" IsVisible="{Binding IsRunning}"
                       Text="Upgrading — please keep GitLoom open. The environment restarts once at the end."/>

            <!-- Actions -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right"
                        Spacing="10" Margin="0,16,0,0">
                <Button Content="Later" Classes="Secondary" Padding="15,6"
                        IsVisible="{Binding IsOffering}" Command="{Binding LaterCommand}"/>
                <Button Content="Upgrade now" Classes="Primary" Padding="15,6"
                        IsVisible="{Binding IsOffering}" Command="{Binding UpgradeCommand}"/>
                <Button Content="Close" Classes="Secondary" Padding="15,6"
                        IsVisible="{Binding !IsOffering}" IsEnabled="{Binding !IsRunning}"
                        Command="{Binding CloseCommand}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
