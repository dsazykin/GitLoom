<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GitLoom.App.ViewModels"
             xmlns:models="using:GitLoom.Core.Models"
             xmlns:AvaloniaEdit="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
             x:Class="GitLoom.App.Views.DiffViewerView"
             x:DataType="vm:DiffViewerViewModel">
    
    <UserControl.Styles>
        <Style Selector="Border.IsAdded">
            <Setter Property="Background" Value="#1A3A22"/>
        </Style>
        <Style Selector="Border.IsRemoved">
            <Setter Property="Background" Value="#4D1D22"/>
        </Style>
        <Style Selector="Border.IsHeader">
            <Setter Property="Background" Value="#252526"/>
        </Style>
    </UserControl.Styles>

    <Grid Background="{StaticResource BgWindow}" RowDefinitions="Auto, *">

        <!-- View Toggle Buttons -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10" Spacing="5">
            <ToggleButton Content="Side-by-Side Diff" IsChecked="{Binding IsSideBySideView}"
                          Background="{StaticResource ButtonBg}" Foreground="{StaticResource TextPrimary}"
                          BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1" CornerRadius="4" Padding="12,6"/>
            <ToggleButton Content="Code Editor" IsChecked="{Binding IsEditMode}"
                          Background="{StaticResource ButtonBg}" Foreground="{StaticResource TextPrimary}"
                          BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1" CornerRadius="4" Padding="12,6"/>
            <Button Content="Save File" Command="{Binding SaveFileCommand}" IsVisible="{Binding IsEditMode}"
                    Classes="Primary" Padding="12,6"/>
        </StackPanel>

        <!-- UNIFIED VIEW -->
        <ScrollViewer Grid.Row="1" IsVisible="{Binding ShowUnified}">
            <ItemsControl ItemsSource="{Binding DiffLines}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:GitDiffLine">
                        <Border Classes.IsAdded="{Binding IsAdded}"
                                Classes.IsRemoved="{Binding IsRemoved}"
                                Classes.IsHeader="{Binding IsHeader}">
                            <TextBlock Text="{Binding Content}" FontFamily="Consolas, Courier New, Monospace" FontSize="13" Foreground="{StaticResource TextPrimary}" Margin="10,0" LineHeight="20"/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- SIDE-BY-SIDE VIEW -->
        <ScrollViewer Grid.Row="1" IsVisible="{Binding ShowSideBySide}">
            <ItemsControl ItemsSource="{Binding SideBySideLines}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:SideBySideDiffRow">
                        <Grid ColumnDefinitions="*, *">

                            <!-- Left Column (Deletions) -->
                            <Border Grid.Column="0" Classes.IsRemoved="{Binding LeftLine.IsRemoved}" Classes.IsHeader="{Binding LeftLine.IsHeader}">
                                <TextBlock Text="{Binding LeftLine.Content}" FontFamily="Consolas, Courier New, Monospace" FontSize="13" Foreground="{StaticResource TextPrimary}" Margin="10,0" LineHeight="20"/>
                            </Border>

                            <!-- Right Column (Additions) -->
                            <Border Grid.Column="1" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1,0,0,0"
                                    Classes.IsAdded="{Binding RightLine.IsAdded}" Classes.IsHeader="{Binding RightLine.IsHeader}">
                                <TextBlock Text="{Binding RightLine.Content}" FontFamily="Consolas, Courier New, Monospace" FontSize="13" Foreground="{StaticResource TextPrimary}" Margin="10,0" LineHeight="20"/>
                            </Border>

                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- EDIT VIEW -->
        <Grid Grid.Row="1" IsVisible="{Binding IsEditMode}" RowDefinitions="Auto, *">
            
            <!-- CONFLICT RESOLUTION BAR -->
            <Border Grid.Row="0" Background="{StaticResource BgSidebar}" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,0,1"
                    IsVisible="{Binding HasConflicts}" Padding="15,10">
                <Grid ColumnDefinitions="*, Auto">
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock Text="⚠️ Merge Conflicts Detected:" Foreground="{StaticResource BranchRed}" FontWeight="Bold" />
                        <TextBlock Text="{Binding ConflictCount, StringFormat='\{0\} remaining'}" Foreground="{StaticResource TextMuted}" />
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                        <Button Content="Accept Current" Classes="Secondary" Command="{Binding AcceptOursCommand}" />
                        <Button Content="Accept Incoming" Classes="Secondary" Command="{Binding AcceptTheirsCommand}" />
                        <Button Content="Accept Both" Classes="Secondary" Command="{Binding AcceptBothCommand}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- AVALONIA EDIT TEXT EDITOR -->
            <AvaloniaEdit:TextEditor Grid.Row="1" 
                                     x:Name="Editor"
                                     ShowLineNumbers="True"
                                     Background="{StaticResource BgObsidian}"
                                     Foreground="{StaticResource TextPrimary}"
                                     FontFamily="Consolas, Courier New, Monospace" />
        </Grid>
    </Grid>
</UserControl>
