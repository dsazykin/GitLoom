<views:ChromedWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GitLoom.App.ViewModels"
        xmlns:views="using:GitLoom.App.Views"
        xmlns:controls="clr-namespace:GitLoom.App.Controls"
        x:Class="GitLoom.App.Views.ChecksWindow"
        x:DataType="vm:ChecksViewModel"
        Title="CI Checks"
        Width="640" Height="560"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SurfaceWindow}">
    <Grid RowDefinitions="Auto,*">
    <controls:CustomTitleBar Grid.Row="0"/>
    <Border Grid.Row="1" Padding="20">
        <Grid RowDefinitions="Auto,Auto,*,Auto,Auto">

            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="0,0,0,15">
                <PathIcon Data="{StaticResource ChecksIcon}" Width="18" Height="18" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                <TextBlock Text="CI Checks" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding ShortSha, StringFormat='commit {0}'}" Classes="Mono" FontSize="12" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" Margin="6,3,0,0"/>
            </StackPanel>

            <!-- Overall badge (hidden when the commit has no checks) + refresh -->
            <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="0,0,0,12" IsVisible="{Binding IsSupported}">
                <Border Grid.Column="0" Classes="Card" Background="{DynamicResource SurfaceCard}" Padding="12,8" CornerRadius="8"
                        HorizontalAlignment="Left" IsVisible="{Binding Badge.IsVisible}">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <!-- State glyph — one token-colored glyph per state -->
                        <TextBlock Text="{Binding Badge.GlyphText}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"
                                   Foreground="{DynamicResource SuccessBrush}" IsVisible="{Binding Badge.IsSuccess}"/>
                        <TextBlock Text="{Binding Badge.GlyphText}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"
                                   Foreground="{DynamicResource DangerBrush}" IsVisible="{Binding Badge.IsFailure}"/>
                        <TextBlock Text="{Binding Badge.GlyphText}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"
                                   Foreground="{DynamicResource WarningBrush}" IsVisible="{Binding Badge.IsPending}"/>
                        <StackPanel VerticalAlignment="Center" Spacing="1">
                            <TextBlock Text="{Binding Badge.SummaryText}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="{Binding Badge.CountsText}" FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Button Grid.Column="1" Classes="IconButton" Command="{Binding RefreshCommand}" ToolTip.Tip="Refresh"
                        VerticalAlignment="Center" Background="{DynamicResource SurfaceHoverGhost}">
                    <PathIcon Data="{StaticResource RefreshIcon}" Width="14" Height="14" Foreground="{DynamicResource TextMuted}"/>
                </Button>
            </Grid>

            <!-- Body -->
            <Grid Grid.Row="2">

                <!-- Unsupported / no-token affordance -->
                <StackPanel Spacing="12" VerticalAlignment="Top" IsVisible="{Binding !IsSupported}">
                    <Border Classes="Card" Background="{DynamicResource SurfaceCard}" Padding="18" CornerRadius="8">
                        <StackPanel Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="{StaticResource CloudIcon}" Width="16" Height="16" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                                <TextBlock Text="Not connected" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{Binding UnsupportedHint}" FontSize="12" Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Supported: run list -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" IsVisible="{Binding IsSupported}">
                    <StackPanel Spacing="6">
                        <ItemsControl ItemsSource="{Binding Runs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:CheckRunRowViewModel">
                                    <Border Classes="Card" Background="{DynamicResource SurfaceCard}" Padding="12" Margin="0,0,0,2" CornerRadius="8">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <!-- State icon — one token-colored glyph per state -->
                                            <Panel Grid.Column="0" Width="22" VerticalAlignment="Center">
                                                <TextBlock Text="✓" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}" IsVisible="{Binding IsSuccess}"/>
                                                <TextBlock Text="✕" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource DangerBrush}" IsVisible="{Binding IsFailure}"/>
                                                <TextBlock Text="•" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource WarningBrush}" IsVisible="{Binding IsPending}"/>
                                                <TextBlock Text="–" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" IsVisible="{Binding IsNeutral}"/>
                                            </Panel>

                                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center" Margin="4,0,0,0">
                                                <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap"/>
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="{Binding StateText}" FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                                                    <TextBlock Text="{Binding WhenText}" FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                <Button Content="View logs" Classes="Secondary" Padding="12,4"
                                                        Command="{Binding OpenLogsCommand}" IsVisible="{Binding HasUrl}"
                                                        ToolTip.Tip="Open this check's logs in the browser"/>
                                                <Button Content="Re-run" Classes="Primary" Padding="12,4"
                                                        Command="{Binding RerunCommand}" IsVisible="{Binding CanRerun}"
                                                        ToolTip.Tip="Re-request this check run"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="This commit has no CI checks."
                                   Foreground="{DynamicResource TextMuted}" FontSize="12"
                                   IsVisible="{Binding IsEmpty}" Margin="4,8" TextWrapping="Wrap"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Error -->
            <TextBlock Grid.Row="3" Text="{Binding ErrorMessage}" Foreground="{DynamicResource DangerBrush}"
                       TextWrapping="Wrap" Margin="0,10,0,0" FontSize="12"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

            <!-- Footer -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                <Button Content="Close" Classes="Secondary" Padding="15,6" Command="{Binding CloseCommand}"/>
            </StackPanel>
        </Grid>
    </Border>
    </Grid>
</views:ChromedWindow>
