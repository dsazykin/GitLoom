<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GitLoom.App.ViewModels"
        x:Class="GitLoom.App.Views.SubmodulesWindow"
        x:DataType="vm:SubmodulesViewModel"
        Title="Submodules"
        Width="620" Height="520"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SurfaceWindow}">
    <Border Padding="20">
        <Grid RowDefinitions="Auto,*,Auto,Auto">

            <!-- Header -->
            <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,15">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                    <PathIcon Data="{StaticResource SubmoduleIcon}" Width="18" Height="18" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="Submodules" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Grid.Column="2" Classes="IconButton" Command="{Binding RefreshCommand}" ToolTip.Tip="Refresh">
                    <PathIcon Data="{StaticResource RefreshIcon}" Width="14" Height="14" Foreground="{DynamicResource TextMuted}"/>
                </Button>
            </Grid>

            <!-- Submodule list -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="10">
                    <ItemsControl ItemsSource="{Binding Submodules}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:SubmoduleRowViewModel">
                                <Border Classes="Card" Background="{DynamicResource SurfaceCard}" Padding="12" Margin="0,0,0,2" CornerRadius="8">
                                    <StackPanel Spacing="8">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                <PathIcon Data="{StaticResource FolderIcon}" Width="14" Height="14" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Path}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" FontSize="13" VerticalAlignment="Center"/>
                                                <TextBlock Classes="Mono" Text="{Binding ShortSha}" Foreground="{DynamicResource TextMuted}" FontSize="11" VerticalAlignment="Center"/>
                                            </StackPanel>

                                            <!-- Status chip: one per state, DynamicResource tokens follow theme switches -->
                                            <Panel Grid.Column="1">
                                                <Border CornerRadius="999" Padding="8,2" Background="{DynamicResource SuccessBrush}" IsVisible="{Binding IsUpToDate}">
                                                    <TextBlock Text="{Binding StatusLabel}" Foreground="{DynamicResource OnAccent}" FontSize="10"/>
                                                </Border>
                                                <Border CornerRadius="999" Padding="8,2" Background="{DynamicResource WarningBrush}" IsVisible="{Binding IsModified}">
                                                    <TextBlock Text="{Binding StatusLabel}" Foreground="{DynamicResource OnAccent}" FontSize="10"/>
                                                </Border>
                                                <Border CornerRadius="999" Padding="8,2" Background="{DynamicResource DangerBrush}" IsVisible="{Binding IsDirty}">
                                                    <TextBlock Text="{Binding StatusLabel}" Foreground="{DynamicResource OnAccent}" FontSize="10"/>
                                                </Border>
                                                <Border CornerRadius="999" Padding="8,2" Background="{DynamicResource ButtonBg}" IsVisible="{Binding IsUninitialized}">
                                                    <TextBlock Text="{Binding StatusLabel}" Foreground="{DynamicResource TextMuted}" FontSize="10"/>
                                                </Border>
                                            </Panel>
                                        </Grid>

                                        <TextBlock Classes="Mono" Text="{Binding Url}" Foreground="{DynamicResource TextMuted}" FontSize="11" TextTrimming="CharacterEllipsis"/>

                                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                            <Button Content="Update to remote" Classes="Primary" Padding="12,4" Command="{Binding UpdateRemoteCommand}"/>
                                            <Button Content="Open as repo" Classes="Secondary" Padding="12,4"
                                                    Command="{Binding OpenAsRepoCommand}" IsVisible="{Binding CanOpen}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel IsVisible="{Binding IsEmpty}" Spacing="8" Margin="4,24" HorizontalAlignment="Center">
                        <PathIcon Data="{StaticResource SubmoduleIcon}" Width="48" Height="48" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center" Opacity="0.5"/>
                        <TextBlock Text="This repository has no submodules." Foreground="{DynamicResource TextMuted}" FontSize="13" HorizontalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Error -->
            <TextBlock Grid.Row="2" Text="{Binding ErrorMessage}" Foreground="{DynamicResource DangerBrush}"
                       TextWrapping="Wrap" Margin="0,10,0,0" FontSize="12"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

            <!-- Footer -->
            <Grid Grid.Row="3" ColumnDefinitions="Auto,*,Auto" Margin="0,15,0,0">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                    <Button Content="Update all (init)" Classes="Accent" Padding="15,6" Command="{Binding UpdateAllCommand}" IsEnabled="{Binding !IsBusy}"/>
                    <Button Content="Sync URLs" Classes="Primary" Padding="15,6" Command="{Binding SyncCommand}" IsEnabled="{Binding !IsBusy}"/>
                </StackPanel>
                <Button Grid.Column="2" Content="Close" Classes="Secondary" Padding="15,6" Command="{Binding CloseCommand}"/>
            </Grid>
        </Grid>
    </Border>
</Window>
