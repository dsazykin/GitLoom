<views:ChromedWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GitLoom.App.ViewModels"
        xmlns:views="using:GitLoom.App.Views"
        xmlns:controls="clr-namespace:GitLoom.App.Controls"
        x:Class="GitLoom.App.Views.CreateTagDialog"
        x:DataType="vm:CreateTagDialogViewModel"
        Title="Create Tag"
        Width="400" SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SurfaceWindow}">
    <Grid RowDefinitions="Auto,*">
    <controls:CustomTitleBar Grid.Row="0"/>
    <Border Grid.Row="1" Padding="20">
        <StackPanel Spacing="15">
            <TextBlock Text="Create Tag" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" />

            <StackPanel Spacing="5">
                <TextBlock Text="Target commit:" Foreground="{DynamicResource TextMuted}" FontSize="12" />
                <TextBlock Classes="Mono" Text="{Binding TargetShortSha}" Foreground="{DynamicResource AccentBrush}" FontSize="12" />
            </StackPanel>

            <TextBlock Text="Tag Name:" Foreground="{DynamicResource TextMuted}" />
            <TextBox Text="{Binding TagName, UpdateSourceTrigger=PropertyChanged}" Watermark="e.g. v1.0.0" />
            <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource DangerBrush}" IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

            <CheckBox Content="Annotated (with message)" IsChecked="{Binding IsAnnotated}" Foreground="{DynamicResource TextPrimary}" />
            <TextBox Text="{Binding Message, UpdateSourceTrigger=PropertyChanged}" Watermark="Tag message"
                     AcceptsReturn="True" MinHeight="60" TextWrapping="Wrap"
                     IsVisible="{Binding IsAnnotated}" />

            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="Cancel" Classes="Secondary" Command="{Binding CancelCommand}" />
                <Button Content="Create" Classes="Accent" Command="{Binding ConfirmCommand}" />
            </StackPanel>
        </StackPanel>
    </Border>
    </Grid>
</views:ChromedWindow>
