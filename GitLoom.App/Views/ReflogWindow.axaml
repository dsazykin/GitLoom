<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GitLoom.App.ViewModels"
        x:Class="GitLoom.App.Views.ReflogWindow"
        x:DataType="vm:ReflogViewModel"
        Title="Reflog"
        Width="680" Height="560"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SurfaceWindow}">
    <Border Padding="20">
        <Grid RowDefinitions="Auto,Auto,*,Auto,Auto">

            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="0,0,0,15">
                <PathIcon Data="{StaticResource HistoryIcon}" Width="18" Height="18" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                <TextBlock Text="Reflog" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                <TextBlock Text="Where a ref has pointed — restore or recover a lost commit" FontSize="12" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" Margin="6,3,0,0"/>
            </StackPanel>

            <!-- Ref picker -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="10" Margin="0,0,0,12" VerticalAlignment="Center">
                <TextBlock Text="Ref" FontSize="12" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                <ComboBox ItemsSource="{Binding RefNames}" SelectedItem="{Binding SelectedRef}" MinWidth="220" FontSize="13"/>
                <Button Classes="IconButton" Command="{Binding RefreshCommand}" ToolTip.Tip="Refresh"
                        Background="{DynamicResource SurfaceHoverGhost}">
                    <PathIcon Data="{StaticResource RefreshIcon}" Width="14" Height="14" Foreground="{DynamicResource TextMuted}"/>
                </Button>
            </StackPanel>

            <!-- Reflog list -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="8">
                    <ItemsControl ItemsSource="{Binding Entries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:ReflogRowViewModel">
                                <Border Classes="Card" Background="{DynamicResource SurfaceCard}" Padding="12" Margin="0,0,0,2" CornerRadius="8">
                                    <StackPanel Spacing="8">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Classes="Mono" Text="{Binding MoveText}" FontSize="12" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding When}" FontSize="10" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Message}" FontSize="12" Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                <Button Content="Create branch here" Classes="Primary" Padding="12,4"
                                                        Command="{Binding BeginCreateBranchCommand}"
                                                        IsVisible="{Binding !IsCreatingBranch}"
                                                        ToolTip.Tip="Recover this tip onto a new branch"/>
                                                <Button Content="Restore" Classes="Danger" Padding="12,4"
                                                        Command="{Binding RestoreCommand}"
                                                        ToolTip.Tip="Hard-reset the current branch to this entry"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Inline "create branch here" editor -->
                                        <Grid ColumnDefinitions="*,Auto,Auto" IsVisible="{Binding IsCreatingBranch}">
                                            <TextBox Grid.Column="0" Text="{Binding NewBranchName}" Watermark="new-branch-name" FontSize="13" Margin="0,0,8,0"/>
                                            <Button Grid.Column="1" Content="Create" Classes="Success" Padding="12,4" Command="{Binding CreateBranchHereCommand}" Margin="0,0,8,0"/>
                                            <Button Grid.Column="2" Content="Cancel" Classes="Secondary" Padding="12,4" Command="{Binding CancelCreateBranchCommand}"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="No reflog entries for this ref yet. Commit, reset, or check out to see where it moves."
                               Foreground="{DynamicResource TextMuted}" FontSize="12"
                               IsVisible="{Binding IsEmpty}" Margin="4,8" TextWrapping="Wrap"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Error -->
            <TextBlock Grid.Row="3" Text="{Binding ErrorMessage}" Foreground="{DynamicResource DangerBrush}"
                       TextWrapping="Wrap" Margin="0,10,0,0" FontSize="12"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

            <!-- Footer -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                <Button Content="Close" Classes="Secondary" Padding="15,6" Command="{Binding CloseCommand}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
