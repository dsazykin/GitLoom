<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GitLoom.App.ViewModels"
        x:Class="GitLoom.App.Views.RemotesWindow"
        x:DataType="vm:RemotesViewModel"
        Title="Manage Remotes"
        Width="560" Height="480"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SurfaceWindow}">
    <Border Padding="20">
        <Grid RowDefinitions="Auto,*,Auto,Auto,Auto">

            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="0,0,0,15">
                <PathIcon Data="{StaticResource CloudIcon}" Width="18" Height="18" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                <TextBlock Text="Remotes" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Existing remotes -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="10">
                    <ItemsControl ItemsSource="{Binding Remotes}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:RemoteRowViewModel">
                                <Border Classes="Card" Background="{DynamicResource SurfaceCard}" Padding="12" Margin="0,0,0,2" CornerRadius="8">
                                    <StackPanel Spacing="8">
                                        <Grid ColumnDefinitions="90,*">
                                            <TextBlock Grid.Column="0" Text="Name" Foreground="{DynamicResource TextMuted}" FontSize="12" VerticalAlignment="Center"/>
                                            <TextBox Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="90,*">
                                            <TextBlock Grid.Column="0" Text="URL" Foreground="{DynamicResource TextMuted}" FontSize="12" VerticalAlignment="Center"/>
                                            <TextBox Grid.Column="1" Classes="Mono" Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}"/>
                                        </Grid>
                                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                            <Button Content="Save" Classes="Primary" Padding="12,4" Command="{Binding SaveCommand}"/>
                                            <Button Content="Remove" Classes="Danger" Padding="12,4" Command="{Binding RemoveCommand}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="No remotes configured yet." Foreground="{DynamicResource TextMuted}" FontSize="12"
                               IsVisible="{Binding !Remotes.Count}" Margin="4,8"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Add remote -->
            <Border Grid.Row="2" Background="{DynamicResource SurfaceCard}" CornerRadius="8" Padding="12" Margin="0,12,0,0">
                <StackPanel Spacing="8">
                    <TextBlock Text="Add a remote" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" FontSize="13"/>
                    <Grid ColumnDefinitions="90,*">
                        <TextBlock Grid.Column="0" Text="Name" Foreground="{DynamicResource TextMuted}" FontSize="12" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Text="{Binding NewRemoteName, UpdateSourceTrigger=PropertyChanged}" Watermark="e.g. upstream"/>
                    </Grid>
                    <Grid ColumnDefinitions="90,*,Auto">
                        <TextBlock Grid.Column="0" Text="URL" Foreground="{DynamicResource TextMuted}" FontSize="12" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Classes="Mono" Text="{Binding NewRemoteUrl, UpdateSourceTrigger=PropertyChanged}" Watermark="https://github.com/owner/repo.git"/>
                        <Button Grid.Column="2" Content="Add" Classes="Accent" Padding="14,4" Margin="8,0,0,0" Command="{Binding AddRemoteCommand}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Error -->
            <TextBlock Grid.Row="3" Text="{Binding ErrorMessage}" Foreground="{DynamicResource DangerBrush}"
                       TextWrapping="Wrap" Margin="0,10,0,0" FontSize="12"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

            <!-- Footer -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                <Button Content="Close" Classes="Secondary" Padding="15,6" Command="{Binding CloseCommand}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
