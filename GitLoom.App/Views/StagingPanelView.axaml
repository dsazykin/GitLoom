<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GitLoom.App.ViewModels"
             xmlns:models="using:GitLoom.Core.Models"
             xmlns:converters="using:GitLoom.App.Converters"
             x:Class="GitLoom.App.Views.StagingPanelView"
             x:DataType="vm:StagingPanelViewModel">
    <UserControl.Resources>
        <converters:FileExtensionToIconConverter x:Key="FileExtensionToIconConverter" />
    </UserControl.Resources>
    <UserControl.Styles>
        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinHeight" Value="20" />
        </Style>

        <!-- ToggleButton Animation Styles -->
        <Style Selector="ToggleButton.StagingCategory:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource ButtonHover}" />
        </Style>
        <Style Selector="ToggleButton.StagingCategory:checked /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="ToggleButton.StagingCategory:checked:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource ButtonHover}" />
        </Style>


        <!-- (Chevron data-swap and CheckBox sizing are defined globally in App.axaml) -->

        <Style Selector="Button.TabButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
            <Setter Property="BorderThickness" Value="0,0,0,2" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding" Value="0,0,0,4" />
            <Setter Property="Margin" Value="0,0,15,0" />
            <Setter Property="FontWeight" Value="Normal" />
        </Style>
        <Style Selector="Button.TabButton.Active">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="BorderBrush" Value="{StaticResource BranchCyan}" />
        </Style>
        <!-- Staging Category Chevron Animations -->

    </UserControl.Styles>
    <Grid RowDefinitions="Auto, *">

        <!-- Toolbar / Tabs -->
        <Border Grid.Row="0" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,0,1" Padding="10,10,10,0">
            <Grid ColumnDefinitions="Auto, *, Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <!-- Commit Tab Button -->
                    <Button Classes="TabButton" Classes.Active="{Binding !IsStashTabActive}" Content="Commit"
                            Command="{Binding SwitchToCommitTabCommand}" />
                    
                    <!-- Shelf Tab Button -->
                    <Button Classes="TabButton" Classes.Active="{Binding IsStashTabActive}" Content="Shelf"
                            Command="{Binding SwitchToStashTabCommand}" />
                </StackPanel>
                
                <!-- Toolbar Icons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" Margin="0,0,0,10" VerticalAlignment="Bottom">
                    <Button ToolTip.Tip="Refresh" Command="{Binding RefreshCommand}" Background="Transparent" Padding="4">
                        <PathIcon Classes.spinning="{Binding IsRefreshing}" Data="{StaticResource RefreshIcon}" Foreground="{StaticResource TextMuted}" Width="14" Height="14">
                            <PathIcon.RenderTransform>
                                <RotateTransform/>
                            </PathIcon.RenderTransform>
                        </PathIcon>
                    </Button>
                    <Button ToolTip.Tip="Rollback Selected Files" Command="{Binding RollbackSelectedCommand}" Background="Transparent" Padding="4">
                        <PathIcon Data="{StaticResource UndoIcon}" Foreground="{StaticResource TextMuted}" Width="14" Height="14"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            
            <!-- COMMIT TAB -->
            <Grid RowDefinitions="*, 4, 180" IsVisible="{Binding !IsStashTabActive}">
                <!-- Scrollable File Lists -->
                <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- Versioned Block (CHANGES) -->
                    <StackPanel>
                        <!-- Category Header -->
                        <Border>
                            <Grid ColumnDefinitions="Auto, *">
                                <ToggleButton Classes="StagingCategory" Grid.Column="1" IsChecked="{Binding IsChangesExpanded, Mode=TwoWay}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="Transparent" BorderThickness="0" Padding="2,2" MinHeight="24">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <PathIcon Classes="Chevron" Classes.expanded="{Binding IsChangesExpanded}" Width="10" Height="10" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" />
                                        <CheckBox Margin="0,0,0,0" ToolTip.Tip="Select/Deselect All" IsThreeState="True" IsChecked="{Binding IsAllVersionedSelected, Mode=OneWay}" Command="{Binding ToggleVersionedSelectionCommand}"/>
                                        <TextBlock Text="Changes" Foreground="{StaticResource TextPrimary}" FontWeight="Bold" FontSize="12" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding VersionedFilesCountText}" Foreground="{StaticResource TextMuted}" FontSize="12" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </ToggleButton>
                            </Grid>
                        </Border>
                        
                        <ListBox x:Name="VersionedListBox" SelectionMode="Multiple" SelectedItem="{Binding SelectedFile}" ItemsSource="{Binding VersionedFiles}" Background="Transparent" BorderThickness="0" IsVisible="{Binding IsChangesExpanded}" Margin="15,0,0,0">
                            <ListBox.Styles>
                                <Style Selector="ListBoxItem">
                                    <Setter Property="Padding" Value="0,0"/>
                                    <Setter Property="MinHeight" Value="14"/>
                                </Style>
                            </ListBox.Styles>
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="models:GitFileStatus">
                                    <StackPanel Orientation="Horizontal" Background="Transparent" Margin="0,0">
                                        <StackPanel.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Delete File" Command="{Binding $parent[UserControl].((vm:StagingPanelViewModel)DataContext).DeleteFileCommand}" CommandParameter="{Binding}" />
                                                <MenuItem Header="Add to .gitignore" Command="{Binding $parent[UserControl].((vm:StagingPanelViewModel)DataContext).AddToGitignoreCommand}" CommandParameter="{Binding}" />
                                                <MenuItem Header="Rollback" Command="{Binding $parent[UserControl].((vm:StagingPanelViewModel)DataContext).RollbackFileCommand}" CommandParameter="{Binding}" />
                                                <MenuItem Header="Show History" Command="{Binding $parent[UserControl].((vm:StagingPanelViewModel)DataContext).ShowFileHistoryCommand}" CommandParameter="{Binding}" />
                                            </ContextMenu>
                                        </StackPanel.ContextMenu>
                                        <CheckBox Classes="FileRow" IsChecked="{Binding IsSelected, Mode=TwoWay}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding FileName, Converter={StaticResource FileExtensionToIconConverter}}" Foreground="{StaticResource BranchGreen}" FontSize="12" VerticalAlignment="Center" Margin="0,0,5,0" Width="18" TextAlignment="Center"/>
                                        <TextBlock Text="{Binding FileName}" Foreground="{StaticResource TextPrimary}" FontSize="12" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding DirectoryPath}" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="10,0,10,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>

                    <!-- Unversioned Block -->
                    <StackPanel Margin="0,5,0,0">
                        <!-- Category Header (No blue background for unversioned) -->
                        <Grid ColumnDefinitions="Auto, *">
                            <ToggleButton Classes="StagingCategory" Grid.Column="1" IsChecked="{Binding IsUnversionedExpanded, Mode=TwoWay}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="Transparent" BorderThickness="0" Padding="2,2" MinHeight="24">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <PathIcon Classes="Chevron" Classes.expanded="{Binding IsUnversionedExpanded}" Width="10" Height="10" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" />
                                    <CheckBox Margin="0,0,0,0" ToolTip.Tip="Select/Deselect All" IsThreeState="True" IsChecked="{Binding IsAllUnversionedSelected, Mode=OneWay}" Command="{Binding ToggleUnversionedSelectionCommand}"/>
                                    <TextBlock Text="Unversioned Files" Foreground="{StaticResource TextPrimary}" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding UnversionedFilesCountText}" Foreground="{StaticResource TextMuted}" FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>
                            </ToggleButton>
                        </Grid>
                        
                        <ListBox x:Name="UnversionedListBox" SelectionMode="Multiple" SelectedItem="{Binding SelectedFile}" ItemsSource="{Binding UnversionedFiles}" Background="Transparent" BorderThickness="0" IsVisible="{Binding IsUnversionedExpanded}" Margin="15,0,0,0">
                            <ListBox.Styles>
                                <Style Selector="ListBoxItem">
                                    <Setter Property="Padding" Value="0,0"/>
                                    <Setter Property="MinHeight" Value="14"/>
                                </Style>
                            </ListBox.Styles>
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="models:GitFileStatus">
                                    <StackPanel Orientation="Horizontal" Background="Transparent" Margin="0,0">
                                        <StackPanel.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Add to VCS" Command="{Binding $parent[UserControl].((vm:StagingPanelViewModel)DataContext).AddToVcsCommand}" CommandParameter="{Binding}" />
                                                <MenuItem Header="Delete File" Command="{Binding $parent[UserControl].((vm:StagingPanelViewModel)DataContext).DeleteFileCommand}" CommandParameter="{Binding}" />
                                                <MenuItem Header="Add to .gitignore" Command="{Binding $parent[UserControl].((vm:StagingPanelViewModel)DataContext).AddToGitignoreCommand}" CommandParameter="{Binding}" />
                                            </ContextMenu>
                                        </StackPanel.ContextMenu>
                                        <CheckBox Classes="FileRow" IsChecked="{Binding IsSelected, Mode=TwoWay}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding FileName, Converter={StaticResource FileExtensionToIconConverter}}" Foreground="{StaticResource BranchRed}" FontSize="12" VerticalAlignment="Center" Margin="0,0,5,0" Width="18" TextAlignment="Center"/>
                                        <TextBlock Text="{Binding FileName}" Foreground="{StaticResource BranchRed}" FontSize="12" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding DirectoryPath}" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="10,0,10,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>

            <!-- Draggable GridSplitter -->
            <GridSplitter Grid.Row="1" Background="{StaticResource BorderSubtle}" Height="4" HorizontalAlignment="Stretch" />

            <!-- Fixed Commit Composer -->
            <Border Grid.Row="2" Padding="10">
                <Grid RowDefinitions="Auto, *, Auto">
                    <!-- Standard Commit View -->
                    <Grid Grid.Row="1" RowDefinitions="Auto, *" IsVisible="{Binding !IsRebasing}">
                        <CheckBox Grid.Row="0" Content="Amend last commit" IsChecked="{Binding AmendLastCommit}" Foreground="{StaticResource TextPrimary}" FontSize="12" Margin="0,0,0,5"/>
                        
                        <TextBox Grid.Row="1" Text="{Binding CommitMessage}" Watermark="Commit Message (Hit Enter for Description)" AcceptsReturn="True" TextWrapping="Wrap" FontSize="13"
                                 BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1" Background="{StaticResource PanelSurface}" VerticalAlignment="Stretch"/>
                    </Grid>

                    <Grid Grid.Row="2" ColumnDefinitions="Auto, Auto, *" IsVisible="{Binding !IsRebasing}" Margin="0,10,0,0">
                        <Button Grid.Column="0" Classes="Accent" Padding="15,6" Margin="0,0,5,0"
                                Command="{Binding CommitCommand}">
                            <TextBlock Text="Commit" FontSize="12"/>
                        </Button>

                        <Button Grid.Column="1" Classes="Primary" Padding="15,6"
                                Command="{Binding CommitAndPushCommand}">
                            <TextBlock Text="Commit and Push..." FontSize="12"/>
                        </Button>
                    </Grid>

                    <!-- Rebasing View -->
                    <StackPanel Grid.Row="1" Spacing="10" IsVisible="{Binding IsRebasing}" VerticalAlignment="Center">
                        <TextBlock Text="Merge Conflicts Detected" Foreground="{StaticResource BranchRed}" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Resolve the conflicts (use Resolve Conflicts for the 3-way merge tool, or edit &amp; save files in the right window). Once all conflicts are staged, click Continue Rebase." TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextMuted}" TextAlignment="Center"/>
                        <Button Classes="Accent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="0,8"
                                Command="{Binding ResolveConflictsCommand}">
                            <TextBlock Text="Resolve Conflicts" FontWeight="SemiBold"/>
                        </Button>
                        <Grid ColumnDefinitions="*,10,*">
                            <Button Grid.Column="0" Classes="Primary" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="0,8"
                                    Command="{Binding ContinueRebaseCommand}">
                                <TextBlock Text="Continue Rebase" FontWeight="SemiBold"/>
                            </Button>
                            <Button Grid.Column="2" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="0,8"
                                    Command="{Binding AbortRebaseCommand}">
                                <TextBlock Text="Abort Rebase" FontWeight="SemiBold" Foreground="{StaticResource BranchRed}"/>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>
            </Grid>

            <!-- SHELF (STASHES) TAB -->
            <Grid RowDefinitions="Auto, *" IsVisible="{Binding IsStashTabActive}" Margin="15">
                <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,15">
                    <TextBox Grid.Column="0" Text="{Binding StashMessage}" Watermark="Shelf message..." Margin="0,0,5,0" FontSize="13" />
                    <Button Grid.Column="1" Classes="Primary" Content="Shelf Changes" Command="{Binding StashPushCommand}" Padding="15,6" FontWeight="SemiBold" FontSize="12"/>
                </Grid>
                
                <ScrollViewer Grid.Row="1">
                    <ListBox ItemsSource="{Binding Stashes}" Background="Transparent" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:GitStashItem">
                                <Border Background="{StaticResource PanelSurface}" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,8">
                                    <Grid ColumnDefinitions="*, Auto">
                                        <TextBlock Grid.Column="0" Text="{Binding FriendlyName}" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding Message}"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                            <Button Content="Pop" Padding="8,4" FontSize="11" Command="{Binding $parent[UserControl].((vm:StagingPanelViewModel)DataContext).StashPopCommand}" CommandParameter="{Binding}" />
                                            <Button Content="Apply" Padding="8,4" FontSize="11" Command="{Binding $parent[UserControl].((vm:StagingPanelViewModel)DataContext).StashApplyCommand}" CommandParameter="{Binding}" />
                                            <Button Content="Drop" Padding="8,4" FontSize="11" Background="Transparent" Foreground="{StaticResource BranchRed}" Command="{Binding $parent[UserControl].((vm:StagingPanelViewModel)DataContext).StashDropCommand}" CommandParameter="{Binding}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>
            </Grid>

        </Grid>
    </Grid>
</UserControl>
