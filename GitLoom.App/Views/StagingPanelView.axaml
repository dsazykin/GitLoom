<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GitLoom.App.ViewModels"
             xmlns:models="using:GitLoom.Core.Models"
             x:Class="GitLoom.App.Views.StagingPanelView"
             x:DataType="vm:StagingPanelViewModel">
    <UserControl.Styles>
        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="5,2" />
            <Setter Property="MinHeight" Value="24" />
        </Style>
    </UserControl.Styles>
    <Grid RowDefinitions="*, Auto">

        <!-- Scrollable File Lists -->
        <ScrollViewer Grid.Row="0" Margin="0,0,0,15">
            <StackPanel Spacing="15">

                <!-- Staged Block -->
                <Grid ColumnDefinitions="Auto, *, Auto" Margin="0,0,0,5">
                    <CheckBox Grid.Column="0" Margin="0,0,10,0" ToolTip.Tip="Select/Deselect All" Checked="StagedSelectAll_Checked" Unchecked="StagedSelectAll_Unchecked"/>
                    <TextBlock Grid.Column="1" Text="STAGED CHANGES" Foreground="{StaticResource TextMuted}" FontWeight="Bold" FontSize="11" LetterSpacing="1" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="5">
                        <Button Classes="Primary" Content="Unstage Selected" Padding="8,4" FontSize="11" Command="{Binding UnstageSelectedFilesCommand}" CommandParameter="{Binding #StagedListBox.SelectedItems}" />
                        <Button Classes="Primary" Content="Unstage All" Padding="8,4" FontSize="11" Command="{Binding UnstageAllFilesCommand}" />
                    </StackPanel>
                </Grid>
                <ListBox x:Name="StagedListBox" SelectionMode="Multiple" ItemsSource="{Binding StagedFiles}" Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:GitFileStatus">
                            <Grid ColumnDefinitions="Auto, *" Background="Transparent">
                                <CheckBox Grid.Column="0" IsChecked="{Binding $parent[ListBoxItem].IsSelected, Mode=TwoWay}" Margin="0,0,10,0" />
                                <TextBlock Grid.Column="1" Text="{Binding FilePath}" Foreground="{StaticResource BranchGreen}" FontSize="13" VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Unstaged Block -->
                <Grid ColumnDefinitions="Auto, *, Auto" Margin="0,0,0,5">
                    <CheckBox Grid.Column="0" Margin="0,0,10,0" ToolTip.Tip="Select/Deselect All" Checked="UnstagedSelectAll_Checked" Unchecked="UnstagedSelectAll_Unchecked"/>
                    <TextBlock Grid.Column="1" Text="CHANGES" Foreground="{StaticResource TextMuted}" FontWeight="Bold" FontSize="11" LetterSpacing="1" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="5">
                        <Button Classes="Primary" Content="Stage Selected" Padding="8,4" FontSize="11" Command="{Binding StageSelectedFilesCommand}" CommandParameter="{Binding #UnstagedListBox.SelectedItems}" />
                        <Button Classes="Primary" Content="Stage All" Padding="8,4" FontSize="11" Command="{Binding StageAllFilesCommand}" />
                    </StackPanel>
                </Grid>
                <ListBox x:Name="UnstagedListBox" SelectedItem="{Binding SelectedFile}" SelectionMode="Multiple" ItemsSource="{Binding UnstagedFiles}" Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:GitFileStatus">
                            <Grid ColumnDefinitions="Auto, *" Background="Transparent">
                                <CheckBox Grid.Column="0" IsChecked="{Binding $parent[ListBoxItem].IsSelected, Mode=TwoWay}" Margin="0,0,10,0" />
                                <TextBlock Grid.Column="1" Text="{Binding FilePath}" Foreground="{StaticResource BranchRed}" FontSize="13" VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Stashes Block -->
                <Grid ColumnDefinitions="*, Auto" Margin="0,15,0,5">
                    <TextBlock Grid.Column="0" Text="STASHES" Foreground="{StaticResource TextMuted}" FontWeight="Bold" FontSize="11" LetterSpacing="1" VerticalAlignment="Center"/>
                </Grid>
                <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,10">
                    <TextBox Grid.Column="0" Text="{Binding StashMessage}" Watermark="Stash message..." Margin="0,0,5,0" />
                    <Button Grid.Column="1" Classes="Primary" Content="Stash" Command="{Binding StashPushCommand}" />
                </Grid>
                <ListBox ItemsSource="{Binding Stashes}" Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:GitStashItem">
                            <Grid ColumnDefinitions="*, Auto" Background="Transparent" Margin="0,0,0,5">
                                <TextBlock Grid.Column="0" Text="{Binding FriendlyName}" Foreground="{StaticResource TextPrimary}" FontSize="13" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding Message}"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="5">
                                    <Button Classes="Primary" Content="Pop" Padding="6,2" FontSize="10" Command="{Binding $parent[UserControl].((vm:StagingPanelViewModel)DataContext).StashPopCommand}" CommandParameter="{Binding}" />
                                    <Button Classes="Primary" Content="Apply" Padding="6,2" FontSize="10" Command="{Binding $parent[UserControl].((vm:StagingPanelViewModel)DataContext).StashApplyCommand}" CommandParameter="{Binding}" />
                                    <Button Content="Drop" Padding="6,2" FontSize="10" Background="Transparent" Foreground="{StaticResource BranchRed}" Command="{Binding $parent[UserControl].((vm:StagingPanelViewModel)DataContext).StashDropCommand}" CommandParameter="{Binding}" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            </StackPanel>
        </ScrollViewer>

        <!-- Fixed Commit Composer -->
        <Border Grid.Row="1" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,1,0,0" Padding="0,15,0,0">
            <StackPanel Spacing="10">
                <!-- Standard Commit View -->
                <StackPanel Spacing="10" IsVisible="{Binding !IsRebasing}">
                    <TextBox Text="{Binding CommitMessage}" Watermark="Commit message..." Height="80" AcceptsReturn="True" TextWrapping="Wrap"/>
                    <Grid ColumnDefinitions="*,10,*">
                        <Button Grid.Column="0" Classes="Primary" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="0,8"
                                Command="{Binding CommitCommand}">
                            <TextBlock Text="Commit" FontWeight="SemiBold"/>
                        </Button>
                        <Button Grid.Column="2" Classes="Primary" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="0,8"
                                Command="{Binding CommitAndPushCommand}">
                            <TextBlock Text="Commit &amp; Push" FontWeight="SemiBold"/>
                        </Button>
                    </Grid>
                </StackPanel>

                <!-- Rebasing View -->
                <StackPanel Spacing="10" IsVisible="{Binding IsRebasing}">
                    <TextBlock Text="Merge Conflicts Detected" Foreground="{StaticResource BranchRed}" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Please select the files above, resolve their conflicts in the right window, and save the files to stage them. Once all conflicts are staged, click Continue Rebase." TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextMuted}" TextAlignment="Center"/>
                    <Grid ColumnDefinitions="*,10,*">
                        <Button Grid.Column="0" Classes="Primary" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="0,8"
                                Command="{Binding ContinueRebaseCommand}">
                            <TextBlock Text="Continue Rebase" FontWeight="SemiBold"/>
                        </Button>
                        <Button Grid.Column="2" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="0,8"
                                Command="{Binding AbortRebaseCommand}">
                            <TextBlock Text="Abort Rebase" FontWeight="SemiBold" Foreground="{StaticResource BranchRed}"/>
                        </Button>
                    </Grid>
                </StackPanel>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>
