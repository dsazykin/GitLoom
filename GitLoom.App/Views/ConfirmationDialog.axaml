<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GitLoom.App.ViewModels"
        x:Class="GitLoom.App.Views.ConfirmationDialog"
        x:DataType="vm:ConfirmationDialogViewModel"
        Title="{Binding Title}"
        Width="400" Height="200"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ExtendClientAreaToDecorationsHint="True"
        Background="{StaticResource BgWindow}">

    <Border Padding="30" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1">
        <Grid RowDefinitions="Auto,*,Auto">
            
            <TextBlock Text="{Binding Title}"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextPrimary}"/>

            <StackPanel Grid.Row="1" Margin="0,20,0,0">
                <TextBlock Text="{Binding Message}"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource TextPrimary}"/>
                <CheckBox Content="{Binding OptionalCheckboxText}"
                          IsChecked="{Binding IsOptionalCheckboxChecked}"
                          IsVisible="{Binding IsOptionalCheckboxVisible}"
                          Margin="0,15,0,0"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                <Button Content="Cancel" 
                        Command="{Binding CancelCommand}"
                        CommandParameter="{Binding $parent[Window]}"
                        Classes="Secondary"/>
                <Button Content="{Binding ConfirmButtonText}"
                        Command="{Binding ConfirmCommand}"
                        CommandParameter="{Binding $parent[Window]}"
                        Classes="Danger"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
