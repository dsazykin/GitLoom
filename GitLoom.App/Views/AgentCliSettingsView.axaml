<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GitLoom.App.ViewModels"
        x:Class="GitLoom.App.Views.AgentCliSettingsView"
        x:DataType="vm:AgentCliSettingsViewModel"
        Title="Agent CLIs"
        Width="620" Height="560"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SurfaceWindow}">
    <Border Padding="20">
        <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">

            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="0,0,0,6">
                <PathIcon Data="{StaticResource TerminalIcon}" Width="18" Height="18"
                          Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                <TextBlock Text="Agent command-line tools" FontSize="18" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Grid.Row="1" Margin="0,0,0,12" FontSize="12" TextWrapping="Wrap"
                       Foreground="{DynamicResource TextMuted}"
                       Text="The coding agents Mainguard can run in its isolated sandbox. Each installs at a pinned, checksum-verified version inside the Mainguard environment — never on your own system — and is available to every new agent session the moment it's installed."/>

            <!-- Loading: a named line, never a blank list. -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,0,0,10"
                        IsVisible="{Binding IsLoading}">
                <PathIcon Classes="spinning" Data="{StaticResource RefreshIcon}" Width="14" Height="14"
                          Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                <TextBlock Text="Checking which agents are installed…" FontSize="12"
                           Foreground="{DynamicResource TextMuted}"/>
            </StackPanel>

            <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="8">

                    <!-- Catalog read failed: the cause + the way forward, inline. -->
                    <Border Classes="Card" Background="{DynamicResource SurfaceCard}" CornerRadius="8"
                            Padding="14" IsVisible="{Binding HasLoadError}">
                        <StackPanel Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <PathIcon Data="{StaticResource WarningIcon}" Width="16" Height="16"
                                          Foreground="{DynamicResource DangerBrush}" VerticalAlignment="Top"/>
                                <TextBlock Text="{Binding LoadError}" FontSize="12" MaxWidth="500"
                                           Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap"/>
                            </StackPanel>
                            <Button Content="Try again" Classes="Primary" Padding="14,6" HorizontalAlignment="Right"
                                    Command="{Binding RefreshCommand}"/>
                        </StackPanel>
                    </Border>

                    <ItemsControl ItemsSource="{Binding Clis}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:AgentCliRowViewModel">
                                <Border Classes="Card" Background="{DynamicResource SurfaceCard}"
                                        CornerRadius="8" Padding="14" Margin="0,0,0,2">
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <!-- Health/lifecycle glyph: icon + text below, never colour alone. -->
                                        <Panel Grid.Column="0" Width="22" Height="22" Margin="0,0,12,0" VerticalAlignment="Top">
                                            <PathIcon Data="{StaticResource CheckmarkIcon}" Width="18" Height="18"
                                                      Foreground="{DynamicResource SuccessBrush}" IsVisible="{Binding IsInstalled}"/>
                                            <PathIcon Classes="spinning" Data="{StaticResource RefreshIcon}" Width="16" Height="16"
                                                      Foreground="{DynamicResource AccentBrush}" IsVisible="{Binding IsInstalling}"/>
                                            <PathIcon Data="{StaticResource TerminalIcon}" Width="16" Height="16"
                                                      Foreground="{DynamicResource TextMuted}" IsVisible="{Binding IsIdle}"/>
                                        </Panel>

                                        <StackPanel Grid.Column="1" Spacing="4" Margin="0,0,12,0">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <!-- MaxWidth bounds the measure so TextTrimming actually engages inside the
                                                     horizontal StackPanel (unbounded, it would collide with the Install button). -->
                                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="13"
                                                           Foreground="{DynamicResource TextPrimary}" MaxWidth="260"
                                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                <Border CornerRadius="999" Background="{DynamicResource AccentSelection}"
                                                        Padding="8,1" VerticalAlignment="Center">
                                                    <TextBlock Classes="Mono" Text="{Binding VersionLabel}" FontSize="10"
                                                               Foreground="{DynamicResource AccentBrush}"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="Installed — verified at the pinned version" FontSize="11"
                                                       Foreground="{DynamicResource SuccessBrush}" IsVisible="{Binding IsInstalled}"/>
                                            <TextBlock Text="Not installed" FontSize="11"
                                                       Foreground="{DynamicResource TextMuted}" IsVisible="{Binding CanInstall}"/>
                                            <!-- Progress detail (muted) vs failure cause (icon + danger text). -->
                                            <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                                                       Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap">
                                                <TextBlock.IsVisible>
                                                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                                                        <Binding Path="HasStatusMessage"/>
                                                        <Binding Path="!IsFailed"/>
                                                    </MultiBinding>
                                                </TextBlock.IsVisible>
                                            </TextBlock>
                                            <StackPanel Orientation="Horizontal" Spacing="6" IsVisible="{Binding IsFailed}">
                                                <PathIcon Data="{StaticResource WarningIcon}" Width="12" Height="12"
                                                          Foreground="{DynamicResource DangerBrush}" VerticalAlignment="Top"
                                                          Margin="0,2,0,0"/>
                                                <TextBlock Text="{Binding StatusMessage}" FontSize="12" MaxWidth="420"
                                                           Foreground="{DynamicResource DangerBrush}" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <Button Grid.Column="2" Content="Install" Classes="Primary" Padding="14,5"
                                                VerticalAlignment="Center" IsVisible="{Binding CanInstall}"
                                                Command="{Binding $parent[Window].((vm:AgentCliSettingsViewModel)DataContext).InstallCommand}"
                                                CommandParameter="{Binding}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="This Mainguard release's CLI catalog is empty — check for a Mainguard update."
                               Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="4,8"
                               IsVisible="{Binding ShowEmpty}"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Grid Grid.Row="4" ColumnDefinitions="*,Auto" Margin="0,15,0,0">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center"
                            IsVisible="{Binding IsBusy}">
                    <TextBlock Text="Installing — you can cancel anytime; finished installs stay."
                               FontSize="11" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                    <Button Content="Cancel install" Classes="Secondary" Padding="15,6"
                            IsVisible="{Binding IsBusy}" Command="{Binding CancelInstallCommand}"/>
                    <Button Content="Refresh" Classes="Primary" Padding="15,6"
                            Command="{Binding RefreshCommand}"/>
                    <Button Content="Close" Classes="Secondary" Padding="15,6" Command="{Binding CloseCommand}"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
