<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GitLoom.App.ViewModels"
        xmlns:views="using:GitLoom.App.Views"
        x:Class="GitLoom.App.Views.NotificationsWindow"
        x:DataType="vm:NotificationsViewModel"
        Title="Notifications"
        Width="760"
        Height="640"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SurfaceWindow}">
    <!-- Content extracted to NotificationsView (2026-07-11) so the same surface hosts as a
         MainWindow section tab; this window remains for the legacy dialog entry points. -->
    <views:NotificationsView/>
</Window>
