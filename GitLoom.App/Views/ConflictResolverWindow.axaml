<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GitLoom.App.ViewModels"
        x:Class="GitLoom.App.Views.ConflictResolverWindow"
        x:DataType="vm:ConflictResolverWindowViewModel"
        Title="{Binding FileName}"
        Width="1200" Height="820"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SurfaceWindow}" Foreground="{DynamicResource TextPrimary}">

    <Grid RowDefinitions="Auto,*,Auto" Margin="15">
        <!-- Header -->
        <TextBlock Grid.Row="0" Text="{Binding FileName}" FontSize="16" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,12"/>

        <!-- Loading -->
        <TextBlock Grid.Row="1" Text="Loading…" HorizontalAlignment="Center" VerticalAlignment="Center"
                   Foreground="{DynamicResource TextMuted}" IsVisible="{Binding IsLoading}"/>

        <!-- Whole-file mode (delete/modify or add/add with a missing side) -->
        <Border Grid.Row="1" Classes="Card" Padding="25" VerticalAlignment="Center" HorizontalAlignment="Center"
                IsVisible="{Binding IsWholeFileMode}">
            <StackPanel Spacing="15" MaxWidth="420">
                <TextBlock Text="This file was deleted on one side and changed on the other."
                           TextWrapping="Wrap" Foreground="{DynamicResource TextPrimary}"/>
                <TextBlock Text="{Binding MissingSideNote}" Foreground="{DynamicResource TextMuted}"/>
                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                    <Button Content="Keep File" Classes="Success" Command="{Binding KeepFileCommand}"/>
                    <Button Content="Delete File" Classes="Danger" Command="{Binding DeleteFileCommand}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Chunk mode: chunks on the left, merged preview on the right -->
        <Grid Grid.Row="1" ColumnDefinitions="*,8,0.9*" IsVisible="{Binding IsChunkMode}">
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Chunks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:MergeChunkViewModel">
                            <StackPanel Margin="0,0,0,8">
                                <!-- Non-conflict (context / auto-merged) -->
                                <Border IsVisible="{Binding !IsConflict}" Background="{DynamicResource SurfaceDeep}"
                                        CornerRadius="8" Padding="8" BorderBrush="{DynamicResource BorderHairline}"
                                        BorderThickness="1">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{Binding AutoMergedLabel}" FontSize="10"
                                                   Foreground="{DynamicResource TextMuted}"
                                                   IsVisible="{Binding IsAutoMerged}"/>
                                        <TextBlock Text="{Binding ContextText}" FontFamily="{StaticResource FontMono}"
                                                   Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <!-- Conflict -->
                                <Border IsVisible="{Binding IsConflict}" Background="{DynamicResource SurfaceCard}"
                                        CornerRadius="8" Padding="8" BorderBrush="{DynamicResource BorderHairline}"
                                        BorderThickness="1">
                                    <StackPanel Spacing="8">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Button Content="Use Ours" Classes="Primary" Padding="8,3" FontSize="11"
                                                    Command="{Binding TakeOursCommand}"/>
                                            <Button Content="Use Theirs" Classes="Primary" Padding="8,3" FontSize="11"
                                                    Command="{Binding TakeTheirsCommand}"/>
                                            <Button Content="Use Both" Classes="Primary" Padding="8,3" FontSize="11"
                                                    Command="{Binding TakeBothCommand}"/>
                                            <PathIcon Data="{StaticResource CheckmarkIcon}" Width="14" Height="14"
                                                      Foreground="{DynamicResource SuccessBrush}"
                                                      IsVisible="{Binding IsResolved}"/>
                                        </StackPanel>

                                        <Grid ColumnDefinitions="*,8,*">
                                            <!-- Ours -->
                                            <Grid Grid.Column="0">
                                                <Border Background="{DynamicResource AccentSelection}" CornerRadius="6"
                                                        IsVisible="{Binding TookOurs}"/>
                                                <StackPanel Margin="6" Spacing="2">
                                                    <TextBlock Text="OURS" FontSize="10" FontWeight="Bold"
                                                               Foreground="{DynamicResource SuccessBrush}"/>
                                                    <TextBlock Text="{Binding OursText}" FontFamily="{StaticResource FontMono}"
                                                               Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Grid>
                                            <!-- Theirs -->
                                            <Grid Grid.Column="2">
                                                <Border Background="{DynamicResource AccentSelection}" CornerRadius="6"
                                                        IsVisible="{Binding TookTheirs}"/>
                                                <StackPanel Margin="6" Spacing="2">
                                                    <TextBlock Text="THEIRS" FontSize="10" FontWeight="Bold"
                                                               Foreground="{DynamicResource AccentBrush}"/>
                                                    <TextBlock Text="{Binding TheirsText}" FontFamily="{StaticResource FontMono}"
                                                               Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Grid>
                                        </Grid>

                                        <!-- Custom -->
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBox Grid.Column="0" Text="{Binding CustomText, Mode=TwoWay}"
                                                     AcceptsReturn="True" FontFamily="{StaticResource FontMono}"
                                                     Watermark="Custom resolution…"/>
                                            <Button Grid.Column="1" Content="Use Custom" Classes="Primary" Padding="8,3"
                                                    FontSize="11" VerticalAlignment="Top" Margin="8,0,0,0"
                                                    Command="{Binding UseCustomCommand}"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <GridSplitter Grid.Column="1" Background="Transparent"/>

            <!-- Merged preview -->
            <Border Grid.Column="2" Classes="Card" Padding="0" Background="{DynamicResource SurfaceDeep}">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Grid.Row="0" Text="MERGED PREVIEW" FontSize="10" FontWeight="Bold"
                               Foreground="{DynamicResource TextMuted}" Margin="10,8"/>
                    <ScrollViewer Grid.Row="1">
                        <TextBox Text="{Binding MergedPreview}" IsReadOnly="True" Focusable="False"
                                 FontFamily="{StaticResource FontMono}" Background="Transparent" BorderThickness="0"
                                 Foreground="{DynamicResource TextPrimary}" AcceptsReturn="True" TextWrapping="NoWrap"
                                 Padding="10,0,10,10"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,12,0,0">
            <Button Content="Cancel" Command="{Binding CancelCommand}" Classes="Secondary" Width="100"
                    HorizontalContentAlignment="Center"/>
            <Button Content="Mark Resolved" Command="{Binding MarkResolvedCommand}" Classes="Accent" Padding="15,5"
                    IsVisible="{Binding IsChunkMode}"/>
        </StackPanel>
    </Grid>
</Window>
