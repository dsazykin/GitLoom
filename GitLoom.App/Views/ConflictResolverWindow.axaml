<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GitLoom.App.ViewModels"
        x:Class="GitLoom.App.Views.ConflictResolverWindow"
        x:DataType="vm:ConflictResolverWindowViewModel"
        Title="Conflict Resolver - {Binding FileName}"
        Width="1200" Height="800"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E">

    <Grid RowDefinitions="Auto, *, Auto" Margin="10">
        <!-- Header -->
        <Border Grid.Row="0" Background="#2D2D30" Padding="15" CornerRadius="5" Margin="0,0,0,10">
            <Grid ColumnDefinitions="*, *, *">
                <TextBlock Grid.Column="0" Text="INCOMING (Left)" Foreground="#4EC9B0" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="FINAL RESULT (Middle)" Foreground="#FFFFFF" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="YOURS (Right)" Foreground="#569CD6" FontWeight="Bold" HorizontalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Blocks}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#3F3F46" BorderThickness="0,0,0,1" Padding="0,5">
                            <Grid>
                                <!-- Non-Conflict Block -->
                                <TextBox Text="{Binding CommonText}" 
                                         IsVisible="{Binding !IsConflict}"
                                         IsReadOnly="True"
                                         FontFamily="Consolas"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="#D4D4D4"/>

                                <!-- Conflict Block -->
                                <Grid IsVisible="{Binding IsConflict}" ColumnDefinitions="*, *, *">
                                    
                                    <!-- Left: Incoming -->
                                    <Border Grid.Column="0" Background="#283A2E" Margin="5" CornerRadius="3" Padding="5">
                                        <Grid RowDefinitions="Auto, *">
                                            <Grid Grid.Row="0" ColumnDefinitions="*, Auto">
                                                <TextBlock Text="{Binding LeftLabel}" Foreground="#808080" FontSize="11" />
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="5">
                                                    <Button Command="{Binding AcceptLeftCommand}" Content="Keep &amp; Move ->" Padding="5,2" Background="#4EC9B0" Foreground="Black" FontSize="11" ToolTip.Tip="Apply Incoming"/>
                                                </StackPanel>
                                            </Grid>
                                            <TextBox Grid.Row="1" Text="{Binding LeftText}" IsReadOnly="True" FontFamily="Consolas" Background="Transparent" BorderThickness="0" Foreground="#D4D4D4" Margin="0,5,0,0" AcceptsReturn="True"/>
                                        </Grid>
                                    </Border>

                                    <!-- Middle: Final -->
                                    <Border Grid.Column="1" Background="#1E1E1E" BorderBrush="#3F3F46" BorderThickness="1" Margin="5" CornerRadius="3" Padding="5">
                                        <Grid RowDefinitions="Auto, *">
                                            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right">
                                                <Button Command="{Binding ClearFinalCommand}" Content="X Clear" Padding="5,2" Background="#F44336" Foreground="White" FontSize="11" ToolTip.Tip="Clear Final Selection"/>
                                            </StackPanel>
                                            <TextBox Grid.Row="1" Text="{Binding FinalText}" FontFamily="Consolas" Background="Transparent" BorderThickness="0" Foreground="#D4D4D4" Margin="0,5,0,0" AcceptsReturn="True"/>
                                        </Grid>
                                    </Border>

                                    <!-- Right: Yours -->
                                    <Border Grid.Column="2" Background="#2B3645" Margin="5" CornerRadius="3" Padding="5">
                                        <Grid RowDefinitions="Auto, *">
                                            <Grid Grid.Row="0" ColumnDefinitions="Auto, *">
                                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="5">
                                                    <Button Command="{Binding AcceptRightCommand}" Content="&lt;- Keep &amp; Move" Padding="5,2" Background="#569CD6" Foreground="Black" FontSize="11" ToolTip.Tip="Apply Yours"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="{Binding RightLabel}" Foreground="#808080" FontSize="11" HorizontalAlignment="Right" />
                                            </Grid>
                                            <TextBox Grid.Row="1" Text="{Binding RightText}" IsReadOnly="True" FontFamily="Consolas" Background="Transparent" BorderThickness="0" Foreground="#D4D4D4" Margin="0,5,0,0" AcceptsReturn="True"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,10,0,0">
            <Button Content="Cancel" Command="{Binding CancelCommand}" Width="100" HorizontalContentAlignment="Center" />
            <Button Content="Save &amp; Mark Resolved" Command="{Binding SaveAndCloseCommand}" Background="#007ACC" Foreground="White" FontWeight="Bold" Padding="15,5" />
        </StackPanel>
    </Grid>
</Window>
