<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GitLoom.App.ViewModels"
        x:Class="GitLoom.App.Views.ConflictResolverWindow"
        x:DataType="vm:ConflictResolverWindowViewModel"
        Title="Conflict Resolver - {Binding FileName}"
        Width="1200" Height="800"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E">

    <Grid RowDefinitions="Auto, *, Auto" Margin="10">
        <!-- Header -->
        <Border Grid.Row="0" Background="#2D2D30" Padding="15" CornerRadius="5" Margin="0,0,0,10">
            <Grid ColumnDefinitions="*, *, *">
                <TextBlock Grid.Column="0" Text="INCOMING (Left)" Foreground="#4EC9B0" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="FINAL RESULT (Middle)" Foreground="#FFFFFF" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="YOURS (Right)" Foreground="#569CD6" FontWeight="Bold" HorizontalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Blocks}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#3F3F46" BorderThickness="0,0,0,1">
                            <Grid ColumnDefinitions="*, *, *">
                                
                                <!-- Left Column (Incoming) -->
                                <Border Grid.Column="0" Background="{Binding LeftBackground}" BorderBrush="#3F3F46" BorderThickness="0,0,1,0" Padding="5">
                                    <Grid RowDefinitions="Auto, *">
                                        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" IsVisible="{Binding IsConflict}" Margin="0,0,0,5">
                                            <TextBlock Text="{Binding LeftLabel}" Foreground="#808080" FontSize="11" VerticalAlignment="Center"/>
                                            <Button Grid.Column="1" Command="{Binding AcceptLeftCommand}" Content="{Binding LeftButtonText}" Padding="5,2" Background="#4EC9B0" Foreground="Black" FontSize="11" ToolTip.Tip="Apply Incoming"/>
                                        </Grid>
                                        <TextBox Grid.Row="1" Text="{Binding LeftText}" IsReadOnly="True" FontFamily="Consolas" Background="Transparent" BorderThickness="0" Foreground="#D4D4D4" AcceptsReturn="True" TextWrapping="Wrap"/>
                                    </Grid>
                                </Border>

                                <!-- Middle Column (Final Result) -->
                                <Border Grid.Column="1" Background="{Binding MiddleBackground}" BorderBrush="#3F3F46" BorderThickness="0,0,1,0" Padding="5">
                                    <Grid RowDefinitions="Auto, *">
                                        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" IsVisible="{Binding IsConflict}" Margin="0,0,0,5">
                                            <Button Command="{Binding ClearFinalCommand}" Content="X Clear" Padding="5,2" Background="#F44336" Foreground="White" FontSize="11" ToolTip.Tip="Clear Final Selection"/>
                                        </StackPanel>
                                        <TextBox Grid.Row="1" Text="{Binding FinalText}" IsReadOnly="{Binding !IsConflict}" FontFamily="Consolas" Background="Transparent" BorderThickness="0" Foreground="#D4D4D4" AcceptsReturn="True" TextWrapping="Wrap"/>
                                    </Grid>
                                </Border>

                                <!-- Right Column (Yours) -->
                                <Border Grid.Column="2" Background="{Binding RightBackground}" Padding="5">
                                    <Grid RowDefinitions="Auto, *">
                                        <Grid Grid.Row="0" ColumnDefinitions="Auto, *" IsVisible="{Binding IsConflict}" Margin="0,0,0,5">
                                            <Button Grid.Column="0" Command="{Binding AcceptRightCommand}" Content="{Binding RightButtonText}" Padding="5,2" Background="#569CD6" Foreground="Black" FontSize="11" ToolTip.Tip="Apply Yours"/>
                                            <TextBlock Grid.Column="1" Text="{Binding RightLabel}" Foreground="#808080" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        </Grid>
                                        <TextBox Grid.Row="1" Text="{Binding RightText}" IsReadOnly="True" FontFamily="Consolas" Background="Transparent" BorderThickness="0" Foreground="#D4D4D4" AcceptsReturn="True" TextWrapping="Wrap"/>
                                    </Grid>
                                </Border>
                                
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,10,0,0">
            <Button Content="Cancel" Command="{Binding CancelCommand}" Width="100" HorizontalContentAlignment="Center" />
            <Button Content="Save &amp; Mark Resolved" Command="{Binding SaveAndCloseCommand}" Background="#007ACC" Foreground="White" FontWeight="Bold" Padding="15,5" />
        </StackPanel>
    </Grid>
</Window>
