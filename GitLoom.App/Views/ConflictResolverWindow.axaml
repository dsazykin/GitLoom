<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GitLoom.App.ViewModels"
        xmlns:views="using:GitLoom.App.Views"
        xmlns:AvaloniaEdit="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
        x:Class="GitLoom.App.Views.ConflictResolverWindow"
        x:DataType="vm:ConflictResolverWindowViewModel"
        Title="{Binding FileName}"
        Width="1280" Height="820"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SurfaceWindow}" Foreground="{DynamicResource TextPrimary}">

    <Grid RowDefinitions="Auto,*,Auto" Margin="12">
        <!-- Toolbar -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,10" IsVisible="{Binding IsChunkMode}">
            <TextBlock Grid.Column="0" Text="{Binding FileName}" FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1" Text="{Binding StatusText}" HorizontalAlignment="Center"
                       VerticalAlignment="Center" Foreground="{DynamicResource TextMuted}" FontSize="12"/>
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
                <Button x:Name="PrevConflictButton" Classes="IconButton" ToolTip.Tip="Previous conflict">
                    <PathIcon Data="{StaticResource ArrowUpIcon}" Width="14" Height="14"/>
                </Button>
                <Button x:Name="NextConflictButton" Classes="IconButton" ToolTip.Tip="Next conflict">
                    <PathIcon Data="{StaticResource ArrowDownIcon}" Width="14" Height="14"/>
                </Button>
                <Button x:Name="AcceptAllOursButton" Content="All Ours" Classes="Primary" Padding="8,4" FontSize="11"
                        ToolTip.Tip="Resolve every remaining conflict with ours"/>
                <Button x:Name="AcceptAllTheirsButton" Content="All Theirs" Classes="Primary" Padding="8,4" FontSize="11"
                        ToolTip.Tip="Resolve every remaining conflict with theirs"/>
            </StackPanel>
        </Grid>

        <!-- Loading -->
        <TextBlock Grid.Row="1" Text="Loading…" HorizontalAlignment="Center" VerticalAlignment="Center"
                   Foreground="{DynamicResource TextMuted}" IsVisible="{Binding IsLoading}"/>

        <!-- Whole-file mode (delete/modify or add/add with a missing side) -->
        <Border Grid.Row="1" Classes="Card" Padding="25" VerticalAlignment="Center" HorizontalAlignment="Center"
                IsVisible="{Binding IsWholeFileMode}">
            <StackPanel Spacing="15" MaxWidth="420">
                <TextBlock Text="This file was deleted on one side and changed on the other."
                           TextWrapping="Wrap" Foreground="{DynamicResource TextPrimary}"/>
                <TextBlock Text="{Binding MissingSideNote}" Foreground="{DynamicResource TextMuted}"/>
                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                    <Button Content="Keep File" Classes="Success" Command="{Binding KeepFileCommand}"/>
                    <Button Content="Delete File" Classes="Danger" Command="{Binding DeleteFileCommand}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Chunk mode: synchronized 3-pane merge editor (one continuous surface) -->
        <Grid Grid.Row="1" RowDefinitions="Auto,*" IsVisible="{Binding IsChunkMode}">
            <Grid Grid.Row="0" ColumnDefinitions="*,1,*,1,*" Margin="0,0,0,4">
                <TextBlock Grid.Column="0" Text="OURS (current)" FontSize="11" FontWeight="Bold"
                           Foreground="{DynamicResource SuccessBrush}" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="RESULT (editable)" FontSize="11" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimary}" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="4" Text="THEIRS (incoming)" FontSize="11" FontWeight="Bold"
                           Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center"/>
            </Grid>

            <Border Grid.Row="1" Classes="Card" Padding="0" Background="{DynamicResource SurfaceDeep}">
                <Grid ColumnDefinitions="*,44,*,44,*">
                    <AvaloniaEdit:TextEditor Grid.Column="0" x:Name="OursEditor" IsReadOnly="True" ShowLineNumbers="True"
                                             Background="Transparent" Foreground="{DynamicResource TextPrimary}"
                                             FontFamily="{StaticResource FontMono}" FontSize="14"/>
                    <views:MergeGutter Grid.Column="1" x:Name="OursGutter"/>
                    <AvaloniaEdit:TextEditor Grid.Column="2" x:Name="ResultEditor" ShowLineNumbers="True"
                                             Background="Transparent" Foreground="{DynamicResource TextPrimary}"
                                             FontFamily="{StaticResource FontMono}" FontSize="14"/>
                    <views:MergeGutter Grid.Column="3" x:Name="TheirsGutter"/>
                    <AvaloniaEdit:TextEditor Grid.Column="4" x:Name="TheirsEditor" IsReadOnly="True" ShowLineNumbers="True"
                                             Background="Transparent" Foreground="{DynamicResource TextPrimary}"
                                             FontFamily="{StaticResource FontMono}" FontSize="14"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,12,0,0">
            <Button Content="Cancel" Command="{Binding CancelCommand}" Classes="Secondary" Width="100"
                    HorizontalContentAlignment="Center"/>
            <Button Content="Mark Resolved" Command="{Binding MarkResolvedCommand}" Classes="Accent" Padding="15,5"
                    IsVisible="{Binding IsChunkMode}"/>
        </StackPanel>
    </Grid>
</Window>
