<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GitLoom.App.ViewModels"
        x:Class="GitLoom.App.Views.ConflictResolverWindow"
        x:DataType="vm:ConflictResolverWindowViewModel"
        Title="Conflict Resolver - {Binding FileName}"
        Width="1200" Height="800"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgWindow}">

    <Grid RowDefinitions="Auto, Auto, *, Auto" Margin="10">
        <!-- Resolved Banner -->
        <Border Grid.Row="0" Background="{StaticResource BranchGreen}" Padding="10" CornerRadius="5" Margin="0,0,0,10" IsVisible="{Binding IsFullyResolved}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                <PathIcon Data="{StaticResource CheckmarkIcon}" Foreground="Black" Width="16" Height="16" />
                <TextBlock Text="All conflicts in this file have been resolved! You can now accept the changes." Foreground="Black" FontWeight="Bold" VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Header -->
        <Border Grid.Row="1" Background="{StaticResource PanelSurface}" Padding="15" CornerRadius="5" Margin="0,0,0,10">
            <Grid x:Name="HeaderGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{Binding Column1Width, Mode=TwoWay}" MinWidth="100"/>
                    <ColumnDefinition Width="5" />
                    <ColumnDefinition Width="{Binding Column2Width, Mode=TwoWay}" MinWidth="100"/>
                    <ColumnDefinition Width="5" />
                    <ColumnDefinition Width="{Binding Column3Width, Mode=TwoWay}" MinWidth="100"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <TextBlock Text="INCOMING (Left)" Foreground="{StaticResource BranchGreen}" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Spacing="5">
                        <Button Command="{Binding PrevConflictCommand}" ToolTip.Tip="Previous Conflict">
                            <PathIcon Data="{StaticResource ArrowUpIcon}" Width="14" Height="14"/>
                        </Button>
                        <Button Command="{Binding NextConflictCommand}" ToolTip.Tip="Next Conflict">
                            <PathIcon Data="{StaticResource ArrowDownIcon}" Width="14" Height="14"/>
                        </Button>
                    </StackPanel>
                </Grid>

                <GridSplitter Grid.Column="1" Background="{StaticResource BorderSubtle}" Margin="1,0"/>
                <TextBlock Grid.Column="2" Text="FINAL RESULT (Middle)" Foreground="{StaticResource TextPrimary}" FontWeight="Bold" HorizontalAlignment="Center"/>
                <GridSplitter Grid.Column="3" Background="{StaticResource BorderSubtle}" Margin="1,0"/>

                <Grid Grid.Column="4">
                    <TextBlock Text="YOURS (Right)" Foreground="{StaticResource BranchCyan}" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <Button Content="Discard Changes" Command="{Binding DiscardAllCommand}" HorizontalAlignment="Right" Classes="Danger" Padding="5,2" ToolTip.Tip="Discard all conflicts"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="2" ColumnDefinitions="*, 15">
            <ScrollViewer x:Name="MainScroll" Grid.Column="0" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="BlocksControl" ItemsSource="{Binding Blocks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="{Binding $parent[Window].((vm:ConflictResolverWindowViewModel)DataContext).Column1Width}" />
                                        <ColumnDefinition Width="5" />
                                        <ColumnDefinition Width="{Binding $parent[Window].((vm:ConflictResolverWindowViewModel)DataContext).Column2Width}" />
                                        <ColumnDefinition Width="5" />
                                        <ColumnDefinition Width="{Binding $parent[Window].((vm:ConflictResolverWindowViewModel)DataContext).Column3Width}" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Left Column (Incoming) -->
                                    <Border Grid.Column="0" Background="{Binding LeftBackground}" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,1,0" Padding="5">
                                        <Grid RowDefinitions="Auto, *">
                                            <Grid Grid.Row="0" ColumnDefinitions="*, Auto, Auto" IsVisible="{Binding IsConflict}" Margin="0,0,0,5">
                                                <TextBlock Text="{Binding LeftLabel}" Foreground="{StaticResource TextMuted}" FontSize="11" VerticalAlignment="Center"/>
                                                <Button Grid.Column="1" Command="{Binding AcceptLeftCommand}" Content="{Binding LeftButtonText}" IsVisible="{Binding LeftKeepVisible}" Classes="Success" Padding="5,2" FontSize="11" ToolTip.Tip="Apply Incoming"/>
                                                <Button Grid.Column="2" Command="{Binding DiscardLeftCommand}" Content="{Binding LeftDiscardText}" IsVisible="{Binding LeftDiscardVisible}" Classes="Danger" Padding="5,2" FontSize="11" Margin="5,0,0,0" ToolTip.Tip="Discard Change"/>
                                            </Grid>
                                    <TextBox Grid.Row="1" Text="{Binding LeftText}" IsReadOnly="True" Focusable="False" IsHitTestVisible="False" FontFamily="Consolas" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextPrimary}" AcceptsReturn="True" TextWrapping="Wrap">
                                        <TextBox.Styles>
                                            <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
                                                <Setter Property="Background" Value="Transparent" />
                                            </Style>
                                        </TextBox.Styles>
                                    </TextBox>
                                </Grid>
                            </Border>

                            <!-- Middle Column (Final Result) -->
                            <Border Grid.Column="2" Background="{Binding MiddleBackground}" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,1,0" Padding="5">
                                <Grid RowDefinitions="Auto, *">
                                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" IsVisible="{Binding IsConflict}" Margin="0,0,0,5">
                                        <Button Command="{Binding ClearFinalCommand}" Content="X Clear" Classes="Danger" Padding="5,2" FontSize="11" ToolTip.Tip="Clear Final Selection"/>
                                    </StackPanel>
                                    <TextBox Grid.Row="1" Text="{Binding FinalText}" IsReadOnly="True" Focusable="False" IsHitTestVisible="False" FontFamily="Consolas" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextPrimary}" AcceptsReturn="True" TextWrapping="Wrap">
                                        <TextBox.Styles>
                                            <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
                                                <Setter Property="Background" Value="Transparent" />
                                            </Style>
                                        </TextBox.Styles>
                                    </TextBox>
                                </Grid>
                            </Border>

                            <!-- Right Column (Yours) -->
                            <Border Grid.Column="4" Background="{Binding RightBackground}" Padding="5">
                                <Grid RowDefinitions="Auto, *">
                                    <Grid Grid.Row="0" ColumnDefinitions="Auto, Auto, *" IsVisible="{Binding IsConflict}" Margin="0,0,0,5">
                                        <Button Grid.Column="0" Command="{Binding AcceptRightCommand}" Content="{Binding RightButtonText}" IsVisible="{Binding RightKeepVisible}" Classes="Accent" Padding="5,2" FontSize="11" ToolTip.Tip="Apply Yours"/>
                                        <Button Grid.Column="1" Command="{Binding DiscardRightCommand}" Content="{Binding RightDiscardText}" IsVisible="{Binding RightDiscardVisible}" Classes="Danger" Padding="5,2" FontSize="11" Margin="5,0,0,0" ToolTip.Tip="Discard Change"/>
                                        <TextBlock Grid.Column="2" Text="{Binding RightLabel}" Foreground="{StaticResource TextMuted}" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                    <TextBox Grid.Row="1" Text="{Binding RightText}" IsReadOnly="True" Focusable="False" IsHitTestVisible="False" FontFamily="Consolas" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextPrimary}" AcceptsReturn="True" TextWrapping="Wrap">
                                        <TextBox.Styles>
                                            <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
                                                <Setter Property="Background" Value="Transparent" />
                                            </Style>
                                        </TextBox.Styles>
                                    </TextBox>
                                </Grid>
                            </Border>

                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
    <Canvas x:Name="MinimapCanvas" Grid.Column="1" Background="{StaticResource BgWindow}" Width="15" Margin="0,0,0,0" />
</Grid>

        <!-- Footer -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,10,0,0">
            <Button Content="Cancel" Command="{Binding CancelCommand}" Classes="Secondary" Width="100" HorizontalContentAlignment="Center" />
            <Button Content="Accept Changes" Command="{Binding SaveAndCloseCommand}" Classes="Accent" Padding="15,5" />
        </StackPanel>
    </Grid>
</Window>
