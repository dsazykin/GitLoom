<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GitLoom.App.ViewModels"
        x:Class="GitLoom.App.Views.OperationHistoryWindow"
        x:DataType="vm:OperationHistoryViewModel"
        Title="Operation History"
        Width="620" Height="520"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SurfaceWindow}">
    <Border Padding="20">
        <Grid RowDefinitions="Auto,*,Auto,Auto">

            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="0,0,0,15">
                <PathIcon Data="{StaticResource UndoIcon}" Width="18" Height="18" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                <TextBlock Text="Operation History" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                <TextBlock Text="Undo / redo any journaled operation" FontSize="12" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" Margin="6,3,0,0"/>
            </StackPanel>

            <!-- History list -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="8">
                    <ItemsControl ItemsSource="{Binding Entries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:OperationHistoryRowViewModel">
                                <Border Classes="Card" Background="{DynamicResource SurfaceCard}" Padding="12" Margin="0,0,0,2" CornerRadius="8">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{Binding Kind}" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource TextPrimary}"/>
                                                <Border CornerRadius="999" Background="{DynamicResource SurfaceHover}" Padding="8,1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding StatusText}" FontSize="10" Foreground="{DynamicResource TextMuted}"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Description}" FontSize="12" Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding When}" FontSize="10" Foreground="{DynamicResource TextMuted}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                            <Button Content="Undo" Classes="Primary" Padding="12,4"
                                                    Command="{Binding UndoCommand}"
                                                    IsVisible="{Binding !IsUndone}"
                                                    ToolTip.Tip="{Binding UndoBlockedReason}"/>
                                            <Button Content="Redo" Classes="Primary" Padding="12,4"
                                                    Command="{Binding RedoCommand}"
                                                    IsVisible="{Binding IsUndone}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="No operations recorded yet. Commit, branch, merge, or reset to see them here."
                               Foreground="{DynamicResource TextMuted}" FontSize="12"
                               IsVisible="{Binding !HasEntries}" Margin="4,8" TextWrapping="Wrap"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Error -->
            <TextBlock Grid.Row="2" Text="{Binding ErrorMessage}" Foreground="{DynamicResource DangerBrush}"
                       TextWrapping="Wrap" Margin="0,10,0,0" FontSize="12"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

            <!-- Footer -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                <Button Content="Close" Classes="Secondary" Padding="15,6" Command="{Binding CloseCommand}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
