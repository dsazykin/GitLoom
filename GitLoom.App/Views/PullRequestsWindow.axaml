<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GitLoom.App.ViewModels"
        xmlns:conv="using:GitLoom.App.Converters"
        x:Class="GitLoom.App.Views.PullRequestsWindow"
        x:DataType="vm:PullRequestsViewModel"
        Title="Pull Requests"
        Width="760" Height="620"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SurfaceWindow}">
    <Window.Resources>
      <conv:ReviewVerdictConverter x:Key="ReviewVerdictConverter" />
    </Window.Resources>
    <Border Padding="20">
        <Grid RowDefinitions="Auto,Auto,*,Auto,Auto">

            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="0,0,0,15">
                <PathIcon Data="{StaticResource GitHubIcon}" Width="18" Height="18" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                <TextBlock Text="Pull Requests" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                <TextBlock Text="Open, review, and merge pull requests without leaving GitLoom" FontSize="12" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" Margin="6,3,0,0"/>
            </StackPanel>

            <!-- Toolbar (only when the host is supported) -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="10" Margin="0,0,0,12"
                        IsVisible="{Binding IsSupported}">
                <Button Content="Create pull request" Classes="Primary" Padding="12,6"
                        Command="{Binding BeginCreateCommand}"
                        ToolTip.Tip="Open a pull request from the current branch"/>
                <Button Classes="IconButton" Command="{Binding RefreshListCommand}" ToolTip.Tip="Refresh"
                        Background="{DynamicResource SurfaceHoverGhost}">
                    <PathIcon Data="{StaticResource RefreshIcon}" Width="14" Height="14" Foreground="{DynamicResource TextMuted}"/>
                </Button>
                <TextBlock Text="{Binding CreateDisabledHint}" FontSize="11" Foreground="{DynamicResource TextMuted}"
                           VerticalAlignment="Center" TextWrapping="Wrap"
                           IsVisible="{Binding CreateDisabledHint, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
            </StackPanel>

            <!-- Body -->
            <Grid Grid.Row="2">

                <!-- Unsupported / no-token affordance -->
                <StackPanel Spacing="12" VerticalAlignment="Top" IsVisible="{Binding !IsSupported}">
                    <Border Classes="Card" Background="{DynamicResource SurfaceCard}" Padding="18" CornerRadius="8">
                        <StackPanel Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="{StaticResource CloudIcon}" Width="16" Height="16" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                                <TextBlock Text="Not connected" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{Binding UnsupportedHint}" FontSize="12" Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Supported: create form + list -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" IsVisible="{Binding IsSupported}">
                    <StackPanel Spacing="10">

                        <!-- Create-PR form -->
                        <Border Classes="Card" Background="{DynamicResource SurfaceCard}" Padding="14" CornerRadius="8"
                                IsVisible="{Binding IsCreating}">
                            <StackPanel Spacing="10">
                                <TextBlock Text="New pull request" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{Binding NewSourceBranch}" Classes="Mono" FontSize="12" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="→" FontSize="12" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding NewTargetBranch}" Watermark="target branch" MinWidth="160" FontSize="12"/>
                                </StackPanel>
                                <TextBox Text="{Binding NewTitle}" Watermark="Title" FontSize="13"/>
                                <TextBox Text="{Binding NewBody}" Watermark="Description (optional)" FontSize="12"
                                         AcceptsReturn="True" TextWrapping="Wrap" MinHeight="80"/>
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <CheckBox Content="Create as draft" IsChecked="{Binding NewIsDraft}" FontSize="12"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                    <Button Content="Create" Classes="Success" Padding="14,6" Command="{Binding SubmitCreateCommand}"/>
                                    <Button Content="Cancel" Classes="Secondary" Padding="14,6" Command="{Binding CancelCreateCommand}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- PR list -->
                        <ItemsControl ItemsSource="{Binding PullRequests}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:PullRequestRowViewModel">
                                    <Border Classes="Card" Background="{DynamicResource SurfaceCard}" Padding="14" Margin="0,0,0,2" CornerRadius="8">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel Grid.Column="0" Spacing="6" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="{Binding NumberText}" Classes="Mono" FontSize="12" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                                    <Border Background="{DynamicResource SurfaceHoverGhost}" CornerRadius="4" Padding="6,1" VerticalAlignment="Center"
                                                            IsVisible="{Binding ShowDraftBadge}">
                                                        <TextBlock Text="DRAFT" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMuted}"/>
                                                    </Border>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Spacing="10">
                                                    <TextBlock Text="{Binding BranchFlow}" Classes="Mono" FontSize="11" Foreground="{DynamicResource AccentBrush}"/>
                                                    <TextBlock Text="{Binding AuthorText}" FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                <Button Content="Check out locally" Classes="Primary" Padding="12,4" Command="{Binding CheckoutLocallyCommand}"
                                                        ToolTip.Tip="Fetch this PR into a separate worktree so you can build/run it without disturbing your current checkout"/>
                                                <Button Content="Review" Classes="Primary" Padding="12,4" Command="{Binding ReviewCommand}"
                                                        ToolTip.Tip="Read reviews &amp; inline comments and submit a review"/>
                                                <ComboBox ItemsSource="{Binding MergeMethods}" SelectedItem="{Binding SelectedMergeMethod}" MinWidth="90" FontSize="12"/>
                                                <Button Content="Merge" Classes="Success" Padding="12,4" Command="{Binding MergeCommand}"/>
                                                <Button Content="Close" Classes="Danger" Padding="12,4" Command="{Binding ClosePrCommand}"/>
                                                <Button Classes="IconButton" Command="{Binding OpenInBrowserCommand}"
                                                        IsVisible="{Binding HasUrl}" ToolTip.Tip="Open in browser"
                                                        Background="{DynamicResource SurfaceHoverGhost}">
                                                    <PathIcon Data="{StaticResource EyeIcon}" Width="14" Height="14" Foreground="{DynamicResource TextMuted}"/>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="No open pull requests. Create one from the current branch to get started."
                                   Foreground="{DynamicResource TextMuted}" FontSize="12"
                                   IsVisible="{Binding IsEmpty}" Margin="4,8" TextWrapping="Wrap"/>

                        <!-- Checked-out-locally banner (T-29): offer to open the freshly created worktree as a repo -->
                        <Border Classes="Card" Background="{DynamicResource AccentSelection}" Padding="12" CornerRadius="8"
                                Margin="0,8,0,0" IsVisible="{Binding CanOpenWorktree}">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding LastCheckoutPath, StringFormat='Checked out into {0}'}"
                                               FontSize="12" Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap"/>
                                    <TextBlock Text="Open it as a repository to build and review it."
                                               FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="Open worktree" Classes="Accent" Padding="14,6"
                                        VerticalAlignment="Center" Command="{Binding OpenWorktreeCommand}"/>
                            </Grid>
                        </Border>

                        <!-- Review panel (T-25): selected PR's reviews + inline comment threads + submit-review -->
                        <Border Classes="Card" Background="{DynamicResource SurfaceCard}" Padding="16" CornerRadius="8"
                                Margin="0,8,0,0" IsVisible="{Binding IsReviewOpen}">
                            <StackPanel Spacing="14">

                                <!-- Panel header -->
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <PathIcon Data="{StaticResource IssueIcon}" Width="15" Height="15" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="Review" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding SelectedReviewPr.NumberText}" Classes="Mono" FontSize="12" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding SelectedReviewPr.Title}" FontSize="12" Foreground="{DynamicResource TextMuted}" TextWrapping="NoWrap" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="Hide" Classes="Secondary" Padding="12,4" Command="{Binding CloseReviewCommand}"/>
                                </Grid>

                                <!-- Reviews -->
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Reviews" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                                    <ItemsControl ItemsSource="{Binding Reviews}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="vm:ReviewRowViewModel">
                                                <Border Background="{DynamicResource SurfaceHoverGhost}" CornerRadius="6" Padding="10" Margin="0,0,0,4">
                                                    <StackPanel Spacing="4">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <TextBlock Text="{Binding AuthorText}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                                                            <!-- Verdict badge (token-styled; VM holds no color) -->
                                                            <Border CornerRadius="4" Padding="6,1" VerticalAlignment="Center" IsVisible="{Binding IsApproved}"
                                                                    Background="{DynamicResource SurfaceHoverGhost}" BorderBrush="{DynamicResource SuccessBrush}" BorderThickness="1">
                                                                <TextBlock Text="Approved" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}"/>
                                                            </Border>
                                                            <Border CornerRadius="4" Padding="6,1" VerticalAlignment="Center" IsVisible="{Binding IsChangesRequested}"
                                                                    Background="{DynamicResource SurfaceHoverGhost}" BorderBrush="{DynamicResource DangerBrush}" BorderThickness="1">
                                                                <TextBlock Text="Changes requested" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource DangerBrush}"/>
                                                            </Border>
                                                            <Border CornerRadius="4" Padding="6,1" VerticalAlignment="Center" IsVisible="{Binding IsNeutral}"
                                                                    Background="{DynamicResource SurfaceHoverGhost}" BorderBrush="{DynamicResource TextMuted}" BorderThickness="1">
                                                                <TextBlock Text="{Binding VerdictText}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMuted}"/>
                                                            </Border>
                                                            <TextBlock Text="{Binding WhenText}" FontSize="11" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding Body}" FontSize="12" Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap"
                                                                   IsVisible="{Binding HasBody}"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="No reviews yet." FontSize="11" Foreground="{DynamicResource TextMuted}"
                                               IsVisible="{Binding !HasReviews}"/>
                                </StackPanel>

                                <!-- Inline comment threads (grouped by file path) -->
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Inline comments" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                                    <ItemsControl ItemsSource="{Binding CommentThreads}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="vm:ReviewThreadViewModel">
                                                <Border Background="{DynamicResource SurfaceHoverGhost}" CornerRadius="6" Padding="10" Margin="0,0,0,4">
                                                    <StackPanel Spacing="6">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <TextBlock Text="{Binding Path}" Classes="Mono" FontSize="11" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding CountText}" FontSize="10" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <ItemsControl ItemsSource="{Binding Comments}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate DataType="vm:ReviewCommentRowViewModel">
                                                                    <StackPanel Spacing="4" Margin="0,0,0,6">
                                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                                            <TextBlock Text="{Binding AuthorText}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                                                                            <Border CornerRadius="4" Padding="5,0" Background="{DynamicResource SurfaceHoverGhost}"
                                                                                    BorderBrush="{DynamicResource TextMuted}" BorderThickness="1" VerticalAlignment="Center"
                                                                                    IsVisible="{Binding HasLine}">
                                                                                <TextBlock Text="{Binding LineText}" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TextMuted}"/>
                                                                            </Border>
                                                                            <Border CornerRadius="4" Padding="5,0" Background="{DynamicResource SurfaceHoverGhost}"
                                                                                    BorderBrush="{DynamicResource WarningBrush}" BorderThickness="1" VerticalAlignment="Center"
                                                                                    IsVisible="{Binding IsOutdated}">
                                                                                <TextBlock Text="outdated" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource WarningBrush}"/>
                                                                            </Border>
                                                                        </StackPanel>
                                                                        <Border Background="{DynamicResource SurfaceCard}" CornerRadius="4" Padding="8,6"
                                                                                IsVisible="{Binding HasDiffHunk}">
                                                                            <TextBlock Text="{Binding DiffHunk}" Classes="Mono" FontSize="10" Foreground="{DynamicResource TextMuted}" TextWrapping="NoWrap"/>
                                                                        </Border>
                                                                        <TextBlock Text="{Binding Body}" FontSize="12" Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap"/>
                                                                    </StackPanel>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="No inline comments." FontSize="11" Foreground="{DynamicResource TextMuted}"
                                               IsVisible="{Binding !HasCommentThreads}"/>
                                </StackPanel>

                                <!-- Submit a review -->
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Submit a review" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Verdict" FontSize="12" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                                        <ComboBox ItemsSource="{Binding Verdicts}" SelectedItem="{Binding SubmitVerdict}" MinWidth="150" FontSize="12">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Converter={StaticResource ReviewVerdictConverter}}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                    <TextBox Text="{Binding ReviewBody}" Watermark="Review comment (required unless approving)" FontSize="12"
                                             AcceptsReturn="True" TextWrapping="Wrap" MinHeight="70"/>
                                    <Button Content="Submit review" Classes="Success" Padding="14,6" HorizontalAlignment="Left"
                                            Command="{Binding SubmitReviewCommand}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Error -->
            <TextBlock Grid.Row="3" Text="{Binding ErrorMessage}" Foreground="{DynamicResource DangerBrush}"
                       TextWrapping="Wrap" Margin="0,10,0,0" FontSize="12"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

            <!-- Footer -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                <Button Content="Close" Classes="Secondary" Padding="15,6" Command="{Binding CloseCommand}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
